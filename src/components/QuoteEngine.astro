---
---

<div class="bg-[#111827]/40 border border-slate-800/70 p-8 rounded-lg shadow-xl relative overflow-hidden max-w-4xl mx-auto" id="quote-container">
  <!-- Progress Header -->
  <div class="flex items-center justify-between mb-8 border-b border-slate-800/50 pb-4">
    <span class="text-xs font-mono uppercase tracking-widest text-slate-500">SYS_PROCUREMENT: STEP <span id="current-step-num">1</span> OF 4</span>
    <div class="flex gap-2">
      <div class="h-1.5 w-6 rounded-full bg-blue-600 step-dot"></div>
      <div class="h-1.5 w-6 rounded-full bg-slate-800 step-dot"></div>
      <div class="h-1.5 w-6 rounded-full bg-slate-800 step-dot"></div>
      <div class="h-1.5 w-6 rounded-full bg-slate-800 step-dot"></div>
    </div>
  </div>

  <form id="quote-form" class="space-y-6">
    <!-- STEP 1: Operations Division Selection -->
    <div class="step-panel space-y-4" data-step="1">
      <div class="space-y-2">
        <h3 class="text-xl font-bold text-white font-outfit uppercase">Select Operations Division</h3>
        <p class="text-slate-400 text-sm">Choose the operational framework for your shipment to apply correct regulatory routing.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-4">
        <!-- Division Option 1 -->
        <label class="border-2 border-slate-800 bg-[#0B0F19]/60 hover:bg-[#0b0f19] p-6 rounded-lg cursor-pointer flex flex-col justify-between transition-all relative group select-none" id="div-commercial">
          <input type="radio" name="logisticsType" value="commercial" class="absolute top-4 right-4 h-4 w-4 text-blue-600 focus:ring-0 focus:ring-offset-0 border-slate-800" checked />
          <div class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-widest text-blue-400">Division 01 // COM</span>
            <h4 class="text-lg font-bold text-white font-outfit">Commercial Cross-Border</h4>
            <p class="text-slate-400 text-xs leading-relaxed">
              Standard commercial oversized, flatbed, or stepdeck loads across regional corridors and Canada/US borders.
            </p>
          </div>
        </label>

        <!-- Division Option 2 -->
        <label class="border-2 border-slate-800 bg-[#0B0F19]/60 hover:bg-[#0b0f19] p-6 rounded-lg cursor-pointer flex flex-col justify-between transition-all relative group select-none" id="div-industrial">
          <input type="radio" name="logisticsType" value="industrial" class="absolute top-4 right-4 h-4 w-4 text-blue-600 focus:ring-0 focus:ring-offset-0 border-slate-800" />
          <div class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-widest text-amber-400">Division 02 // IND</span>
            <h4 class="text-lg font-bold text-white font-outfit">Specialized Industrial</h4>
            <p class="text-slate-400 text-xs leading-relaxed">
              Superload specs, heavy industrial machinery, and infrastructure components requiring route surveys and specialized permits.
            </p>
          </div>
        </label>
      </div>
    </div>

    <!-- STEP 2: Dimensional Configurations -->
    <div class="step-panel space-y-4 hidden" data-step="2">
      <div class="space-y-2">
        <h3 class="text-xl font-bold text-white font-outfit uppercase">Load Specifications</h3>
        <p class="text-slate-400 text-sm">Provide exact load dimensions. System will evaluate equipment specs in real-time.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4">
        <!-- Input fields -->
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="length" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Length (ft)</label>
              <input type="number" id="length" min="1" step="0.5" class="w-full bg-[#0B0F19] border border-slate-800 focus:border-blue-500 focus:outline-none rounded-md px-4 py-3 text-white text-sm" placeholder="48" />
            </div>
            <div>
              <label for="width" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Width (ft)</label>
              <input type="number" id="width" min="1" step="0.5" class="w-full bg-[#0B0F19] border border-slate-800 focus:border-blue-500 focus:outline-none rounded-md px-4 py-3 text-white text-sm" placeholder="8.5" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="height" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Height (ft)</label>
              <input type="number" id="height" min="1" step="0.5" class="w-full bg-[#0B0F19] border border-slate-800 focus:border-blue-500 focus:outline-none rounded-md px-4 py-3 text-white text-sm" placeholder="13.5" />
            </div>
            <div>
              <label for="weight" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Weight (lbs)</label>
              <input type="number" id="weight" min="1" step="50" class="w-full bg-[#0B0F19] border border-slate-800 focus:border-blue-500 focus:outline-none rounded-md px-4 py-3 text-white text-sm" placeholder="45000" />
            </div>
          </div>
        </div>

        <!-- Live Blueprint Visualizer Card -->
        <div class="bg-[#05070D] border border-slate-900 rounded-lg p-6 flex flex-col justify-between font-mono text-[9px] text-slate-500 relative scanlines min-h-60 overflow-hidden">
          <!-- Cyber Corner Accents -->
          <div class="absolute top-2 left-2 text-[8px] text-blue-500/80 font-bold uppercase tracking-wider flex items-center gap-1 select-none">// LIVE_BLUEPRINT_FOOTPRINT</div>
          
          <!-- Warning Indicator -->
          <div id="blueprint-warning" class="absolute top-2 right-2 px-1.5 py-0.5 rounded border border-rose-500/30 bg-rose-950/20 text-rose-400 font-bold hidden animate-pulse">OVERSIZED SUPERLOAD</div>

          <!-- SVG Visualizer Canvas -->
          <div class="flex-1 flex items-center justify-center py-4">
            <svg id="blueprint-svg" viewBox="0 0 300 120" class="w-full h-28 max-w-xs overflow-visible">
              <!-- Grid Background inside SVG -->
              <defs>
                <pattern id="blueprint-svg-grid" width="10" height="10" patternUnits="userSpaceOnUse">
                  <path d="M 10 0 L 0 0 0 10" fill="none" stroke="rgba(59, 130, 246, 0.08)" stroke-width="0.5"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#blueprint-svg-grid)" rx="4"/>
              
              <!-- Ground Reference line -->
              <line x1="10" y1="105" x2="290" y2="105" stroke="rgba(255, 255, 255, 0.15)" stroke-width="1" stroke-dasharray="2,2"/>

              <!-- Semi Truck Cab Reference (static) -->
              <path d="M 220,105 L 220,75 L 240,75 L 247,88 L 260,88 L 260,105 Z" fill="rgba(255, 255, 255, 0.04)" stroke="rgba(255, 255, 255, 0.25)" stroke-width="1"/>
              <!-- Wheels Cab -->
              <circle cx="227" cy="105" r="4.5" fill="#05070D" stroke="rgba(255, 255, 255, 0.3)"/>
              <circle cx="250" cy="105" r="4.5" fill="#05070D" stroke="rgba(255, 255, 255, 0.3)"/>

              <!-- Trailer flatbed template (static) -->
              <line x1="20" y1="92" x2="220" y2="92" stroke="rgba(255, 255, 255, 0.15)" stroke-width="2"/>
              <circle cx="35" cy="105" r="4.5" fill="#05070D" stroke="rgba(255, 255, 255, 0.3)"/>
              <circle cx="47" cy="105" r="4.5" fill="#05070D" stroke="rgba(255, 255, 255, 0.3)"/>

              <!-- Dynamic Cargo Footprint Box -->
              <rect id="blueprint-cargo-box" x="55" y="52" width="160" height="40" fill="rgba(59, 130, 246, 0.15)" stroke="#3b82f6" stroke-width="1" class="transition-all duration-300"/>
              
              <!-- Blueprint annotations -->
              <text id="blueprint-len-text" x="135" y="45" fill="rgba(255, 255, 255, 0.5)" text-anchor="middle">L: 48.0ft</text>
              <text id="blueprint-hgt-text" x="45" y="75" fill="rgba(255, 255, 255, 0.5)" text-anchor="end">H: 13.5ft</text>
            </svg>
          </div>

          <!-- Bottom Telemetry specs -->
          <div class="flex justify-between border-t border-slate-900 pt-2 text-slate-500 font-mono text-[9px] select-none">
            <span>WEIGHT: <span id="blueprint-weight-text" class="text-slate-300">45,000 LBS</span></span>
            <span>WIDTH: <span id="blueprint-width-text" class="text-slate-300">8.5 FT</span></span>
          </div>
        </div>
      </div>
    </div>

    <!-- STEP 3: Real-Time Regulatory Review -->
    <div class="step-panel space-y-4 hidden" data-step="3">
      <div class="space-y-2">
        <h3 class="text-xl font-bold text-white font-outfit uppercase">Regulatory Evaluation</h3>
        <p class="text-slate-400 text-sm">Lidar and permit calculations based on your physical specifications.</p>
      </div>

      <!-- Real-Time Evaluation Report Widget -->
      <div class="bg-[#0B0F19] rounded-lg border border-slate-800 p-6 space-y-6">
        <div class="flex items-center justify-between border-b border-slate-800/80 pb-4">
          <span class="text-xs font-mono uppercase tracking-widest text-slate-500">SYS_REPORT // AUTO_DIAGNOSTIC</span>
          <span class="text-xs px-2 py-1 rounded font-mono" id="permit-badge">EVALUATING</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-1.5">
            <span class="text-[10px] uppercase tracking-widest text-slate-500 block font-mono">Asset Allocation Suggestions:</span>
            <div class="text-base font-bold text-white" id="allocated-trailer">Calculating Optimal Trailer...</div>
            <p class="text-xs text-slate-400 leading-relaxed" id="allocated-desc">
              Analyzing dimensions to select flatbed, RGN, or heavy 13-axle combinations.
            </p>
          </div>

          <div class="space-y-2">
            <span class="text-[10px] uppercase tracking-widest text-slate-500 block font-mono">Special Directives Required:</span>
            <ul class="text-xs space-y-1.5 text-slate-300" id="directive-list">
              <li>- Operational clearance check</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- STEP 4: Corridor Contact -->
    <div class="step-panel space-y-4 hidden" data-step="4">
      <div class="space-y-2">
        <h3 class="text-xl font-bold text-white font-outfit uppercase">Secure Routing Detail</h3>
        <p class="text-slate-400 text-sm">Enter destination and contact profiles to dispatch pricing summaries to the edge Workers.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="origin" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Transit Origin</label>
          <input type="text" id="origin" class="w-full bg-[#0B0F19] border border-slate-800 focus:border-blue-500 focus:outline-none rounded-md px-4 py-3 text-white text-sm" placeholder="e.g., Charlottetown, PE" />
        </div>
        <div>
          <label for="destination" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Transit Destination</label>
          <input type="text" id="destination" class="w-full bg-[#0B0F19] border border-slate-800 focus:border-blue-500 focus:outline-none rounded-md px-4 py-3 text-white text-sm" placeholder="e.g., Fort McMurray, AB" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label for="contactName" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Contact Name</label>
          <input type="text" id="contactName" class="w-full bg-[#0B0F19] border border-slate-800 focus:border-blue-500 focus:outline-none rounded-md px-4 py-3 text-white text-sm" placeholder="Alex Carter" />
        </div>
        <div>
          <label for="contactEmail" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Email Address</label>
          <input type="email" id="contactEmail" class="w-full bg-[#0B0F19] border border-slate-800 focus:border-blue-500 focus:outline-none rounded-md px-4 py-3 text-white text-sm" placeholder="alex@carrier.com" />
        </div>
        <div>
          <label for="contactPhone" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Direct Phone</label>
          <input type="tel" id="contactPhone" class="w-full bg-[#0B0F19] border border-slate-800 focus:border-blue-500 focus:outline-none rounded-md px-4 py-3 text-white text-sm" placeholder="902-555-0144" />
        </div>
      </div>
      
      <!-- Cloudflare Turnstile Challenge -->
      <div class="flex justify-center pt-6" id="turnstile-quote-wrapper">
        <div id="turnstile-quote-widget"></div>
      </div>
    </div>

    <!-- Error/Status Box -->
    <div id="validation-errors" class="hidden text-xs text-rose-400 bg-rose-950/20 border border-rose-900/40 p-4 rounded-md"></div>

    <!-- Navigation Buttons -->
    <div class="flex justify-between items-center pt-4 border-t border-slate-800/50">
      <button type="button" id="prev-btn" class="hidden bg-slate-900 border border-slate-800 hover:border-slate-700 text-slate-400 hover:text-white px-6 py-3 rounded-md font-semibold text-sm transition-all duration-300">
        Previous Step
      </button>
      <div class="flex-1"></div>
      <button type="button" id="next-btn" class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-3.5 rounded-md font-semibold text-sm transition-all duration-300 transform hover:-translate-y-0.5 shadow-lg shadow-blue-600/10">
        Next Step
      </button>
    </div>
  </form>
</div>

<!-- Client-side Quote Engine Processing -->
<script>
  import { QuoteSchema } from '../lib/schemas';

  // State Management
  let currentStep = 1;
  const totalSteps = 4;
  const STORAGE_KEY = 'bro_quote_flow_v5';

  // Turnstile State
  let turnstileWidgetId: any = null;
  let turnstileToken = '';

  // DOM Elements
  const form = document.getElementById('quote-form') as HTMLFormElement;
  const panels = document.querySelectorAll('.step-panel');
  const dots = document.querySelectorAll('.step-dot');
  const currentStepNum = document.getElementById('current-step-num');
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const errorBox = document.getElementById('validation-errors');

  // Input Elements
  const getRadioVal = (name: string) => {
    const el = document.querySelector(`input[name="${name}"]:checked`) as HTMLInputElement | null;
    return el ? el.value : '';
  };
  const getNumberVal = (id: string) => {
    const el = document.getElementById(id) as HTMLInputElement | null;
    return el ? parseFloat(el.value) || 0 : 0;
  };
  const getStringVal = (id: string) => {
    const el = document.getElementById(id) as HTMLInputElement | null;
    return el ? el.value.trim() : '';
  };

  function renderTurnstileWidget() {
    const container = document.getElementById('turnstile-quote-widget');
    if (!container) return;

    if (!(window as any).turnstile) {
      setTimeout(renderTurnstileWidget, 500);
      return;
    }

    const turnstile = (window as any).turnstile;
    if (turnstileWidgetId !== null) {
      turnstile.reset(turnstileWidgetId);
      return;
    }

    try {
      turnstileWidgetId = turnstile.render('#turnstile-quote-widget', {
        sitekey: '1x00000000000000000000AA', // Testing sitekey (always passes)
        theme: 'dark',
        callback: function(token: string) {
          turnstileToken = token;
          if (errorBox) errorBox.classList.add('hidden');
        }
      });
    } catch (e) {
      console.error('Failed to render Turnstile widget', e);
    }
  }

  // Setup Step Changes
  function showStep(step: number) {
    panels.forEach((p) => {
      const panelStep = parseInt(p.getAttribute('data-step') || '1');
      if (panelStep === step) {
        p.classList.remove('hidden');
      } else {
        p.classList.add('hidden');
      }
    });

    dots.forEach((d, idx) => {
      if (idx + 1 <= step) {
        d.className = 'h-1.5 w-6 rounded-full bg-blue-600 step-dot';
      } else {
        d.className = 'h-1.5 w-6 rounded-full bg-slate-800 step-dot';
      }
    });

    if (currentStepNum) currentStepNum.innerText = step.toString();

    // Toggle Nav Buttons
    if (step === 1) {
      prevBtn.classList.add('hidden');
    } else {
      prevBtn.classList.remove('hidden');
    }

    if (step === totalSteps) {
      nextBtn.innerText = 'Submit Quote Request';
      nextBtn.className = 'bg-emerald-600 hover:bg-emerald-500 text-white px-8 py-3.5 rounded-md font-semibold text-sm transition-all duration-300 transform hover:-translate-y-0.5 shadow-lg shadow-emerald-600/10';
    } else {
      nextBtn.innerText = 'Next Step';
      nextBtn.className = 'bg-blue-600 hover:bg-blue-500 text-white px-8 py-3.5 rounded-md font-semibold text-sm transition-all duration-300 transform hover:-translate-y-0.5 shadow-lg shadow-blue-600/10';
    }

    if (step === 3) {
      runEvaluation();
    }

    if (step === 4) {
      renderTurnstileWidget();
    }
  }

  // Real-Time Evaluation logic for Step 3
  function runEvaluation() {
    const logisticsType = getRadioVal('logisticsType');
    const length = getNumberVal('length');
    const width = getNumberVal('width');
    const height = getNumberVal('height');
    const weight = getNumberVal('weight');

    const badge = document.getElementById('permit-badge');
    const allocatedTrailer = document.getElementById('allocated-trailer');
    const allocatedDesc = document.getElementById('allocated-desc');
    const directiveList = document.getElementById('directive-list');

    if (!badge || !allocatedTrailer || !allocatedDesc || !directiveList) return;

    // Check if Oversized
    const isOversized = width > 8.5 || height > 13.5 || length > 53 || weight > 45000;
    const isIndustrial = logisticsType === 'industrial';

    // Reset styles
    badge.className = 'text-xs px-2 py-1 rounded font-mono';
    directiveList.innerHTML = '';

    // Set Status Badge
    if (isOversized) {
      badge.innerText = 'OVERSIZED SUPERLOAD';
      badge.classList.add('bg-rose-950/40', 'text-rose-400', 'border', 'border-rose-900/30');
    } else {
      badge.innerText = 'STANDARD LOAD';
      badge.classList.add('bg-emerald-950/40', 'text-emerald-400', 'border', 'border-emerald-900/30');
    }

    // Allocate Equipment
    if (weight > 75000 || (width > 11 && weight > 50000)) {
      allocatedTrailer.innerText = '13-Axle Transport Combo';
      allocatedDesc.innerText = 'Allocated due to excessive load tonnage and oversized load width footprint. Jeeps and boosters will distribute ground pressure to clear regional highway bridges.';
    } else if (isOversized) {
      allocatedTrailer.innerText = 'Extendable RGN Lowboy Float';
      allocatedDesc.innerText = 'Removable Gooseneck selected. RGN configuration accommodates height restrictions by lowering structural clearance down to 12 inches.';
    } else {
      allocatedTrailer.innerText = 'Standard Stepdeck / Flatbed';
      allocatedDesc.innerText = 'Standard freight parameters detected. Cargo fits within standard commercial Flatbed or Stepdeck loading parameters.';
    }

    // Directives
    if (isIndustrial) {
      directiveList.innerHTML += `<li class="text-amber-400 font-mono">📋 Route survey & infrastructure assessment active</li>`;
      directiveList.innerHTML += `<li class="text-slate-300 font-mono">- Multi-jurisdictional permit filings required</li>`;
      directiveList.innerHTML += `<li class="text-slate-300 font-mono">- ACI eManifest customs transmission mandatory</li>`;
    } else {
      directiveList.innerHTML += `<li class="text-slate-400 font-mono">- Standard commercial shipping regulations</li>`;
    }

    if (isOversized) {
      directiveList.innerHTML += `<li class="text-rose-400 font-mono">⚠️ Oversized Load Permits (Ontario corridor)</li>`;
      if (width > 10) {
        directiveList.innerHTML += `<li class="text-rose-400 font-mono">⚠️ Escort Vehicles & Pilot Cars required</li>`;
      }
    }
  }

  // Local Storage Save
  function saveFlowData() {
    const data = {
      logisticsType: getRadioVal('logisticsType'),
      length: getNumberVal('length'),
      width: getNumberVal('width'),
      height: getNumberVal('height'),
      weight: getNumberVal('weight'),
      origin: getStringVal('origin'),
      destination: getStringVal('destination'),
      contactName: getStringVal('contactName'),
      contactEmail: getStringVal('contactEmail'),
      contactPhone: getStringVal('contactPhone'),
      currentStep
    };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  }

  // Local Storage Load
  function loadFlowData() {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (!saved) return;

    try {
      const data = JSON.parse(saved);
      
      // Set Radios
      const radio = document.querySelector(`input[name="logisticsType"][value="${data.logisticsType}"]`) as HTMLInputElement | null;
      if (radio) radio.checked = true;

      // Set Numbers
      const setNum = (id: string, val: number) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el && val) el.value = val.toString();
      };
      setNum('length', data.length);
      setNum('width', data.width);
      setNum('height', data.height);
      setNum('weight', data.weight);

      // Set Strings
      const setStr = (id: string, val: string) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el && val) el.value = val;
      };
      setStr('origin', data.origin);
      setStr('destination', data.destination);
      setStr('contactName', data.contactName);
      setStr('contactEmail', data.contactEmail);
      setStr('contactPhone', data.contactPhone);

      // Set step if cached
      if (data.currentStep) {
        currentStep = data.currentStep;
        showStep(currentStep);
      }
      updateBlueprint();
    } catch (e) {
      console.error('Failed to restore cached quote progress', e);
    }
  }

  function updateBlueprint() {
    const length = getNumberVal('length') || 48;
    const width = getNumberVal('width') || 8.5;
    const height = getNumberVal('height') || 13.5;
    const weight = getNumberVal('weight') || 45000;

    const cargoBox = document.getElementById('blueprint-cargo-box');
    const warning = document.getElementById('blueprint-warning');
    
    const lenText = document.getElementById('blueprint-len-text');
    const hgtText = document.getElementById('blueprint-hgt-text');
    const wdtText = document.getElementById('blueprint-width-text');
    const wgtText = document.getElementById('blueprint-weight-text');

    if (!cargoBox) return;

    // Scale mapping (max length 53, height 16)
    const mappedWidth = Math.max(30, Math.min(180, (length / 53) * 160));
    const mappedHeight = Math.max(10, Math.min(65, (height / 16) * 45));

    // Position box relative to wheels (cargo bed is at y = 92)
    const nextX = 220 - mappedWidth;
    const nextY = 92 - mappedHeight;

    cargoBox.setAttribute('x', nextX.toString());
    cargoBox.setAttribute('y', nextY.toString());
    cargoBox.setAttribute('width', mappedWidth.toString());
    cargoBox.setAttribute('height', mappedHeight.toString());

    // Update labels
    if (lenText) lenText.textContent = `L: ${length.toFixed(1)}ft`;
    if (hgtText) hgtText.textContent = `H: ${height.toFixed(1)}ft`;
    if (wdtText) wdtText.textContent = `${width.toFixed(1)} FT`;
    if (wgtText) wgtText.textContent = `${weight.toLocaleString()} LBS`;

    // Oversized status check
    const isOversized = width > 8.5 || height > 13.5 || length > 53 || weight > 45000;
    if (isOversized) {
      cargoBox.setAttribute('stroke', '#f97316'); // Orange
      cargoBox.setAttribute('fill', 'rgba(249, 115, 22, 0.15)');
      if (warning) warning.classList.remove('hidden');
    } else {
      cargoBox.setAttribute('stroke', '#3b82f6'); // Blue
      cargoBox.setAttribute('fill', 'rgba(59, 130, 246, 0.15)');
      if (warning) warning.classList.add('hidden');
    }
  }

  // Initialize
  loadFlowData();

  // Next Button Handler
  nextBtn?.addEventListener('click', () => {
    if (errorBox) errorBox.classList.add('hidden');

    // If on Step 4, validate everything with Zod and submit
    if (currentStep === totalSteps) {
      const payload = {
        logisticsType: getRadioVal('logisticsType'),
        length: getNumberVal('length'),
        width: getNumberVal('width'),
        height: getNumberVal('height'),
        weight: getNumberVal('weight'),
        origin: getStringVal('origin'),
        destination: getStringVal('destination'),
        contactName: getStringVal('contactName'),
        contactEmail: getStringVal('contactEmail'),
        contactPhone: getStringVal('contactPhone'),
        turnstileToken: turnstileToken
      };

      // Zod Validation
      const result = QuoteSchema.safeParse(payload);
      if (!result.success) {
        if (errorBox) {
          errorBox.innerHTML = result.error.errors.map((e) => `• ${e.message}`).join('<br />');
          errorBox.classList.remove('hidden');
        }
        return;
      }

      // Successful Validation - submit payload
      if (errorBox) {
        errorBox.className = 'text-xs text-emerald-400 bg-emerald-950/20 border border-emerald-900/40 p-4 rounded-md';
        errorBox.innerText = 'Payload verified. Transmitting secure payload to edge Cloudflare Workers...';
        errorBox.classList.remove('hidden');
      }

      const apiUrl = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
        ? 'http://127.0.0.1:8787/api/quote'
        : 'https://brotransport-edge-api.keshuin0.workers.dev/api/quote';

      fetch(apiUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      })
      .then(async (res) => {
        const data = await res.json();
        if (!res.ok) {
          throw new Error(data.error || 'Server rejected the request.');
        }
        return data;
      })
      .then((data) => {
        alert(`Quote submitted successfully! Decoupled edge worker response: ${data.message}`);
        localStorage.removeItem(STORAGE_KEY);
        form.reset();
        currentStep = 1;
        showStep(1);
        if (errorBox) errorBox.classList.add('hidden');
        // Reset turnstile widget
        if (turnstileWidgetId !== null && (window as any).turnstile) {
          (window as any).turnstile.reset(turnstileWidgetId);
          turnstileToken = '';
        }
      })
      .catch((err) => {
        if (errorBox) {
          errorBox.innerText = `Submission failed: ${err.message}`;
          errorBox.className = 'text-xs text-rose-400 bg-rose-950/20 border border-rose-900/40 p-4 rounded-md';
          errorBox.classList.remove('hidden');
        }
      });

      return;
    }

    // Step-by-Step input safety checks
    if (currentStep === 2) {
      const l = getNumberVal('length');
      const w = getNumberVal('width');
      const h = getNumberVal('height');
      const wt = getNumberVal('weight');
      if (l <= 0 || w <= 0 || h <= 0 || wt <= 0) {
        if (errorBox) {
          errorBox.innerText = 'Please enter valid dimension metrics (must be greater than 0).';
          errorBox.classList.remove('hidden');
        }
        return;
      }
    }

    currentStep++;
    showStep(currentStep);
    saveFlowData();
  });

  // Prev Button Handler
  prevBtn?.addEventListener('click', () => {
    if (errorBox) errorBox.classList.add('hidden');
    if (currentStep > 1) {
      currentStep--;
      showStep(currentStep);
      saveFlowData();
    }
  });

  // Save changes on input
  form?.addEventListener('input', () => {
    saveFlowData();
    updateBlueprint();
  });
</script>

