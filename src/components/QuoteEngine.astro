---
const base = import.meta.env.BASE_URL;
---
<div class="w-full max-w-2xl mx-auto bg-bro-steel/20 border border-bro-gold/30 rounded p-6 md:p-8 shadow-[0_0_30px_rgba(255,170,0,0.06)] relative overflow-hidden backdrop-blur-md cyber-corners-gold">
  
  <!-- Step Progress Header -->
  <div class="flex justify-between items-center mb-8 border-b border-slate-900 pb-4">
    <div class="space-y-1">
      <span class="text-[9px] font-mono text-slate-500 uppercase tracking-widest">// RATE_ENGINE_STEP</span>
      <h3 class="text-sm font-bold text-white font-mono uppercase text-bro-gold" id="step-title">01 // Cargo & Route</h3>
    </div>
    <div class="text-right">
      <span class="text-[10px] font-mono text-bro-gold font-bold" id="step-fraction">Step 1 of 3</span>
      <div class="w-24 h-1.5 bg-[#030307] rounded-full mt-1.5 overflow-hidden border border-slate-900">
        <div class="h-full bg-bro-gold transition-all duration-300" id="step-progress-bar" style="width: 33.3%;"></div>
      </div>
    </div>
  </div>

  <!-- Main Rate Form -->
  <form id="quote-flow-form" class="space-y-6">
    
    <!-- STEP 1: Trailer Type & Route -->
    <div id="step-card-1" class="space-y-6">
      <div class="space-y-3">
        <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider">Select Equipment Configuration:</label>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <!-- Dry Van Card -->
          <label id="card-dry-van" class="flex flex-col items-center justify-center p-4 border border-slate-900 rounded bg-[#030307]/50 cursor-pointer hover:border-bro-gold/40 transition-all select-none group">
            <input type="radio" name="trailerType" value="dry-van" class="sr-only" checked />
            <span class="text-[11px] font-bold text-slate-400 group-hover:text-white uppercase font-mono mb-1">Dry Van</span>
            <span class="text-[8px] text-slate-500 font-mono text-center">Standard 53ft Enclosed Cargo</span>
          </label>

          <!-- Reefer Card -->
          <label id="card-reefer" class="flex flex-col items-center justify-center p-4 border border-slate-900 rounded bg-[#030307]/50 cursor-pointer hover:border-bro-gold/40 transition-all select-none group">
            <input type="radio" name="trailerType" value="reefer" class="sr-only" />
            <span class="text-[11px] font-bold text-slate-400 group-hover:text-white uppercase font-mono mb-1">Reefer</span>
            <span class="text-[8px] text-slate-500 font-mono text-center">Climate-Controlled (-20°F to 80°F)</span>
          </label>

          <!-- Flatbed Card -->
          <label id="card-flatbed" class="flex flex-col items-center justify-center p-4 border border-slate-900 rounded bg-[#030307]/50 cursor-pointer hover:border-bro-gold/40 transition-all select-none group">
            <input type="radio" name="trailerType" value="flatbed" class="sr-only" />
            <span class="text-[11px] font-bold text-slate-400 group-hover:text-white uppercase font-mono mb-1">Flatbed</span>
            <span class="text-[8px] text-slate-500 font-mono text-center">Heavy Open-Deck Equipment</span>
          </label>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
        <div class="space-y-1.5">
          <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider">Origin Location:</label>
          <input type="text" name="origin" id="input-origin" placeholder="City, State/Province (e.g. Charlottetown, PE)" class="w-full bg-[#030307]/70 border border-slate-900 rounded p-3 text-white text-xs outline-none focus:border-bro-gold transition-colors" />
        </div>
        <div class="space-y-1.5">
          <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider">Destination Location:</label>
          <input type="text" name="destination" id="input-destination" placeholder="City, State/Province (e.g. Boston, MA)" class="w-full bg-[#030307]/70 border border-slate-900 rounded p-3 text-white text-xs outline-none focus:border-bro-gold transition-colors" />
        </div>
      </div>
    </div>

    <!-- STEP 2: Parameters & Load Weight -->
    <div id="step-card-2" class="space-y-6 hidden">
      <div class="space-y-3">
        <div class="flex justify-between items-center">
          <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider">Total Cargo Weight:</label>
          <span id="weight-display" class="text-xs font-bold text-bro-gold font-mono">20,000 LBS</span>
        </div>
        <input type="range" name="weight" id="slider-weight" min="1" max="45000" step="100" value="20000" class="w-full h-1 bg-[#030307] rounded-lg appearance-none cursor-pointer accent-bro-gold" />
        <div class="flex justify-between text-[8px] font-mono text-slate-650">
          <span>0 LBS</span>
          <span>MAX LEGAL LIMIT: 45,000 LBS</span>
        </div>
      </div>

      <!-- Conditional Reefer Temp Panel -->
      <div id="temp-control-panel" class="space-y-3 hidden border-t border-slate-900/60 pt-4">
        <div class="flex justify-between items-center">
          <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider">Refrigerated Temperature Setpoint:</label>
          <span id="temp-display" class="text-xs font-bold text-bro-gold font-mono">-18.0°C</span>
        </div>
        <input type="range" name="tempSetpoint" id="slider-temp" min="-25" max="25" step="0.5" value="-18" class="w-full h-1 bg-[#030307] rounded-lg appearance-none cursor-pointer accent-bro-gold" />
        <div class="flex justify-between text-[8px] font-mono text-slate-650">
          <span>-25°C (Frozen)</span>
          <span>+25°C (Warm)</span>
        </div>
      </div>

      <!-- Conditional Flatbed Equipment Checkboxes -->
      <div id="flatbed-control-panel" class="space-y-3 hidden border-t border-slate-900/60 pt-4 font-mono text-[9px] text-slate-400">
        <label class="block text-[10px] text-slate-500 uppercase tracking-wider">Flatbed Loading Requirements:</label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="flex items-center gap-2.5 p-3 bg-[#030307]/30 border border-slate-900 rounded cursor-pointer select-none">
            <input type="checkbox" name="requiresTarp" value="true" class="accent-bro-gold" />
            <span>Heavy-Duty Weather Tarping</span>
          </label>
          <label class="flex items-center gap-2.5 p-3 bg-[#030307]/30 border border-slate-900 rounded cursor-pointer select-none">
            <input type="checkbox" name="requiresStrapping" value="true" class="accent-bro-gold" />
            <span>Strap Tension Securement</span>
          </label>
        </div>
      </div>
    </div>

    <!-- STEP 3: Contact & Submit -->
    <div id="step-card-3" class="space-y-6 hidden">
      <div class="grid grid-cols-1 gap-4">
        <div class="space-y-1.5">
          <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider">Full Representative Name:</label>
          <input type="text" name="contactName" id="input-contactName" placeholder="e.g. John Miller" class="w-full bg-[#030307]/70 border border-slate-900 rounded p-3 text-white text-xs outline-none focus:border-bro-gold transition-colors" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider">Corporate Email:</label>
            <input type="email" name="contactEmail" id="input-contactEmail" placeholder="e.g. j.miller@corp.com" class="w-full bg-[#030307]/70 border border-slate-900 rounded p-3 text-white text-xs outline-none focus:border-bro-gold transition-colors" />
          </div>
          <div class="space-y-1.5">
            <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider">Direct Phone (10-Digit):</label>
            <input type="tel" name="contactPhone" id="input-contactPhone" placeholder="e.g. 9029166936" class="w-full bg-[#030307]/70 border border-slate-900 rounded p-3 text-white text-xs outline-none focus:border-bro-gold transition-colors" />
          </div>
        </div>
      </div>

      <!-- Cloudflare Security challenge container -->
      <div class="flex justify-center py-2.5">
        <div id="turnstile-quote-container" class="min-h-[65px]"></div>
      </div>
    </div>

    <!-- Error/Notice Info Box -->
    <div id="quote-error-box" class="hidden text-xs text-rose-450 bg-rose-950/20 border border-rose-900/40 p-4 rounded text-center"></div>

    <!-- Wizard Navigation buttons -->
    <div class="flex gap-4 border-t border-slate-900/60 pt-6">
      <button type="button" id="btn-prev" class="flex-1 py-3 border border-slate-800 hover:border-bro-gold/40 text-slate-400 hover:text-white rounded font-mono text-xs uppercase tracking-wider transition-colors duration-300 disabled:opacity-30 disabled:pointer-events-none cursor-pointer" disabled>
        Back
      </button>
      <button type="button" id="btn-next" class="flex-1 py-3 bg-bro-gold text-black hover:bg-bro-gold/90 font-bold rounded font-mono text-xs uppercase tracking-wider transition-colors duration-300 cursor-pointer shadow-[0_0_15px_rgba(255,170,0,0.15)]">
        Next Step
      </button>
    </div>

  </form>
</div>

<script>
  import { QuoteSchema } from '../lib/schemas';

  let currentStep = 1;
  const totalSteps = 3;
  const STORAGE_KEY = 'bro_quote_redesign_v1';

  let turnstileToken = '';
  let turnstileWidgetId: string | null = null;

  const form = document.getElementById('quote-flow-form') as HTMLFormElement;
  const card1 = document.getElementById('step-card-1');
  const card2 = document.getElementById('step-card-2');
  const card3 = document.getElementById('step-card-3');

  const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;

  const stepTitle = document.getElementById('step-title');
  const stepFraction = document.getElementById('step-fraction');
  const progressBar = document.getElementById('step-progress-bar');
  const errorBox = document.getElementById('quote-error-box');

  const sliderWeight = document.getElementById('slider-weight') as HTMLInputElement;
  const weightDisplay = document.getElementById('weight-display');
  const sliderTemp = document.getElementById('slider-temp') as HTMLInputElement;
  const tempDisplay = document.getElementById('temp-display');

  const tempPanel = document.getElementById('temp-control-panel');
  const flatbedPanel = document.getElementById('flatbed-control-panel');

  const trailerRadios = document.getElementsByName('trailerType') as NodeListOf<HTMLInputElement>;

  // Show selected step UI card
  function showStep(step: number) {
    if (!card1 || !card2 || !card3 || !stepTitle || !stepFraction || !progressBar || !btnPrev || !btnNext) return;

    card1.classList.add('hidden');
    card2.classList.add('hidden');
    card3.classList.add('hidden');

    if (step === 1) {
      card1.classList.remove('hidden');
      stepTitle.innerText = "01 // Cargo & Route";
      stepFraction.innerText = "Step 1 of 3";
      progressBar.style.width = "33.3%";
      btnPrev.disabled = true;
      btnNext.innerText = "Next Step";
    } else if (step === 2) {
      card2.classList.remove('hidden');
      stepTitle.innerText = "02 // Load Parameters";
      stepFraction.innerText = "Step 2 of 3";
      progressBar.style.width = "66.6%";
      btnPrev.disabled = false;
      btnNext.innerText = "Next Step";
      updateConditionalPanels();
    } else if (step === 3) {
      card3.classList.remove('hidden');
      stepTitle.innerText = "03 // Contact Details";
      stepFraction.innerText = "Step 3 of 3";
      progressBar.style.width = "100%";
      btnPrev.disabled = false;
      btnNext.innerText = "Request Quote";
      initTurnstile();
    }
  }

  function getTrailerType() {
    let checked = 'dry-van';
    trailerRadios.forEach(radio => {
      if (radio.checked) checked = radio.value;
    });
    return checked;
  }

  function updateConditionalPanels() {
    if (!tempPanel || !flatbedPanel) return;
    const type = getTrailerType();
    
    tempPanel.classList.add('hidden');
    flatbedPanel.classList.add('hidden');

    if (type === 'reefer') {
      tempPanel.classList.remove('hidden');
    } else if (type === 'flatbed') {
      flatbedPanel.classList.remove('hidden');
    }
  }

  // Handle Turnstile Initialization
  function initTurnstile() {
    if (turnstileWidgetId !== null) return;
    const container = document.getElementById('turnstile-quote-container');
    if (!container || !(window as any).turnstile) return;

    turnstileWidgetId = (window as any).turnstile.render(container, {
      sitekey: '0x4AAAAAAA2I6F9JkSivv8tZ',
      callback: function(token: string) {
        turnstileToken = token;
        if (errorBox) errorBox.classList.add('hidden');
      }
    });
  }

  // Update slider displays
  if (sliderWeight && weightDisplay) {
    sliderWeight.addEventListener('input', () => {
      weightDisplay.innerText = `${parseInt(sliderWeight.value).toLocaleString()} LBS`;
    });
  }

  if (sliderTemp && tempDisplay) {
    sliderTemp.addEventListener('input', () => {
      tempDisplay.innerText = `${parseFloat(sliderTemp.value).toFixed(1)}°C`;
    });
  }

  // Radio selection card styles toggler (uses gold border highlights)
  function updateCardStyles() {
    const type = getTrailerType();
    ['dry-van', 'reefer', 'flatbed'].forEach(t => {
      const card = document.getElementById(`card-${t}`);
      if (card) {
        if (t === type) {
          card.classList.add('border-bro-gold', 'bg-bro-gold/10');
          card.classList.remove('border-slate-900', 'bg-[#030307]/50');
        } else {
          card.classList.remove('border-bro-gold', 'bg-bro-gold/10');
          card.classList.add('border-slate-900', 'bg-[#030307]/50');
        }
      }
    });
  }

  trailerRadios.forEach(radio => {
    radio.addEventListener('change', updateCardStyles);
  });

  updateCardStyles();

  // Load / Save Session Form Data
  function loadFormState() {
    try {
      const data = sessionStorage.getItem(STORAGE_KEY);
      if (!data) return;
      const parsed = JSON.parse(data);
      if (parsed.trailerType) {
        trailerRadios.forEach(r => { if (r.value === parsed.trailerType) r.checked = true; });
      }
      if (parsed.origin) (document.getElementById('input-origin') as HTMLInputElement).value = parsed.origin;
      if (parsed.destination) (document.getElementById('input-destination') as HTMLInputElement).value = parsed.destination;
      if (parsed.weight) {
        sliderWeight.value = parsed.weight;
        if (weightDisplay) weightDisplay.innerText = `${parseInt(parsed.weight).toLocaleString()} LBS`;
      }
      if (parsed.tempSetpoint && sliderTemp) {
        sliderTemp.value = parsed.tempSetpoint;
        if (tempDisplay) tempDisplay.innerText = `${parseFloat(parsed.tempSetpoint).toFixed(1)}°C`;
      }
      if (parsed.contactName) (document.getElementById('input-contactName') as HTMLInputElement).value = parsed.contactName;
      if (parsed.contactEmail) (document.getElementById('input-contactEmail') as HTMLInputElement).value = parsed.contactEmail;
      if (parsed.contactPhone) (document.getElementById('input-contactPhone') as HTMLInputElement).value = parsed.contactPhone;

      updateCardStyles();
    } catch(e) {}
  }

  function saveFormState() {
    const payload = {
      trailerType: getTrailerType(),
      origin: (document.getElementById('input-origin') as HTMLInputElement).value,
      destination: (document.getElementById('input-destination') as HTMLInputElement).value,
      weight: parseInt(sliderWeight.value),
      tempSetpoint: getTrailerType() === 'reefer' ? parseFloat(sliderTemp.value) : undefined,
      contactName: (document.getElementById('input-contactName') as HTMLInputElement).value,
      contactEmail: (document.getElementById('input-contactEmail') as HTMLInputElement).value,
      contactPhone: (document.getElementById('input-contactPhone') as HTMLInputElement).value,
    };
    sessionStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
  }

  form.addEventListener('input', saveFormState);

  // Navigation handlers
  btnPrev.addEventListener('click', () => {
    if (currentStep > 1) {
      currentStep--;
      showStep(currentStep);
    }
  });

  btnNext.addEventListener('click', () => {
    if (errorBox) errorBox.classList.add('hidden');

    if (currentStep === 1) {
      // Basic validation for Step 1
      const origin = (document.getElementById('input-origin') as HTMLInputElement).value;
      const dest = (document.getElementById('input-destination') as HTMLInputElement).value;
      if (origin.length < 3 || dest.length < 3) {
        if (errorBox) {
          errorBox.innerText = "Origin and destination address must be at least 3 characters.";
          errorBox.classList.remove('hidden');
        }
        return;
      }
      currentStep = 2;
      showStep(currentStep);
    } else if (currentStep === 2) {
      currentStep = 3;
      showStep(currentStep);
    } else if (currentStep === 3) {
      submitForm();
    }
  });

  function submitForm() {
    if (!errorBox) return;

    const payload = {
      trailerType: getTrailerType(),
      weight: parseInt(sliderWeight.value),
      tempSetpoint: getTrailerType() === 'reefer' ? parseFloat(sliderTemp.value) : undefined,
      origin: (document.getElementById('input-origin') as HTMLInputElement).value,
      destination: (document.getElementById('input-destination') as HTMLInputElement).value,
      contactName: (document.getElementById('input-contactName') as HTMLInputElement).value,
      contactEmail: (document.getElementById('input-contactEmail') as HTMLInputElement).value,
      contactPhone: (document.getElementById('input-contactPhone') as HTMLInputElement).value,
      turnstileToken: turnstileToken
    };

    const validation = QuoteSchema.safeParse(payload);
    if (!validation.success) {
      errorBox.innerHTML = validation.error.errors.map(e => `• ${e.message}`).join('<br/>');
      errorBox.className = 'text-xs text-rose-450 bg-rose-950/20 border border-rose-900/40 p-4 rounded text-center';
      errorBox.classList.remove('hidden');
      return;
    }

    // Processing Submit
    errorBox.className = 'text-xs text-bro-gold bg-bro-gold/10 border border-bro-gold/30 p-4 rounded animate-pulse text-center';
    errorBox.innerText = "TRANSMITTING ENCRYPTED RATE CALCULATIONS...";
    errorBox.classList.remove('hidden');

    const apiUrl = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? 'http://127.0.0.1:8787/api/quote'
      : 'https://brotransport-edge-api.keshuin0.workers.dev/api/quote';

    fetch(apiUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(async (res) => {
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Uplink transmission rejected.');
      return data;
    })
    .then((data) => {
      alert(`Quote calculation successful! Estimated shipping price: $${data.estimatedPrice || 'Contact Desk'} CAD. Reference ID: ${data.manifestId || 'BROP-REF'}`);
      sessionStorage.removeItem(STORAGE_KEY);
      form.reset();
      currentStep = 1;
      showStep(1);
      errorBox.classList.add('hidden');
      if (turnstileWidgetId !== null && (window as any).turnstile) {
        (window as any).turnstile.reset(turnstileWidgetId);
        turnstileToken = '';
      }
    })
    .catch((err) => {
      errorBox.innerText = `Quote uplink failed: ${err.message}`;
      errorBox.className = 'text-xs text-rose-450 bg-rose-950/20 border border-rose-900/40 p-4 rounded text-center';
      errorBox.classList.remove('hidden');
    });
  }

  document.addEventListener('astro:page-load', () => {
    loadFormState();
    showStep(currentStep);
  });
</script>
