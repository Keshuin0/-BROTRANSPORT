---
const base = import.meta.env.BASE_URL;
---

<div class="bg-[#020408]/90 border border-slate-900 p-8 rounded-lg shadow-2xl relative overflow-hidden max-w-4xl mx-auto scanlines cyber-corners" id="quote-container">
  <!-- Progress Header -->
  <div class="flex items-center justify-between mb-8 border-b border-slate-900 pb-4">
    <span class="text-xs font-mono uppercase tracking-widest text-slate-500">SYS_PROCUREMENT: STEP <span id="current-step-num">1</span> OF 4</span>
    <div class="flex gap-2">
      <div class="h-1.5 w-6 rounded-full bg-cyan-400 shadow-[0_0_6px_#00f0ff] step-dot"></div>
      <div class="h-1.5 w-6 rounded-full bg-slate-900 step-dot"></div>
      <div class="h-1.5 w-6 rounded-full bg-slate-900 step-dot"></div>
      <div class="h-1.5 w-6 rounded-full bg-slate-900 step-dot"></div>
    </div>
  </div>

  <form id="quote-form" class="space-y-6">
    <!-- STEP 1: Trailer Type Selection -->
    <div class="step-panel space-y-4" data-step="1">
      <div class="space-y-2">
        <h3 class="text-xl font-bold text-white font-display uppercase">Select Equipment Class</h3>
        <p class="text-slate-400 text-sm">Choose the specific trailer configuration to allocate for this manifest.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-4">
        <!-- Option 1: Dry Van -->
        <label class="border border-slate-900 bg-slate-950/60 hover:bg-slate-950 p-6 rounded-lg cursor-pointer flex flex-col justify-between transition-all relative group select-none hover:border-cyan-500/30" id="card-dry-van">
          <input type="radio" name="trailerType" value="dry-van" class="absolute top-4 right-4 h-4 w-4 text-cyan-400 focus:ring-0 focus:ring-offset-0 border-slate-900" checked />
          <div class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-widest text-cyan-400 font-mono">DIV_01 // DRY</span>
            <h4 class="text-lg font-bold text-white font-display uppercase">Enclosed Dry Van</h4>
            <p class="text-slate-455 text-xs leading-relaxed">
              Standard 53ft aluminum box trailer. Fully weatherproof security for general commodities and palletized dry goods.
            </p>
          </div>
        </label>

        <!-- Option 2: Reefer -->
        <label class="border border-slate-900 bg-slate-950/60 hover:bg-slate-950 p-6 rounded-lg cursor-pointer flex flex-col justify-between transition-all relative group select-none hover:border-cyan-500/30" id="card-reefer">
          <input type="radio" name="trailerType" value="reefer" class="absolute top-4 right-4 h-4 w-4 text-cyan-400 focus:ring-0 focus:ring-offset-0 border-slate-900" />
          <div class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-widest text-cyan-400 font-mono">DIV_02 // REF</span>
            <h4 class="text-lg font-bold text-white font-display uppercase">Refrigerated Reefer</h4>
            <p class="text-slate-455 text-xs leading-relaxed">
              53ft insulated climate-controlled trailer. High-performance Thermo King unit for temperature-sensitive cargo.
            </p>
          </div>
        </label>

        <!-- Option 3: Flatbed -->
        <label class="border border-slate-900 bg-slate-950/60 hover:bg-slate-950 p-6 rounded-lg cursor-pointer flex flex-col justify-between transition-all relative group select-none hover:border-blaze/30" id="card-flatbed">
          <input type="radio" name="trailerType" value="flatbed" class="absolute top-4 right-4 h-4 w-4 text-blaze focus:ring-0 focus:ring-offset-0 border-slate-900" />
          <div class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-widest text-[#ff6000] font-mono">DIV_03 // FLT</span>
            <h4 class="text-lg font-bold text-white font-display uppercase">Open Deck Flatbed</h4>
            <p class="text-slate-455 text-xs leading-relaxed">
              53ft steel open platform. Specially outfitted with securement gear, straps, chains, and heavy weather tarps.
            </p>
          </div>
        </label>
      </div>
    </div>

    <!-- STEP 2: Load Specifications -->
    <div class="step-panel space-y-4 hidden" data-step="2">
      <div class="space-y-2">
        <h3 class="text-xl font-bold text-white font-display uppercase">Chassis Load Specifications</h3>
        <p class="text-slate-400 text-sm">Provide exact weight parameters. System will evaluate structural axle flex in real-time.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 pt-4">
        <div class="space-y-6">
          <!-- Weight Input Slider -->
          <div class="space-y-2">
            <label for="weight" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 font-mono">Cargo Weight (LBS):</label>
            <div class="bg-black/50 border border-slate-900 p-4 rounded-md space-y-3">
              <div class="flex justify-between items-center text-xs font-mono">
                <span class="text-slate-500">Legal limit: 45,000 lbs</span>
                <span id="weight-slider-val" class="text-cyan-400 font-bold text-sm">30,000 LBS</span>
              </div>
              <input type="range" id="weight" min="1000" max="45000" step="500" value="30000" class="w-full h-1 bg-slate-900 rounded-lg appearance-none cursor-pointer accent-[#00f0ff]" />
            </div>
          </div>

          <!-- Temperature setpoint (Only visible for Reefer) -->
          <div class="space-y-2 hidden" id="temp-input-wrapper">
            <label for="tempSetpoint" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 font-mono">Reefer Temperature (°C):</label>
            <div class="bg-black/50 border border-slate-900 p-4 rounded-md space-y-3">
              <div class="flex justify-between items-center text-xs font-mono">
                <span class="text-slate-500">Range: -20°C to 15°C</span>
                <span id="temp-slider-val" class="text-cyan-400 font-bold text-sm">-18°C</span>
              </div>
              <input type="range" id="tempSetpoint" min="-20" max="15" step="1" value="-18" class="w-full h-1 bg-slate-900 rounded-lg appearance-none cursor-pointer accent-[#00f0ff]" />
            </div>
          </div>
        </div>

        <!-- Live Blueprint Visualizer Card -->
        <div class="bg-[#020408]/90 border border-slate-900 rounded-lg p-6 flex flex-col justify-between font-mono text-[9px] text-slate-500 relative scanlines min-h-60 overflow-hidden">
          <div class="absolute top-2 left-2 text-[8px] text-[#00f0ff] font-bold uppercase tracking-wider flex items-center gap-1 select-none">// DYNAMIC_BLUEPRINT_HUD</div>
          <div id="blueprint-warning" class="absolute top-2 right-2 px-1.5 py-0.5 rounded border border-rose-500/30 bg-rose-950/20 text-rose-400 font-bold hidden animate-pulse">MAX WEIGHT LIMIT</div>

          <!-- Dynamic SVG Blueprint Canvas -->
          <div class="flex-1 flex items-center justify-center py-4">
            <svg id="blueprint-svg" viewBox="0 0 300 120" class="w-full h-28 max-w-xs overflow-visible bg-black/55 border border-slate-900 rounded">
              <!-- Grid Pattern -->
              <defs>
                <pattern id="blueprint-grid" width="10" height="10" patternUnits="userSpaceOnUse">
                  <path d="M 10 0 L 0 0 0 10" fill="none" stroke="rgba(0, 240, 255, 0.05)" stroke-width="0.5"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#blueprint-grid)" rx="4"/>
              
              <!-- Ground Line -->
              <line x1="10" y1="105" x2="290" y2="105" stroke="rgba(255, 255, 255, 0.1)" stroke-width="1" stroke-dasharray="2,2"/>

              <!-- Tractor Cabin Outline -->
              <path d="M 215,105 L 215,75 L 235,75 L 242,88 L 255,88 L 255,105 Z" fill="rgba(255, 255, 255, 0.03)" stroke="rgba(255, 255, 255, 0.2)" stroke-width="1"/>
              <circle cx="222" cy="105" r="4" fill="#020408" stroke="rgba(255, 255, 255, 0.2)"/>
              <circle cx="245" cy="105" r="4" fill="#020408" stroke="rgba(255, 255, 255, 0.2)"/>

              <!-- Wheels (static trailer tandems) -->
              <circle cx="35" cy="105" r="4" fill="#020408" stroke="rgba(255, 255, 255, 0.2)"/>
              <circle cx="47" cy="105" r="4" fill="#020408" stroke="rgba(255, 255, 255, 0.2)"/>

              <!-- DYNAMIC TRAILER BLUEPRINT PATHS -->
              <!-- Dry Van Shell -->
              <g id="svg-dry-van" class="transition-all duration-300">
                <rect x="20" y="50" width="190" height="42" fill="none" stroke="#00f0ff" stroke-width="1.5" />
                <line x1="20" y1="50" x2="20" y2="92" stroke="#00f0ff" stroke-width="1" stroke-dasharray="2,2" />
                <!-- Pallets in Dry Van -->
                <rect x="30" y="65" width="20" height="27" fill="rgba(0, 240, 255, 0.15)" stroke="#00f0ff" stroke-width="0.5" />
                <rect x="60" y="65" width="20" height="27" fill="rgba(0, 240, 255, 0.15)" stroke="#00f0ff" stroke-width="0.5" />
                <rect x="90" y="65" width="20" height="27" fill="rgba(0, 240, 255, 0.15)" stroke="#00f0ff" stroke-width="0.5" />
                <rect x="120" y="65" width="20" height="27" fill="rgba(0, 240, 255, 0.15)" stroke="#00f0ff" stroke-width="0.5" />
              </g>

              <!-- Reefer Shell -->
              <g id="svg-reefer" class="hidden transition-all duration-300">
                <!-- Insulated Box -->
                <rect x="25" y="50" width="185" height="42" fill="none" stroke="#00f0ff" stroke-width="1.5" />
                <!-- Nosemount cooling unit -->
                <path d="M 210,55 L 210,75 L 218,75 L 218,55 Z" fill="rgba(0, 240, 255, 0.2)" stroke="#00f0ff" stroke-width="1" />
                <circle cx="214" cy="65" r="2.5" fill="none" stroke="#00f0ff" stroke-width="0.5" class="animate-pulse" />
                <!-- Cooling zone gradient overlay -->
                <rect x="30" y="53" width="175" height="36" fill="rgba(0, 240, 255, 0.05)" />
                <text x="110" y="74" fill="#00f0ff" font-family="monospace" font-size="7" id="blueprint-temp-overlay" opacity="0.8">TEMP: -18°C</text>
              </g>

              <!-- Flatbed Shell -->
              <g id="svg-flatbed" class="hidden transition-all duration-300">
                <!-- Flat platform deck (bends based on weight) -->
                <path id="blueprint-flatbed-deck" d="M 20 92 Q 115 92 210 92" fill="none" stroke="#ff6000" stroke-width="3" />
                <!-- Load outline on top of deck (Cargo box) -->
                <rect id="blueprint-flatbed-cargo" x="80" y="62" width="70" height="30" fill="rgba(255, 96, 0, 0.15)" stroke="#ff6000" stroke-width="1" />
                <!-- Cargo straps -->
                <line id="blueprint-strap-1" x1="95" y1="62" x2="95" y2="92" stroke="#ff6000" stroke-width="0.75" />
                <line id="blueprint-strap-2" x1="115" y1="62" x2="115" y2="92" stroke="#ff6000" stroke-width="0.75" />
                <line id="blueprint-strap-3" x1="135" y1="62" x2="135" y2="92" stroke="#ff6000" stroke-width="0.75" />
              </g>
            </svg>
          </div>

          <!-- Bottom Telemetry specs -->
          <div class="flex justify-between border-t border-slate-900 pt-2 text-slate-500 font-mono text-[9px] select-none">
            <span>AXLE FLEX: <span id="blueprint-flex-text" class="text-slate-300">NORMAL</span></span>
            <span>TONNAGE: <span id="blueprint-ton-text" class="text-slate-300">15.0 TONS</span></span>
          </div>
        </div>
      </div>
    </div>

    <!-- STEP 3: Real-Time Rates & Compliance -->
    <div class="step-panel space-y-4 hidden" data-step="3">
      <div class="space-y-2">
        <h3 class="text-xl font-bold text-white font-display uppercase">Telemetry Rate Assessment</h3>
        <p class="text-slate-400 text-sm">Calculated operational pricing coordinates based on dispatch algorithms.</p>
      </div>

      <!-- Real-Time Evaluation Report Widget -->
      <div class="bg-[#05070d] rounded-lg border border-slate-900 p-6 space-y-6">
        <div class="flex items-center justify-between border-b border-slate-900 pb-4">
          <span class="text-xs font-mono uppercase tracking-widest text-slate-500">SYS_REPORT // AUTO_DIAGNOSTIC</span>
          <span class="text-xs px-2 py-1 rounded font-mono bg-cyan-950/40 text-cyan-400 border border-cyan-900/30" id="permit-badge">ESTIMATING RATE</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <span class="text-[10px] uppercase tracking-widest text-slate-500 block font-mono">Assigned Asset:</span>
            <div class="text-base font-bold text-white uppercase" id="allocated-trailer">53FT Enclosed Carrier</div>
            <p class="text-xs text-slate-400 leading-relaxed" id="allocated-desc">
              Standard commercial enclosed asset suited for dry van loads.
            </p>
          </div>

          <div class="space-y-3">
            <span class="text-[10px] uppercase tracking-widest text-slate-500 block font-mono">Pricing Variables:</span>
            <div class="bg-black/60 border border-slate-900 p-4 rounded space-y-2 font-mono text-[10px]">
              <div class="flex justify-between">
                <span class="text-slate-500">BASE MILEAGE RATE:</span>
                <span class="text-white font-bold" id="rate-base">$2.20 / MILE</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-500">SURCHARGES (WEIGHT/TEMP):</span>
                <span class="text-[#ff6000] font-bold" id="rate-surcharges">$0.00 / MILE</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-500">CROSS-BORDER MANIFEST FEE:</span>
                <span class="text-white font-bold">$75.00</span>
              </div>
              <div class="border-t border-slate-900 pt-2 flex justify-between text-xs">
                <span class="text-slate-400 font-bold">TOTAL MILEAGE RATE:</span>
                <span class="text-[#00f0ff] font-bold" id="rate-total">$2.20 / MILE</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- STEP 4: Corridor Routing & Contact -->
    <div class="step-panel space-y-4 hidden" data-step="4">
      <div class="space-y-2">
        <h3 class="text-xl font-bold text-white font-display uppercase">Secure Routing Detail</h3>
        <p class="text-slate-400 text-sm">Enter destination and contact profiles to dispatch pricing summaries to the edge Workers.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="space-y-1">
          <label for="origin" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 font-mono">Transit Origin</label>
          <input type="text" id="origin" class="w-full bg-[#05070d] border border-slate-900 focus:border-[#00f0ff] focus:outline-none rounded px-4 py-3 text-white text-sm font-mono placeholder:text-slate-800" placeholder="e.g. Charlottetown, PE" />
        </div>
        <div class="space-y-1">
          <label for="destination" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 font-mono">Transit Destination</label>
          <input type="text" id="destination" class="w-full bg-[#05070d] border border-slate-900 focus:border-[#00f0ff] focus:outline-none rounded px-4 py-3 text-white text-sm font-mono placeholder:text-slate-800" placeholder="e.g. Toronto, ON" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="space-y-1">
          <label for="contactName" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 font-mono">Contact Name</label>
          <input type="text" id="contactName" class="w-full bg-[#05070d] border border-slate-900 focus:border-[#00f0ff] focus:outline-none rounded px-4 py-3 text-white text-sm font-mono placeholder:text-slate-800" placeholder="Alex Carter" />
        </div>
        <div class="space-y-1">
          <label for="contactEmail" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 font-mono">Email Address</label>
          <input type="email" id="contactEmail" class="w-full bg-[#05070d] border border-slate-900 focus:border-[#00f0ff] focus:outline-none rounded px-4 py-3 text-white text-sm font-mono placeholder:text-slate-800" placeholder="alex@carrier.com" />
        </div>
        <div class="space-y-1">
          <label for="contactPhone" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 font-mono">Direct Phone</label>
          <input type="tel" id="contactPhone" class="w-full bg-[#05070d] border border-slate-900 focus:border-[#00f0ff] focus:outline-none rounded px-4 py-3 text-white text-sm font-mono placeholder:text-slate-800" placeholder="902-555-0144" />
        </div>
      </div>
      
      <!-- Cloudflare Turnstile Challenge -->
      <div class="flex justify-center pt-6" id="turnstile-quote-wrapper">
        <div id="turnstile-quote-widget"></div>
      </div>
    </div>

    <!-- Error/Status Box -->
    <div id="validation-errors" class="hidden text-xs text-rose-450 bg-rose-950/20 border border-rose-900/40 p-4 rounded-md"></div>

    <!-- Navigation Buttons -->
    <div class="flex justify-between items-center pt-4 border-t border-slate-900">
      <button type="button" id="prev-btn" class="hidden bg-slate-950 border border-slate-900 hover:border-slate-800 text-slate-400 hover:text-white px-6 py-3 rounded font-semibold text-sm transition-all duration-300">
        Previous Step
      </button>
      <div class="flex-1"></div>
      <button type="button" id="next-btn" class="bg-cyan-500 hover:bg-[#00f0ff] text-black px-8 py-3.5 rounded font-bold text-sm transition-all duration-300 transform hover:-translate-y-0.5 shadow-lg shadow-cyan-600/10">
        Next Step
      </button>
    </div>
  </form>
</div>

<!-- Client-side Quote Engine Processing -->
<script>
  import { QuoteSchema } from '../lib/schemas';
  import { broAudio } from '../lib/audio';

  // State Management
  let currentStep = 1;
  const totalSteps = 4;
  const STORAGE_KEY = 'bro_quote_flow_v5';

  // Turnstile State
  let turnstileWidgetId: any = null;
  let turnstileToken = '';

  // DOM Elements
  const form = document.getElementById('quote-form') as HTMLFormElement;
  const panels = document.querySelectorAll('.step-panel');
  const dots = document.querySelectorAll('.step-dot');
  const currentStepNum = document.getElementById('current-step-num');
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const errorBox = document.getElementById('validation-errors');

  // SVG Blueprints
  const svgDryVan = document.getElementById('svg-dry-van');
  const svgReefer = document.getElementById('svg-reefer');
  const svgFlatbed = document.getElementById('svg-flatbed');
  const flatbedDeck = document.getElementById('blueprint-flatbed-deck');
  const flatbedCargo = document.getElementById('blueprint-flatbed-cargo');
  const strap1 = document.getElementById('blueprint-strap-1');
  const strap2 = document.getElementById('blueprint-strap-2');
  const strap3 = document.getElementById('blueprint-strap-3');

  const getRadioVal = (name: string) => {
    const el = document.querySelector(`input[name="${name}"]:checked`) as HTMLInputElement | null;
    return el ? el.value : '';
  };
  const getNumberVal = (id: string) => {
    const el = document.getElementById(id) as HTMLInputElement | null;
    return el ? parseFloat(el.value) || 0 : 0;
  };
  const getStringVal = (id: string) => {
    const el = document.getElementById(id) as HTMLInputElement | null;
    return el ? el.value.trim() : '';
  };

  function renderTurnstileWidget() {
    const container = document.getElementById('turnstile-quote-widget');
    if (!container) return;

    if (!(window as any).turnstile) {
      setTimeout(renderTurnstileWidget, 500);
      return;
    }

    const turnstile = (window as any).turnstile;
    if (turnstileWidgetId !== null) {
      turnstile.reset(turnstileWidgetId);
      return;
    }

    try {
      turnstileWidgetId = turnstile.render('#turnstile-quote-widget', {
        sitekey: '1x00000000000000000000AA', // Testing sitekey
        theme: 'dark',
        callback: function(token: string) {
          turnstileToken = token;
          if (errorBox) errorBox.classList.add('hidden');
        }
      });
    } catch (e) {
      console.error('Failed to render Turnstile widget', e);
    }
  }

  // Setup Step Changes
  function showStep(step: number) {
    panels.forEach((p) => {
      const panelStep = parseInt(p.getAttribute('data-step') || '1');
      if (panelStep === step) {
        p.classList.remove('hidden');
      } else {
        p.classList.add('hidden');
      }
    });

    dots.forEach((d, idx) => {
      if (idx + 1 <= step) {
        d.className = 'h-1.5 w-6 rounded-full bg-cyan-400 shadow-[0_0_6px_#00f0ff] step-dot';
      } else {
        d.className = 'h-1.5 w-6 rounded-full bg-slate-900 step-dot';
      }
    });

    if (currentStepNum) currentStepNum.innerText = step.toString();

    // Toggle Nav Buttons
    if (step === 1) {
      prevBtn.classList.add('hidden');
    } else {
      prevBtn.classList.remove('hidden');
    }

    if (step === totalSteps) {
      nextBtn.innerText = 'Submit Quote Request';
      nextBtn.className = 'bg-emerald-500 hover:bg-emerald-400 text-black font-bold px-8 py-3.5 rounded font-semibold text-sm transition-all duration-300 transform hover:-translate-y-0.5 shadow-lg shadow-emerald-600/10';
    } else {
      nextBtn.innerText = 'Next Step';
      nextBtn.className = 'bg-cyan-500 hover:bg-[#00f0ff] text-black font-bold px-8 py-3.5 rounded font-semibold text-sm transition-all duration-300 transform hover:-translate-y-0.5 shadow-lg shadow-cyan-600/10';
    }

    if (step === 3) {
      runEvaluation();
    }

    if (step === 4) {
      renderTurnstileWidget();
    }
  }

  // Real-Time Evaluation logic for Step 3
  function runEvaluation() {
    const trailerType = getRadioVal('trailerType');
    const weight = getNumberVal('weight');
    const tempSetpoint = getNumberVal('tempSetpoint');

    const allocatedTrailer = document.getElementById('allocated-trailer');
    const allocatedDesc = document.getElementById('allocated-desc');
    const rateBase = document.getElementById('rate-base');
    const rateSurcharges = document.getElementById('rate-surcharges');
    const rateTotal = document.getElementById('rate-total');

    if (!allocatedTrailer || !allocatedDesc || !rateBase || !rateSurcharges || !rateTotal) return;

    let basePrice = 2.20;
    let surchargePrice = 0.00;

    if (trailerType === 'dry-van') {
      allocatedTrailer.innerText = '53FT Enclosed Carrier';
      allocatedDesc.innerText = 'Assigned standard dry van. Perfect for palletized freight requiring weather-enclosed security.';
      basePrice = 2.20;
    } else if (trailerType === 'reefer') {
      allocatedTrailer.innerText = '53FT Climate-Controlled Reefer';
      allocatedDesc.innerText = `Assigned insulated reefer. Temperature setpoint lock verified at ${tempSetpoint}°C.`;
      basePrice = 2.55;
      // reefer temperature surcharge
      if (tempSetpoint < -10) {
        surchargePrice += 0.10; // deep freeze power surcharge
      }
    } else if (trailerType === 'flatbed') {
      allocatedTrailer.innerText = '53FT Open Deck Flatbed';
      allocatedDesc.innerText = 'Assigned open flatbed. Payloads require tie-down securement and optional tarps.';
      basePrice = 2.45;
    }

    // Weight surcharge: over 40,000 lbs
    if (weight > 40000) {
      surchargePrice += 0.15;
    }

    const totalRate = basePrice + surchargePrice;

    rateBase.innerText = `$${basePrice.toFixed(2)} / MILE`;
    rateSurcharges.innerText = `$${surchargePrice.toFixed(2)} / MILE`;
    rateTotal.innerText = `$${totalRate.toFixed(2)} / MILE`;
  }

  // Local Storage Save
  function saveFlowData() {
    const data = {
      trailerType: getRadioVal('trailerType'),
      weight: getNumberVal('weight'),
      tempSetpoint: getNumberVal('tempSetpoint'),
      origin: getStringVal('origin'),
      destination: getStringVal('destination'),
      contactName: getStringVal('contactName'),
      contactEmail: getStringVal('contactEmail'),
      contactPhone: getStringVal('contactPhone'),
      currentStep
    };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  }

  // Local Storage Load
  function loadFlowData() {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (!saved) return;

    try {
      const data = JSON.parse(saved);
      
      const radio = document.querySelector(`input[name="trailerType"][value="${data.trailerType}"]`) as HTMLInputElement | null;
      if (radio) radio.checked = true;

      const setNum = (id: string, val: number) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el && val) el.value = val.toString();
      };
      setNum('weight', data.weight);
      setNum('tempSetpoint', data.tempSetpoint);

      const setStr = (id: string, val: string) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el && val) el.value = val;
      };
      setStr('origin', data.origin);
      setStr('destination', data.destination);
      setStr('contactName', data.contactName);
      setStr('contactEmail', data.contactEmail);
      setStr('contactPhone', data.contactPhone);

      if (data.currentStep) {
        currentStep = data.currentStep;
        showStep(currentStep);
      }
      updateBlueprint();
    } catch (e) {
      console.error('Failed to restore cached progress', e);
    }
  }

  function updateBlueprint() {
    const trailerType = getRadioVal('trailerType');
    const weight = getNumberVal('weight') || 30000;
    const tempSetpoint = getNumberVal('tempSetpoint') || -18;

    const warning = document.getElementById('blueprint-warning');
    const sliderVal = document.getElementById('weight-slider-val');
    const tempInputVal = document.getElementById('temp-slider-val');
    const tempInputWrapper = document.getElementById('temp-input-wrapper');

    const blueprintFlex = document.getElementById('blueprint-flex-text');
    const blueprintTon = document.getElementById('blueprint-ton-text');
    const blueprintTempOverlay = document.getElementById('blueprint-temp-overlay');

    // Toggle temp input visibility
    if (trailerType === 'reefer') {
      if (tempInputWrapper) tempInputWrapper.classList.remove('hidden');
    } else {
      if (tempInputWrapper) tempInputWrapper.classList.add('hidden');
    }

    // Toggle blueprint visible groups
    if (svgDryVan && svgReefer && svgFlatbed) {
      svgDryVan.classList.add('hidden');
      svgReefer.classList.add('hidden');
      svgFlatbed.classList.add('hidden');

      if (trailerType === 'dry-van') {
        svgDryVan.classList.remove('hidden');
      } else if (trailerType === 'reefer') {
        svgReefer.classList.remove('hidden');
        if (blueprintTempOverlay) {
          blueprintTempOverlay.textContent = `TEMP: ${tempSetpoint.toFixed(1)}°C`;
        }
      } else if (trailerType === 'flatbed') {
        svgFlatbed.classList.remove('hidden');
        // Flatbed deck bending flex logic based on weight
        const maxFlex = 6;
        const flexRatio = weight / 45000; // 0 to 1
        const bend = flexRatio * maxFlex;
        if (flatbedDeck && flatbedCargo && strap1 && strap2 && strap3) {
          flatbedDeck.setAttribute('d', `M 20 92 Q 115 ${92 + bend} 210 92`);
          // adjust cargo Y based on bend
          flatbedCargo.setAttribute('y', (62 + bend/2).toString());
          // adjust straps Y
          strap1.setAttribute('y2', (92 + bend/2).toString());
          strap2.setAttribute('y2', (92 + bend).toString());
          strap3.setAttribute('y2', (92 + bend/2).toString());
        }
      }
    }

    // Update labels
    if (sliderVal) sliderVal.innerText = `${weight.toLocaleString()} LBS`;
    if (tempInputVal) tempInputVal.innerText = `${tempSetpoint.toFixed(1)}°C`;
    if (blueprintTon) blueprintTon.innerText = `${(weight / 2000).toFixed(1)} TONS`;

    if (blueprintFlex) {
      if (weight > 40000) {
        blueprintFlex.innerText = 'HIGH DECK STRESS';
        blueprintFlex.className = 'text-[#ff6000] font-bold animate-pulse';
        if (warning) warning.classList.remove('hidden');
      } else {
        blueprintFlex.innerText = 'NORMAL';
        blueprintFlex.className = 'text-slate-350';
        if (warning) warning.classList.add('hidden');
      }
    }
  }

  // Initialize
  loadFlowData();

  // Next Button Handler
  nextBtn?.addEventListener('click', () => {
    if (errorBox) errorBox.classList.add('hidden');

    if (currentStep === totalSteps) {
      const payload = {
        trailerType: getRadioVal('trailerType'),
        weight: getNumberVal('weight'),
        tempSetpoint: getRadioVal('trailerType') === 'reefer' ? getNumberVal('tempSetpoint') : undefined,
        origin: getStringVal('origin'),
        destination: getStringVal('destination'),
        contactName: getStringVal('contactName'),
        contactEmail: getStringVal('contactEmail'),
        contactPhone: getStringVal('contactPhone'),
        turnstileToken: turnstileToken
      };

      const result = QuoteSchema.safeParse(payload);
      if (!result.success) {
        if (errorBox) {
          errorBox.innerHTML = result.error.errors.map((e) => `• ${e.message}`).join('<br />');
          errorBox.className = 'text-xs text-rose-450 bg-rose-950/20 border border-rose-900/40 p-4 rounded-md';
          errorBox.classList.remove('hidden');
        }
        return;
      }

      // Successful Validation
      if (errorBox) {
        errorBox.className = 'text-xs text-cyan-400 bg-cyan-950/20 border border-cyan-900/40 p-4 rounded-md';
        errorBox.innerText = 'Manifest payload verified. Transmitting encrypted route metrics...';
        errorBox.classList.remove('hidden');
      }

      const apiUrl = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
        ? 'http://127.0.0.1:8787/api/quote'
        : 'https://brotransport-edge-api.keshuin0.workers.dev/api/quote';

      fetch(apiUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      })
      .then(async (res) => {
        const data = await res.json();
        if (!res.ok) {
          throw new Error(data.error || 'Uplink transmission rejected.');
        }
        return data;
      })
      .then((data) => {
        broAudio.playBiometricSuccess();
        alert(`Procurement request successfully logged! Edge server reply: ${data.message}`);
        localStorage.removeItem(STORAGE_KEY);
        form.reset();
        currentStep = 1;
        showStep(1);
        if (errorBox) errorBox.classList.add('hidden');
        if (turnstileWidgetId !== null && (window as any).turnstile) {
          (window as any).turnstile.reset(turnstileWidgetId);
          turnstileToken = '';
        }
      })
      .catch((err) => {
        broAudio.playWarningChime();
        if (errorBox) {
          errorBox.innerText = `Uplink failed: ${err.message}`;
          errorBox.className = 'text-xs text-rose-450 bg-rose-950/20 border border-rose-900/40 p-4 rounded-md';
          errorBox.classList.remove('hidden');
        }
      });

      return;
    }

    currentStep++;
    showStep(currentStep);
    saveFlowData();
  });

  // Prev Button Handler
  prevBtn?.addEventListener('click', () => {
    if (errorBox) errorBox.classList.add('hidden');
    if (currentStep > 1) {
      currentStep--;
      showStep(currentStep);
      saveFlowData();
    }
  });

  form?.addEventListener('input', () => {
    saveFlowData();
    updateBlueprint();
  });
</script>

<style>
  /* Highlight active cards */
  #card-dry-van:has(input[type="radio"]:checked) {
    border-color: #00f0ff;
    background-color: rgba(0, 240, 255, 0.05);
  }
  #card-reefer:has(input[type="radio"]:checked) {
    border-color: #00f0ff;
    background-color: rgba(0, 240, 255, 0.05);
  }
  #card-flatbed:has(input[type="radio"]:checked) {
    border-color: #ff6000;
    background-color: rgba(255, 96, 0, 0.05);
  }
</style>
