---
const base = import.meta.env.BASE_URL;
---
<div class="space-y-4">
  <div class="text-[10px] font-mono tracking-widest text-slate-500 uppercase flex items-center gap-2 select-none">
    <span class="h-2 w-2 rounded-full bg-cyan-400 animate-pulse shadow-[0_0_6px_#00f0ff]"></span>
    SYS_CORRIDOR_GRID // LIVE COMMERCIAL TRANSIT ROUTES
  </div>
  <div id="corridor-map" class="h-96 w-full rounded-lg bg-[#020408] border border-slate-900 shadow-2xl relative z-0">
    <div id="map-loader" class="absolute inset-0 flex items-center justify-center text-xs font-mono text-slate-500 bg-[#020408]/90 rounded-lg">
      [WAITING FOR TRANSIT SCANNER IN VIEW]
    </div>
  </div>

  <!-- Live GPS Telemetry Dashboard Panel -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 p-4 bg-black/60 border border-slate-900 rounded-lg text-[10px] font-mono text-slate-500 shadow-xl relative overflow-hidden scanlines">
    <div class="space-y-1">
      <span class="text-slate-500 block uppercase">Active Unit:</span>
      <span class="text-white font-bold block flex items-center gap-1.5">
        <span class="h-1.5 w-1.5 rounded-full bg-blaze animate-ping"></span>
        UNIT_BRO_ACTIVE
      </span>
    </div>
    <div class="space-y-1">
      <span class="text-slate-500 block uppercase">Telemetry GPS:</span>
      <span id="telemetry-gps" class="text-cyan-400 font-bold block">46.2507° N, 63.1375° W</span>
    </div>
    <div class="space-y-1">
      <span class="text-slate-500 block uppercase">Transit Velocity:</span>
      <span id="telemetry-velocity" class="text-blaze font-bold block">82 km/h</span>
    </div>
    <div class="space-y-1">
      <span class="text-slate-500 block uppercase">Active Route:</span>
      <span class="text-slate-300 font-bold block">PEI -> ON -> AB LINK</span>
    </div>
  </div>
</div>

<script>
  let mapInitialized = false;

  const initMap = () => {
    if (mapInitialized) return;
    const mapEl = document.getElementById('corridor-map');
    const loader = document.getElementById('map-loader');
    if (!mapEl) return;

    mapInitialized = true;
    if (loader) loader.innerText = '[ESTABLISHING SATELLITE ROAD LINK...]';

    // 1. Inject Leaflet stylesheet dynamically
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
    link.integrity = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
    link.crossOrigin = '';
    document.head.appendChild(link);

    // 2. Load Leaflet script dynamically
    const script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
    script.crossOrigin = '';
    
    script.onload = () => {
      const L = (window as any).L;
      if (!L) return;

      if (loader) loader.remove();

      // Initialize Map focused on central Canada
      const map = L.map('corridor-map', {
        zoomControl: false,
        attributionControl: false
      }).setView([50.0, -90.0], 4);

      // Dark Mode Tile Layer (CartoDB Dark Matter)
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        maxZoom: 18,
      }).addTo(map);

      // Custom Glowing Markers using Cyber Cyan
      const createGlowingMarker = (title: string, subtitle: string) => {
        return L.divIcon({
          className: 'custom-radar-icon',
          html: `<div class="relative flex items-center justify-center">
            <span class="absolute inline-flex h-6 w-6 rounded-full bg-[#00f0ff]/20 animate-ping"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[#00f0ff] border border-white/40 shadow-[0_0_6px_#00f0ff]"></span>
            <div class="absolute left-4 bg-[#020408]/90 border border-slate-900 text-[9px] text-slate-350 font-mono px-2 py-0.5 rounded whitespace-nowrap">
              <strong>${title}</strong><br/>${subtitle}
            </div>
          </div>`,
          iconSize: [8, 8],
          iconAnchor: [4, 4]
        });
      };

      // Define Hubs
      const hubs = [
        { name: 'PEI HQ', coords: [46.2507, -63.1375], info: 'Dispatch Headquarters' },
        { name: 'Ontario Hub', coords: [44.2706, -79.9048], info: 'Central Commercial Hub' },
        { name: 'Alberta Hub', coords: [56.7264, -111.3803], info: 'Western Distribution Link' }
      ];

      const latlngs = hubs.map(hub => {
        L.marker(hub.coords, { icon: createGlowingMarker(hub.name, hub.info) }).addTo(map);
        return hub.coords;
      });

      // Connect corridors with glowing Cyber Cyan dashed polyline
      L.polyline(latlngs, {
        color: '#00f0ff',
        weight: 1.5,
        opacity: 0.8,
        dashArray: '5, 10'
      }).addTo(map);

      // Moving convoy marker using Blaze Orange
      const convoyIcon = L.divIcon({
        className: 'custom-radar-icon',
        html: `<div class="relative flex items-center justify-center">
          <span class="absolute inline-flex h-4 w-4 rounded-full bg-[#ff6000]/40 animate-ping"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[#ff6000] shadow-[0_0_8px_#ff6000] border border-white/60"></span>
        </div>`,
        iconSize: [10, 10],
        iconAnchor: [5, 5]
      });

      const convoyMarker = L.marker(hubs[0].coords, { icon: convoyIcon }).addTo(map);

      // Fit bounds nicely
      map.fitBounds(L.latLngBounds(latlngs), { padding: [40, 40] });

      // Animate convoy along the polyline path
      let pathProgress = 0;
      let direction = 1;

      const gpsLabel = document.getElementById('telemetry-gps');
      const velLabel = document.getElementById('telemetry-velocity');

      function animateConvoy() {
        pathProgress += 0.0006 * direction;
        if (pathProgress >= 1) {
          pathProgress = 1;
          direction = -1;
        } else if (pathProgress <= 0) {
          pathProgress = 0;
          direction = 1;
        }

        let currentCoords;
        if (pathProgress < 0.5) {
          const t = pathProgress * 2;
          const lat = hubs[0].coords[0] + (hubs[1].coords[0] - hubs[0].coords[0]) * t;
          const lng = hubs[0].coords[1] + (hubs[1].coords[1] - hubs[0].coords[1]) * t;
          currentCoords = [lat, lng];
        } else {
          const t = (pathProgress - 0.5) * 2;
          const lat = hubs[1].coords[0] + (hubs[2].coords[0] - hubs[1].coords[0]) * t;
          const lng = hubs[1].coords[1] + (hubs[2].coords[1] - hubs[1].coords[1]) * t;
          currentCoords = [lat, lng];
        }

        convoyMarker.setLatLng(currentCoords);

        // Update GPS Text readout
        if (gpsLabel) {
          gpsLabel.innerText = `${currentCoords[0].toFixed(4)}° N, ${Math.abs(currentCoords[1]).toFixed(4)}° W`;
        }

        // Drifting Velocity readout
        if (velLabel) {
          const baseVel = 85;
          const drift = Math.floor(Math.sin(Date.now() / 1500) * 5);
          velLabel.innerText = `${baseVel + drift} km/h`;
        }

        requestAnimationFrame(animateConvoy);
      }

      // Start Convoy Animation loop
      requestAnimationFrame(animateConvoy);
    };

    document.body.appendChild(script);
  };

  // Setup Lazy Loading IntersectionObserver
  const setupObserver = () => {
    const mapEl = document.getElementById('corridor-map');
    if (!mapEl) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          initMap();
          observer.disconnect();
        }
      });
    }, {
      rootMargin: '100px'
    });

    observer.observe(mapEl);
  };

  document.addEventListener('astro:page-load', setupObserver);
</script>

<style is:global>
  .custom-radar-icon {
    background: transparent !important;
    border: none !important;
  }
  .leaflet-container {
    background: #020408 !important;
  }
</style>
