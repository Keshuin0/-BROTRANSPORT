---
import { Image } from 'astro:assets';

interface Props {
  src: any; // Supports imported ImageMetadata or string URLs
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  priority?: boolean;
}

const { 
  src, 
  alt, 
  width, 
  height, 
  class: className = '', 
  priority = false 
} = Astro.props;
---

{
  typeof src === 'string' ? (
    <img 
      src={src} 
      alt={alt} 
      width={width} 
      height={height} 
      class={className}
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? 'sync' : 'async'}
      fetchpriority={priority ? 'high' : 'auto'}
    />
  ) : (
    <Image 
      src={src} 
      alt={alt} 
      width={width} 
      height={height} 
      class={className}
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? 'sync' : 'async'}
      fetchpriority={priority ? 'high' : 'auto'}
      format="avif"
      quality="mid"
    />
  )
}
