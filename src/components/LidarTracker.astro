---
---
<div class="space-y-6">
  <div class="flex items-center justify-between border-b border-slate-800/80 pb-4">
    <div class="flex items-center gap-3">
      <span class="h-2 w-2 rounded-full bg-blue-500 animate-pulse"></span>
      <h3 class="text-xs font-mono uppercase tracking-widest text-slate-400">SYS_RADAR // ACTIVE CONVOY LIDAR SIMULATOR</h3>
    </div>
    <div class="text-[10px] font-mono text-slate-500 hidden sm:block">
      LAT: 46.2507° N | LON: -63.1375° W // PEI HQ COMMAND
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Telemetry Readouts -->
    <div class="lg:col-span-1 space-y-4 font-mono text-xs text-slate-400 bg-slate-950/80 border border-slate-900 p-6 rounded-lg relative overflow-hidden">
      <div class="absolute top-0 right-0 w-24 h-24 bg-blue-500/5 rounded-full blur-2xl"></div>
      <div class="text-[10px] uppercase text-blue-400 tracking-wider font-bold mb-2">// CONVOY TELEMETRY</div>
      <div class="space-y-2">
        <div class="flex justify-between border-b border-slate-900/60 pb-1">
          <span>TARGETS ACTIVE:</span>
          <span class="text-white font-bold">2,500 PARTICLES</span>
        </div>
        <div class="flex justify-between border-b border-slate-900/60 pb-1">
          <span>TRAJECTORY:</span>
          <span class="text-emerald-400 font-bold">STEADY // ON-ROUTE</span>
        </div>
        <div class="flex justify-between border-b border-slate-900/60 pb-1">
          <span>DISPATCH SECTOR:</span>
          <span class="text-slate-300">HQ_EAST_CORRIDOR</span>
        </div>
        <div class="flex justify-between border-b border-slate-900/60 pb-1">
          <span>EST. COMPLIANCE:</span>
          <span class="text-slate-300">VERIFIED</span>
        </div>
        <div class="flex justify-between">
          <span>LIDAR COMPRESSION:</span>
          <span class="text-blue-400 font-bold">98.2%</span>
        </div>
      </div>

      <!-- Interactive HUD Controls -->
      <div class="pt-4 border-t border-slate-900/60 space-y-4 text-[10px]">
        <div class="uppercase text-blue-400 font-bold tracking-wider flex items-center gap-1.5 select-none">
          <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
          // LIDAR HUD CONTROLS
        </div>
        
        <div class="space-y-1">
          <div class="flex justify-between text-slate-500 select-none">
            <span>SCAN FREQUENCY:</span>
            <span id="scan-freq-val" class="text-slate-300 font-bold font-mono">1.0x</span>
          </div>
          <input type="range" id="scan-freq-slider" min="0.2" max="3" step="0.1" value="1.0" class="w-full h-1 bg-slate-900 rounded appearance-none cursor-pointer accent-blue-500" />
        </div>

        <div class="space-y-1">
          <div class="flex justify-between text-slate-500 select-none">
            <span>SENSOR NOISE:</span>
            <span id="sensor-noise-val" class="text-slate-300 font-bold font-mono">1.0x</span>
          </div>
          <input type="range" id="sensor-noise-slider" min="0.0" max="4.0" step="0.2" value="1.0" class="w-full h-1 bg-slate-900 rounded appearance-none cursor-pointer accent-blue-500" />
        </div>

        <div class="space-y-1">
          <div class="flex justify-between text-slate-500 select-none">
            <span>ROTATION RATE:</span>
            <span id="rotation-rate-val" class="text-slate-300 font-bold font-mono">1.0x</span>
          </div>
          <input type="range" id="rotation-rate-slider" min="0.1" max="3" step="0.1" value="1.0" class="w-full h-1 bg-slate-900 rounded appearance-none cursor-pointer accent-blue-500" />
        </div>
      </div>
    </div>

    <!-- 3D Canvas Screen -->
    <div class="lg:col-span-3 h-80 bg-slate-950/90 border border-slate-900 rounded-lg relative overflow-hidden dent-panel">
      <!-- Blinking Scan Marker -->
      <div class="absolute top-4 left-4 z-10 flex items-center gap-2 select-none pointer-events-none">
        <div class="relative flex items-center justify-center">
          <span class="absolute inline-flex h-3 w-3 rounded-full bg-rose-500/30 animate-ping"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-rose-500"></span>
        </div>
        <span class="text-[9px] font-mono text-rose-400 tracking-wider">LIVE_FEED // CONVOY SCANNING</span>
      </div>
      <canvas id="radar-3d-canvas" class="w-full h-full opacity-80 block"></canvas>
    </div>
  </div>
</div>

<script>
  async function initRadar3D() {
    const canvas = document.getElementById('radar-3d-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    if (!('transferControlToOffscreen' in canvas)) {
      console.warn('OffscreenCanvas not supported in this browser.');
      return;
    }

    const offscreen = canvas.transferControlToOffscreen();

    try {
      const HeroWorker = await import('../lib/hero-worker?worker');
      const worker = new HeroWorker.default();

      worker.postMessage({
        type: 'init',
        canvas: offscreen,
        w: canvas.clientWidth,
        h: canvas.clientHeight
      }, [offscreen]);

      const resizeObserver = new ResizeObserver((entries) => {
        for (let entry of entries) {
          const { width, height } = entry.contentRect;
          worker.postMessage({
            type: 'resize',
            w: Math.floor(width),
            h: Math.floor(height)
          });
        }
      });
      resizeObserver.observe(canvas.parentElement || document.body);

      window.addEventListener('mousemove', (e) => {
        const mx = (e.clientX / window.innerWidth) * 2 - 1;
        const my = -(e.clientY / window.innerHeight) * 2 + 1;
        worker.postMessage({
          type: 'mousemove',
          mx,
          my
        });
      });

      // HUD Slider Elements & Listeners
      const freqSlider = document.getElementById('scan-freq-slider') as HTMLInputElement | null;
      const noiseSlider = document.getElementById('sensor-noise-slider') as HTMLInputElement | null;
      const rotSlider = document.getElementById('rotation-rate-slider') as HTMLInputElement | null;

      const freqVal = document.getElementById('scan-freq-val');
      const noiseVal = document.getElementById('sensor-noise-val');
      const rotVal = document.getElementById('rotation-rate-val');

      freqSlider?.addEventListener('input', () => {
        const val = parseFloat(freqSlider.value);
        if (freqVal) freqVal.innerText = `${val.toFixed(1)}x`;
        worker.postMessage({ type: 'update_freq', value: val });
      });

      noiseSlider?.addEventListener('input', () => {
        const val = parseFloat(noiseSlider.value);
        if (noiseVal) noiseVal.innerText = `${val.toFixed(1)}x`;
        worker.postMessage({ type: 'update_noise', value: val });
      });

      rotSlider?.addEventListener('input', () => {
        const val = parseFloat(rotSlider.value);
        if (rotVal) rotVal.innerText = `${val.toFixed(1)}x`;
        worker.postMessage({ type: 'update_rotation', value: val });
      });

    } catch (err) {
      console.error('Failed to initialize Radar 3D Web Worker:', err);
    }
  }

  document.addEventListener('astro:page-load', initRadar3D);
</script>
