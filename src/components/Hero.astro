---
const base = import.meta.env.BASE_URL;
---
<div class="relative min-h-[85vh] flex flex-col justify-center items-center overflow-hidden text-white select-none py-20 px-6">
  <!-- Background Image with High Priority -->
  <div class="absolute inset-0 z-0">
    <img 
      src={`${base}images/hero-truck.png`} 
      alt="Commercial semi truck crossing a highway bridge at sunset" 
      class="w-full h-full object-cover object-center scale-100 opacity-30 pointer-events-none"
      fetchpriority="high"
    />
    <!-- Premium Gradient Masks -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#030307] via-[#030307]/90 to-[#030307]/75 z-10"></div>
    <div class="absolute inset-0 bg-radial-at-c from-transparent via-[#030307]/50 to-[#030307] z-10"></div>
    <!-- Subtle Grid Overlay -->
    <div class="absolute inset-0 bg-cyber-grid opacity-10 z-10 pointer-events-none"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-20 max-w-4xl mx-auto w-full flex flex-col items-center text-center space-y-10">
    <!-- Prominent Logo Pic -->
    <div class="p-2 bg-bro-steel/40 border border-slate-900 rounded-lg shadow-2xl backdrop-blur-md animate-[pulse_4s_infinite]">
      <img src={`${base}images/logo.jpg?v=3`} alt="#BRO TRANSPORT" class="h-20 sm:h-24 w-auto object-contain" />
    </div>

    <!-- Slogan Headline -->
    <div class="space-y-4">
      <h1 class="text-4xl sm:text-6xl md:text-7xl font-black font-display uppercase tracking-tight leading-none text-white drop-shadow-lg">
        A BRO IN NEED <br />
        <span class="text-bro-cyan glow-text-cyan block mt-2">
          IS A BRO INDEED
        </span>
      </h1>
      <p class="text-sm sm:text-base md:text-lg text-bro-ice/80 max-w-2xl mx-auto font-normal leading-relaxed font-sans pt-2">
        North America's Premier Cross-Border Logistics and Freight Operations Network. Providing high-capacity Dry Van, Refrigerated Reefer, and Heavy Flatbed shipping routes across Canada and the United States.
      </p>
    </div>

    <!-- Clean Quick Actions -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full max-w-2xl pt-4">
      <a href={`${base}quote`} data-astro-prefetch class="flex items-center justify-between p-6 rounded border border-bro-cyan/20 bg-bro-steel/30 hover:bg-bro-steel/60 hover:border-bro-cyan/60 hover:shadow-neon-glow transition-all duration-300 group shadow-lg">
        <div class="text-left">
          <h4 class="text-sm font-bold text-white font-mono tracking-wide uppercase group-hover:text-bro-cyan transition-colors">01 // RATE QUOTE</h4>
          <p class="text-bro-ice/60 text-xs mt-1">Request dry van, reefer, or flatbed pricing.</p>
        </div>
        <span class="text-bro-cyan font-bold font-mono transition-transform group-hover:translate-x-1">→</span>
      </a>

      <a href={`${base}drivers`} data-astro-prefetch class="flex items-center justify-between p-6 rounded border border-bro-gold/20 bg-bro-steel/30 hover:bg-bro-steel/60 hover:border-bro-gold/60 hover:shadow-[0_0_15px_rgba(255,170,0,0.15)] transition-all duration-300 group shadow-lg">
        <div class="text-left">
          <h4 class="text-sm font-bold text-white font-mono tracking-wide uppercase group-hover:text-bro-gold transition-colors">02 // DRIVER GATEWAY</h4>
          <p class="text-bro-ice/60 text-xs mt-1">Join the elite freight operations fleet.</p>
        </div>
        <span class="text-bro-gold font-bold font-mono transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</div>

