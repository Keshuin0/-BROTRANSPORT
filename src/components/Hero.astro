---
const base = import.meta.env.BASE_URL;
---
<div class="relative min-h-[90vh] flex flex-col justify-between overflow-hidden text-white border-b border-slate-900 select-none">
  <!-- Background Image with High Priority -->
  <div class="absolute inset-0 z-0">
    <img 
      src={`${base}images/hero-truck.png`} 
      alt="Heavy haul semi truck crossing a highway bridge at sunset" 
      class="w-full h-full object-cover object-center scale-105 animate-[pulse-slow_8s_infinite] pointer-events-none"
      fetchpriority="high"
    />
    <!-- Premium Gradient Masks -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#05070D] via-[#05070D]/70 to-transparent z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#05070D]/85 via-[#05070D]/30 to-transparent z-10"></div>
    <div class="absolute inset-0 bg-radial-at-c from-transparent via-[#05070D]/40 to-[#05070D]/90 z-10"></div>
    <!-- Subtle Grid Overlay -->
    <div class="absolute inset-0 futuristic-grid opacity-20 z-10 pointer-events-none"></div>
  </div>

  <!-- Tactical Corner Accents (Industrial look) -->
  <div class="absolute top-8 left-8 z-20 pointer-events-none hidden lg:block">
    <div class="text-[10px] font-mono tracking-widest text-blue-500/80 font-bold flex items-center gap-2">
      <span class="h-1.5 w-1.5 rounded-full bg-blue-500 animate-ping"></span>
      SYS_GRID: INDUSTRIAL_ACTIVE
    </div>
    <div class="text-[9px] font-mono text-slate-500 mt-1">LAT: 46.2500° N | LON: -63.1250° W (EASTERN CANADA HUB)</div>
  </div>

  <div class="absolute top-8 right-8 z-20 pointer-events-none hidden lg:block text-right">
    <div class="text-[10px] font-mono tracking-widest text-amber-500/80 font-bold">// OPERATIONS CENTRAL</div>
    <div class="text-[9px] font-mono text-slate-500 mt-1">CROSS-BORDER PERMIT SYSTEM: ACTIVE</div>
  </div>

  <!-- Hero Content Centered Layout -->
  <div class="relative z-20 flex-1 flex flex-col justify-center px-6 max-w-7xl mx-auto w-full pt-28 pb-12">
    <div class="space-y-8 max-w-3xl">
      <div class="inline-flex items-center gap-2 border border-blue-500/30 bg-blue-950/20 px-3 py-1.5 rounded-full text-xs font-bold text-blue-400 uppercase tracking-widest animate-pulse select-none">
        <span class="h-2 w-2 rounded-full bg-blue-500"></span>
        Elite Heavy-Haul & Specialized Load Logistics
      </div>

      <div class="space-y-4">
        <h1 class="text-4xl sm:text-6xl md:text-7xl font-black font-outfit uppercase tracking-tight leading-none text-white drop-shadow-md">
          INDUSTRIAL HEAVY-HAUL <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-400 glow-text-blue">
            COMMAND CENTER
          </span>
        </h1>
        <div class="text-xs font-mono text-blue-400 uppercase tracking-widest font-bold select-none">// A BRO IN NEED IS A BRO INDEED</div>
        <p class="text-base sm:text-lg md:text-xl text-slate-300 max-w-2xl font-normal leading-relaxed">
          Executing high-stakes industrial relocation and cross-border commercial heavy-haul networks out of Prince Edward Island. Fully permitted, licensed, and safety-certified across Canada.
        </p>
      </div>

      <!-- Quick Action Panels (Morphing Glassmorphism cards) -->
      <div class="grid grid-cols-1 sm:sm:grid-cols-2 gap-4 max-w-2xl pt-2">
        <a href={`${base}quote`} data-astro-prefetch class="flex items-center gap-4 p-5 rounded-lg border border-blue-500/20 bg-blue-950/20 hover:bg-blue-950/40 hover:border-blue-500/40 transition-all duration-300 group shadow-lg shadow-blue-950/10 hover:-translate-y-0.5">
          <div class="h-10 w-10 bg-blue-500/10 border border-blue-500/20 group-hover:bg-blue-500 group-hover:text-white transition-colors duration-300 text-blue-400 rounded flex items-center justify-center font-black font-mono">01</div>
          <div class="text-left">
            <h4 class="text-sm font-bold text-white font-outfit tracking-wide uppercase group-hover:text-blue-400 transition-colors">Procurement Engine</h4>
            <p class="text-slate-400 text-xs mt-0.5">Evaluate RGN or 13-axle requirements.</p>
          </div>
        </a>

        <a href={`${base}drivers`} data-astro-prefetch class="flex items-center gap-4 p-5 rounded-lg border border-amber-500/20 bg-amber-950/15 hover:bg-amber-950/30 hover:border-amber-500/40 transition-all duration-300 group shadow-lg shadow-amber-950/10 hover:-translate-y-0.5">
          <div class="h-10 w-10 bg-amber-500/10 border border-amber-500/20 group-hover:bg-amber-500 group-hover:text-white transition-colors duration-300 text-amber-400 rounded flex items-center justify-center font-black font-mono">02</div>
          <div class="text-left">
            <h4 class="text-sm font-bold text-white font-outfit tracking-wide uppercase group-hover:text-amber-400 transition-colors">Driver Gateway</h4>
            <p class="text-slate-400 text-xs mt-0.5">Submit safety qualifications.</p>
          </div>
        </a>
      </div>

      <!-- Live Operations Console Index (HUD Telemetry Stats) -->
      <div class="p-4 rounded-lg bg-[#080B13]/70 border border-slate-900 glass-panel font-mono text-[10px] text-slate-400 flex flex-wrap gap-x-8 gap-y-2 max-w-2xl z-20">
        <div class="flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <span>DISPATCH_LINK: <span class="text-emerald-400 font-bold">ONLINE</span></span>
        </div>
        <div>
          <span>ACTIVE_HAULS: <span class="text-blue-400 font-bold" id="active-hauls-num">124</span></span>
        </div>
        <div>
          <span>PERMIT_COMPLIANCE: <span class="text-amber-500 font-bold">100.0%</span></span>
        </div>
        <div>
          <span>SYSTEM_LATENCY: <span class="text-purple-400 font-bold" id="telemetry-latency">14ms</span></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll-Velocity Kinetic Typography -->
  <div class="w-full overflow-hidden border-t border-slate-900/60 bg-[#05070D]/90 backdrop-blur-sm py-4 relative z-20 pointer-events-none select-none">
    <div class="flex flex-col gap-2">
      <!-- Row 1: Left to Right -->
      <div class="flex whitespace-nowrap text-[3vw] font-black uppercase tracking-widest text-slate-800/15 font-outfit skew-x-12 animate-row-left">
        <span class="inline-block px-4">Oversized Industrial Transport</span>
        <span class="inline-block px-4 text-blue-900/15">—</span>
        <span class="inline-block px-4">13-Axle Combo Transport</span>
        <span class="inline-block px-4 text-blue-900/15">—</span>
        <span class="inline-block px-4">Specialized Permit Operations</span>
        <span class="inline-block px-4 text-blue-900/15">—</span>
        <span class="inline-block px-4">Oversized Industrial Transport</span>
      </div>
      
      <!-- Row 2: Right to Left -->
      <div class="flex whitespace-nowrap text-[3vw] font-black uppercase tracking-widest text-slate-800/15 font-outfit -skew-x-12 animate-row-right">
        <span class="inline-block px-4 text-amber-900/15">Oversized Logistics Dispatch</span>
        <span class="inline-block px-4">—</span>
        <span class="inline-block px-4">85 Ton Max Capacity</span>
        <span class="inline-block px-4">—</span>
        <span class="inline-block px-4">Ontario Corridor Logistics</span>
        <span class="inline-block px-4">—</span>
        <span class="inline-block px-4 text-amber-900/15">Oversized Logistics Dispatch</span>
      </div>
    </div>
  </div>
</div>

<style>
  /* CSS Scroll-Driven Animations */
  @keyframes marqueeLeft {
    from {
      transform: translate3d(0, 0, 0) skewX(-15deg);
    }
    to {
      transform: translate3d(-20%, 0, 0) skewX(15deg);
    }
  }

  @keyframes marqueeRight {
    from {
      transform: translate3d(-20%, 0, 0) skewX(15deg);
    }
    to {
      transform: translate3d(0, 0, 0) skewX(-15deg);
    }
  }

  .animate-row-left {
    animation: marqueeLeft linear;
    animation-timeline: scroll();
  }

  .animate-row-right {
    animation: marqueeRight linear;
    animation-timeline: scroll();
  }

  /* Pulse animation for background image */
  @keyframes pulse-slow {
    0%, 100% {
      transform: scale(1.03);
    }
    50% {
      transform: scale(1.05);
    }
  }
</style>

<script>
  function runTelemetryTicker() {
    const hauls = document.getElementById('active-hauls-num');
    const latency = document.getElementById('telemetry-latency');
    if (!hauls || !latency) return;

    setInterval(() => {
      // Simulate active hauls fluctuating slightly
      const currentHauls = parseInt(hauls.innerText) || 124;
      const change = Math.random() > 0.5 ? 1 : -1;
      const nextHauls = Math.max(115, Math.min(145, currentHauls + (Math.random() > 0.7 ? change : 0)));
      hauls.innerText = nextHauls.toString();

      // Simulate ping latency jitter
      const nextLatency = Math.floor(10 + Math.random() * 8);
      latency.innerText = `${nextLatency}ms`;
    }, 3000);
  }

  document.addEventListener('astro:page-load', runTelemetryTicker);
</script>
