---
const base = import.meta.env.BASE_URL;
---
<div class="relative w-full h-[400px] md:h-[500px] rounded border border-slate-900 bg-bro-steel/20 overflow-hidden shadow-2xl flex items-center justify-center select-none">
  <!-- Interactive WebGL Canvas Container -->
  <div id="globe-canvas-container" class="absolute inset-0 w-full h-full cursor-grab active:cursor-grabbing"></div>
  
  <!-- Diagnostic Telemetry HUD overlay -->
  <div class="absolute bottom-4 left-4 z-10 font-mono text-[9px] text-slate-500 uppercase tracking-widest bg-bro-obsidian/75 backdrop-blur-md px-3 py-2 border border-slate-900/50 rounded flex flex-col gap-1 pointer-events-none select-none">
    <div class="flex items-center gap-1.5 text-bro-cyan font-bold">
      <span class="h-1.5 w-1.5 rounded-full bg-bro-cyan animate-ping"></span>
      LIVE CARGO VECTOR ENGINE
    </div>
    <div>ACTIVE_ROUTES: <span class="text-slate-350">10 // 3D_ARCS</span></div>
    <div>SATELLITE_UPLINK: <span class="text-bro-gold font-bold">ACTIVE</span></div>
  </div>

  <div id="globe-loader" class="absolute z-10 font-mono text-[9px] text-slate-500 uppercase tracking-widest pointer-events-none select-none">
    [ INITIALIZING WebGL 3D VECTORS... ]
  </div>
</div>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  let scene: THREE.Scene | null = null, 
      camera: THREE.PerspectiveCamera | null = null, 
      renderer: THREE.WebGLRenderer | null = null, 
      controls: OrbitControls | null = null;
  let globeMesh: THREE.Mesh | null = null, 
      innerGlobe: THREE.Mesh | null = null,
      linesGroup: THREE.Group | null = null,
      fleetsGroup: THREE.Group | null = null;
  
  let isDragging = false;
  let animationFrameId: number | null = null;

  const locations = {
    PEI: { lat: 46.2507, lon: -63.1375, name: "PEI HQ" },
    BOSTON: { lat: 42.3601, lon: -71.0589, name: "BOSTON HUB" },
    CHICAGO: { lat: 41.8781, lon: -87.6298, name: "CHICAGO TERM" },
    TORONTO: { lat: 43.6532, lon: -79.3832, name: "TORONTO CORR" },
    LOS_ANGELES: { lat: 34.0522, lon: -118.2437, name: "LA TERM" },
    HOUSTON: { lat: 29.7604, lon: -95.3698, name: "HOUSTON HUB" },
    MIAMI: { lat: 25.7617, lon: -80.1918, name: "MIAMI DIVISION" },
    SEATTLE: { lat: 47.6062, lon: -122.3321, name: "SEATTLE TERM" },
    MEXICO_CITY: { lat: 19.4326, lon: -99.1332, name: "MEXICO CITY" },
    VANCOUVER: { lat: 49.2827, lon: -123.1207, name: "VANCOUVER GATE" }
  };

  const routes = [
    { from: locations.PEI, to: locations.BOSTON, color: 0x00f0ff },
    { from: locations.PEI, to: locations.TORONTO, color: 0x00f0ff },
    { from: locations.TORONTO, to: locations.CHICAGO, color: 0xffaa00 },
    { from: locations.CHICAGO, to: locations.HOUSTON, color: 0x00f0ff },
    { from: locations.HOUSTON, to: locations.MEXICO_CITY, color: 0xffaa00 },
    { from: locations.CHICAGO, to: locations.LOS_ANGELES, color: 0xffaa00 },
    { from: locations.VANCOUVER, to: locations.SEATTLE, color: 0x00f0ff },
    { from: locations.SEATTLE, to: locations.LOS_ANGELES, color: 0x00f0ff },
    { from: locations.LOS_ANGELES, to: locations.HOUSTON, color: 0xffaa00 },
    { from: locations.BOSTON, to: locations.MIAMI, color: 0x00f0ff }
  ];

  interface FleetUnit {
    mesh: THREE.Mesh;
    curve: THREE.QuadraticBezierCurve3;
    progress: number;
    speed: number;
  }

  const fleetUnits: FleetUnit[] = [];

  function latLonToVector3(lat: number, lon: number, radius: number) {
    const phi = (90 - lat) * (Math.PI / 180);
    const theta = (lon + 180) * (Math.PI / 180);

    const x = -(radius * Math.sin(phi) * Math.sin(theta));
    const y = radius * Math.cos(phi);
    const z = radius * Math.sin(phi) * Math.cos(theta);

    return new THREE.Vector3(x, y, z);
  }

  function initGlobe() {
    const container = document.getElementById('globe-canvas-container');
    const loader = document.getElementById('globe-loader');
    if (!container) return;

    if (loader) loader.style.display = 'none';

    const width = container.clientWidth;
    const height = container.clientHeight;

    // 0. Clean Up Previous WebGL Instances (Prevents cumulative speedups & memory leaks)
    if (animationFrameId !== null) {
      cancelAnimationFrame(animationFrameId);
      animationFrameId = null;
    }
    if (controls) {
      controls.dispose();
      controls = null;
    }
    if (renderer) {
      renderer.dispose();
      renderer = null;
    }
    if (scene) {
      scene.traverse((object: any) => {
        if (object.geometry) object.geometry.dispose();
        if (object.material) {
          if (Array.isArray(object.material)) {
            object.material.forEach((mat: any) => mat.dispose());
          } else {
            object.material.dispose();
          }
        }
      });
      scene = null;
    }
    fleetUnits.length = 0;

    // 1. Scene Setup
    scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x030307, 0.0025);

    // 2. Camera Setup
    camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
    camera.position.set(0, 40, 150);

    // 3. Renderer Setup
    renderer = new THREE.WebGLRenderer({ 
      antialias: true, 
      alpha: true,
      powerPreference: "high-performance" 
    });
    renderer.setSize(width, height);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    
    container.innerHTML = '';
    container.appendChild(renderer.domElement);

    // 4. Controls Setup
    controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.minDistance = 80;
    controls.maxDistance = 250;
    controls.enablePan = false;

    controls.addEventListener('start', () => { isDragging = true; });
    controls.addEventListener('end', () => { isDragging = false; });

    // 5. Globe Layers (Obsidian Core + Holographic Wireframe)
    const globeGeometry = new THREE.SphereGeometry(50, 40, 40);
    const globeMaterial = new THREE.MeshStandardMaterial({
      color: 0x0e111f,
      wireframe: true,
      transparent: true,
      opacity: 0.22,
      roughness: 0.9,
      metalness: 0.1
    });
    globeMesh = new THREE.Mesh(globeGeometry, globeMaterial);
    scene.add(globeMesh);

    const innerGeometry = new THREE.SphereGeometry(49.6, 40, 40);
    const innerMaterial = new THREE.MeshBasicMaterial({
      color: 0x030307,
      transparent: true,
      opacity: 0.94
    });
    innerGlobe = new THREE.Mesh(innerGeometry, innerMaterial);
    scene.add(innerGlobe);

    // 6. Setup Lighting Environment
    const ambientLight = new THREE.AmbientLight(0x0e111f, 2.0);
    scene.add(ambientLight);

    const directionalLight1 = new THREE.DirectionalLight(0x00f0ff, 2.5);
    directionalLight1.position.set(150, 100, 50);
    scene.add(directionalLight1);

    const directionalLight2 = new THREE.DirectionalLight(0xffaa00, 1.5);
    directionalLight2.position.set(-150, -100, -50);
    scene.add(directionalLight2);

    // Groups for layout curves
    linesGroup = new THREE.Group();
    fleetsGroup = new THREE.Group();
    scene.add(linesGroup);
    scene.add(fleetsGroup);

    // 7. Draw Curves & Initialize Traveling Particles
    setupRoutes();

    // 8. Animation & Render Loop
    function animateLoop() {
      animationFrameId = requestAnimationFrame(animateLoop);

      // Slow elegant satellite drift when not dragging
      if (!isDragging && globeMesh && innerGlobe && linesGroup && fleetsGroup) {
        globeMesh.rotation.y += 0.0003;
        innerGlobe.rotation.y += 0.0003;
        linesGroup.rotation.y += 0.0003;
        fleetsGroup.rotation.y += 0.0003;
      }

      // Animate cargo particle vectors slowly along Bezier paths
      fleetUnits.forEach(unit => {
        unit.progress = (unit.progress + unit.speed) % 1.0;
        const position = unit.curve.getPointAt(unit.progress);
        unit.mesh.position.copy(position);
      });

      if (controls && renderer && scene && camera) {
        controls.update();
        renderer.render(scene, camera);
      }
    }

    animateLoop();

    // Handle Window Resize
    function handleResize() {
      if (!container || !camera || !renderer) return;
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    }

    window.addEventListener('resize', handleResize);
  }

  function setupRoutes() {
    // Sharp high-tech terminal markers (radius 0.5)
    const markerGeometry = new THREE.SphereGeometry(0.5, 16, 16);

    routes.forEach(route => {
      const pStart = latLonToVector3(route.from.lat, route.from.lon, 50);
      const pEnd = latLonToVector3(route.to.lat, route.to.lon, 50);

      // Create arched control point based on distance between terminals
      const midPoint = new THREE.Vector3().addVectors(pStart, pEnd).multiplyScalar(0.5);
      const distance = pStart.distanceTo(pEnd);
      midPoint.normalize().multiplyScalar(50 + distance * 0.22);

      // Construct Quadratic Bezier Curve
      const curve = new THREE.QuadraticBezierCurve3(pStart, midPoint, pEnd);
      
      // Draw static path line
      const pathPoints = curve.getPoints(40);
      const pathGeometry = new THREE.BufferGeometry().setFromPoints(pathPoints);
      const pathMaterial = new THREE.LineBasicMaterial({
        color: route.color,
        transparent: true,
        opacity: 0.35
      });
      const pathLine = new THREE.Line(pathGeometry, pathMaterial);
      linesGroup!.add(pathLine);

      // Draw Terminal Markers
      const startMarkerMat = new THREE.MeshBasicMaterial({ color: route.color });
      const startMarker = new THREE.Mesh(markerGeometry, startMarkerMat);
      startMarker.position.copy(pStart);
      linesGroup!.add(startMarker);

      const endMarkerMat = new THREE.MeshBasicMaterial({ color: route.color });
      const endMarker = new THREE.Mesh(markerGeometry, endMarkerMat);
      endMarker.position.copy(pEnd);
      linesGroup!.add(endMarker);

      // Sleek cargo vectors (radius 0.32)
      const particleGeo = new THREE.SphereGeometry(0.32, 12, 12);
      const particleMat = new THREE.MeshBasicMaterial({
        color: route.color === 0xffaa00 ? 0xffaa00 : 0x00f0ff,
        transparent: true,
        opacity: 0.95
      });

      // Spawn staggered particles gliding smoothly and slowly (0.001 speed)
      const particleMesh1 = new THREE.Mesh(particleGeo, particleMat);
      fleetsGroup!.add(particleMesh1);
      fleetUnits.push({
        mesh: particleMesh1,
        curve: curve,
        progress: Math.random(),
        speed: 0.0008 + Math.random() * 0.0006
      });

      const particleMesh2 = new THREE.Mesh(particleGeo, particleMat);
      fleetsGroup!.add(particleMesh2);
      fleetUnits.push({
        mesh: particleMesh2,
        curve: curve,
        progress: (Math.random() + 0.5) % 1.0,
        speed: 0.0008 + Math.random() * 0.0006
      });
    });
  }

  // Load globe on hydration
  document.addEventListener('astro:page-load', initGlobe);
</script>
