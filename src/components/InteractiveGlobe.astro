---
const base = import.meta.env.BASE_URL;
---
<div class="relative w-full h-[400px] md:h-[500px] rounded border border-slate-900 bg-bro-steel/20 overflow-hidden shadow-2xl flex items-center justify-center select-none">
  <!-- Interactive WebGL Canvas Container -->
  <div id="globe-canvas-container" class="absolute inset-0 w-full h-full cursor-grab active:cursor-grabbing"></div>
  
  <!-- Diagnostic Telemetry HUD overlay -->
  <div class="absolute bottom-4 left-4 z-10 font-mono text-[9px] text-slate-500 uppercase tracking-widest bg-bro-obsidian/75 backdrop-blur-md px-3 py-2 border border-slate-900/50 rounded flex flex-col gap-1 pointer-events-none select-none">
    <div class="flex items-center gap-1.5 text-bro-cyan font-bold">
      <span class="h-1.5 w-1.5 rounded-full bg-bro-cyan animate-ping"></span>
      LIVE CARGO VECTOR ENGINE
    </div>
    <div>ACTIVE_ROUTES: <span class="text-slate-350">28 // 3D_ARCS</span></div>
    <div>SATELLITE_UPLINK: <span class="text-bro-gold font-bold">ACTIVE</span></div>
  </div>

  <div id="globe-loader" class="absolute z-10 font-mono text-[9px] text-slate-500 uppercase tracking-widest pointer-events-none select-none">
    [ INITIALIZING WebGL 3D VECTORS... ]
  </div>
</div>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';
  import { feature } from 'topojson-client';
  import type { Topology } from 'topojson-specification';
  // @ts-ignore — world-atlas ships JSON data files without type declarations
  import worldTopo from 'world-atlas/countries-110m.json';

  let scene: THREE.Scene | null = null, 
      camera: THREE.PerspectiveCamera | null = null, 
      renderer: THREE.WebGLRenderer | null = null, 
      controls: OrbitControls | null = null;
  let globeMesh: THREE.Mesh | null = null, 
      innerGlobe: THREE.Mesh | null = null,
      linesGroup: THREE.Group | null = null,
      fleetsGroup: THREE.Group | null = null;
  
  let shouldSpin = true;
  let resumeSpinTimeout: ReturnType<typeof setTimeout> | null = null;
  let animationFrameId: number | null = null;

  const locations = {
    // ── CANADA ──
    PEI: { lat: 46.2507, lon: -63.1375, name: "PEI HQ" },
    HALIFAX: { lat: 44.6488, lon: -63.5752, name: "HALIFAX PORT" },
    MONTREAL: { lat: 45.5017, lon: -73.5673, name: "MONTREAL HUB" },
    TORONTO: { lat: 43.6532, lon: -79.3832, name: "TORONTO CORR" },
    WINNIPEG: { lat: 49.8951, lon: -97.1384, name: "WINNIPEG GATE" },
    CALGARY: { lat: 51.0447, lon: -114.0719, name: "CALGARY TERM" },
    EDMONTON: { lat: 53.5461, lon: -113.4938, name: "EDMONTON YARD" },
    VANCOUVER: { lat: 49.2827, lon: -123.1207, name: "VANCOUVER GATE" },
    // ── UNITED STATES ──
    BOSTON: { lat: 42.3601, lon: -71.0589, name: "BOSTON HUB" },
    NEW_YORK: { lat: 40.7128, lon: -74.0060, name: "NEW YORK TERM" },
    DETROIT: { lat: 42.3314, lon: -83.0458, name: "DETROIT X-BORDER" },
    CHICAGO: { lat: 41.8781, lon: -87.6298, name: "CHICAGO TERM" },
    MEMPHIS: { lat: 35.1495, lon: -90.0490, name: "MEMPHIS FREIGHT" },
    ATLANTA: { lat: 33.7490, lon: -84.3880, name: "ATLANTA HUB" },
    MIAMI: { lat: 25.7617, lon: -80.1918, name: "MIAMI DIVISION" },
    DALLAS: { lat: 32.7767, lon: -96.7970, name: "DALLAS FW TERM" },
    HOUSTON: { lat: 29.7604, lon: -95.3698, name: "HOUSTON HUB" },
    DENVER: { lat: 39.7392, lon: -104.9903, name: "DENVER CORR" },
    LOS_ANGELES: { lat: 34.0522, lon: -118.2437, name: "LA TERM" },
    SEATTLE: { lat: 47.6062, lon: -122.3321, name: "SEATTLE TERM" },
    MEXICO_CITY: { lat: 19.4326, lon: -99.1332, name: "MEXICO CITY" }
  };

  const routes = [
    // ── CANADIAN CORRIDORS ──────────────────────────────────────────────
    { from: locations.PEI, to: locations.HALIFAX, color: 0x00f0ff },        // Maritime
    { from: locations.PEI, to: locations.MONTREAL, color: 0x00f0ff },       // Quebec link
    { from: locations.PEI, to: locations.BOSTON, color: 0x00f0ff },         // Cross-border Maritime
    { from: locations.HALIFAX, to: locations.MONTREAL, color: 0x00f0ff },   // Maritime → Quebec
    { from: locations.MONTREAL, to: locations.TORONTO, color: 0xffaa00 },   // QC–ON corridor (major)
    { from: locations.TORONTO, to: locations.WINNIPEG, color: 0xffaa00 },   // Trans-Canada central
    { from: locations.WINNIPEG, to: locations.CALGARY, color: 0xffaa00 },   // Prairie corridor
    { from: locations.CALGARY, to: locations.EDMONTON, color: 0x00f0ff },   // Alberta corridor
    { from: locations.CALGARY, to: locations.VANCOUVER, color: 0x00f0ff },  // Trans-Canada west
    // ── CROSS-BORDER CORRIDORS ──────────────────────────────────────────
    { from: locations.TORONTO, to: locations.DETROIT, color: 0xffaa00 },    // Ambassador Bridge
    { from: locations.TORONTO, to: locations.CHICAGO, color: 0xffaa00 },    // ON–IL corridor
    { from: locations.VANCOUVER, to: locations.SEATTLE, color: 0x00f0ff },  // Pacific Gateway
    { from: locations.HOUSTON, to: locations.MEXICO_CITY, color: 0xffaa00 },// USMCA south
    // ── US CORRIDORS ────────────────────────────────────────────────────
    { from: locations.BOSTON, to: locations.NEW_YORK, color: 0x00f0ff },    // I-95 Northeast
    { from: locations.NEW_YORK, to: locations.ATLANTA, color: 0xffaa00 },   // I-95 Southeast
    { from: locations.ATLANTA, to: locations.MIAMI, color: 0x00f0ff },      // Florida corridor
    { from: locations.ATLANTA, to: locations.DALLAS, color: 0xffaa00 },     // Southern cross
    { from: locations.ATLANTA, to: locations.MEMPHIS, color: 0x00f0ff },    // I-20/I-22
    { from: locations.DALLAS, to: locations.HOUSTON, color: 0xffaa00 },     // Texas Triangle
    { from: locations.MEMPHIS, to: locations.DALLAS, color: 0xffaa00 },     // I-30/I-40
    { from: locations.CHICAGO, to: locations.DETROIT, color: 0x00f0ff },    // Great Lakes auto
    { from: locations.CHICAGO, to: locations.MEMPHIS, color: 0x00f0ff },    // I-57 corridor
    { from: locations.CHICAGO, to: locations.DENVER, color: 0xffaa00 },     // I-80/I-76 West
    { from: locations.DENVER, to: locations.LOS_ANGELES, color: 0x00f0ff }, // I-15/I-70 Mountain
    { from: locations.SEATTLE, to: locations.LOS_ANGELES, color: 0x00f0ff },// I-5 Pacific
    { from: locations.LOS_ANGELES, to: locations.HOUSTON, color: 0xffaa00 },// I-10 Southern
    { from: locations.LOS_ANGELES, to: locations.DALLAS, color: 0xffaa00 }, // I-10/I-20 Southwest
    { from: locations.HOUSTON, to: locations.MIAMI, color: 0x00f0ff },      // Gulf Coast
  ];

  interface FleetUnit {
    mesh: THREE.Mesh;
    curve: THREE.QuadraticBezierCurve3;
    progress: number;
    speed: number;
    route: any;
  }

  const fleetUnits: FleetUnit[] = [];

  interface GlowRing {
    mesh: THREE.Mesh;
    baseScale: number;
    speed: number;
    phase: number;
    maxScale: number;
    baseOpacity: number;
    terminalName: string;
  }

  const glowRings: GlowRing[] = [];

  interface Terminal {
    name: string;
    lat: number;
    lon: number;
    color: number;
    isHQ: boolean;
    pulseProgress: number; // -1 if inactive, 0..1 if active
    ringMesh1: THREE.Mesh | null;
    ringMesh2: THREE.Mesh | null;
  }

  const terminals: Terminal[] = [];

  function latLonToVector3(lat: number, lon: number, radius: number) {
    const phi = (90 - lat) * (Math.PI / 180);
    const theta = (lon + 180) * (Math.PI / 180);

    const x = -(radius * Math.sin(phi) * Math.cos(theta));
    const y = radius * Math.cos(phi);
    const z = radius * Math.sin(phi) * Math.sin(theta);

    return new THREE.Vector3(x, y, z);
  }

  // ═══════════════════════════════════════════════════════════════════════
  // World Map Texture Generator — Real Geographic Data (Natural Earth 110m)
  // Renders 177 country polygons via topojson-client onto an 8192×4096 canvas
  // with multi-layer cyber-neon styling, BRO corridor highlight, and hub markers.
  // ═══════════════════════════════════════════════════════════════════════
  function createWorldMapTexture(): THREE.CanvasTexture | null {
    const canvas = document.createElement('canvas');
    const W = 8192, H = 4096;
    const S = 2; // scale factor for line widths / radii relative to 4096×2048 base
    canvas.width = W;
    canvas.height = H;
    const ctx = canvas.getContext('2d');
    if (!ctx) return null;

    // ── 1. DEEP OCEAN BASE ──────────────────────────────────────────────
    ctx.fillStyle = '#020205';
    ctx.fillRect(0, 0, W, H);

    // ── 2. COORDINATE GRID ──────────────────────────────────────────────
    // Longitude lines every 15°
    ctx.strokeStyle = 'rgba(0, 240, 255, 0.025)';
    ctx.lineWidth = 0.5 * S;
    for (let lon = -180; lon <= 180; lon += 15) {
      const x = (lon + 180) * (W / 360);
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
    }
    // Latitude lines every 15°
    for (let lat = -90; lat <= 90; lat += 15) {
      const y = (90 - lat) * (H / 180);
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
    }
    // Special lines — Equator, Tropics, Arctic / Antarctic circles
    ctx.strokeStyle = 'rgba(0, 240, 255, 0.06)';
    ctx.lineWidth = 1 * S;
    [0, 23.44, -23.44, 66.56, -66.56].forEach(lat => {
      const y = (90 - lat) * (H / 180);
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
    });

    // ── 3. EQUIRECTANGULAR PROJECTION ────────────────────────────────────
    const project = (lon: number, lat: number): [number, number] => [
      (lon + 180) * (W / 360),
      (90 - lat) * (H / 180)
    ];

    // ── 4. DECODE TOPOJSON → GEOJSON ────────────────────────────────────
    const topo = worldTopo as unknown as Topology;
    const countriesGeo = feature(topo, topo.objects.countries as any);
    const landGeo = feature(topo, topo.objects.land as any);

    // Helper: trace a GeoJSON ring onto the current canvas path
    const traceRing = (ring: number[][]) => {
      ring.forEach(([lon, lat], i) => {
        const [x, y] = project(lon, lat);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.closePath();
    };

    // Helper: iterate polygons from a GeoJSON geometry
    const forEachPolygon = (
      geom: any,
      fn: (coordinates: number[][][]) => void
    ) => {
      if (!geom) return;
      if (geom.type === 'Polygon') fn(geom.coordinates);
      else if (geom.type === 'MultiPolygon')
        geom.coordinates.forEach((poly: number[][][]) => fn(poly));
    };

    // ── 5. LAYER 1 — LAND FILL (merged mass, subtle cyan) ───────────────
    ctx.save();
    ctx.shadowBlur = 8 * S;
    ctx.shadowColor = 'rgba(0, 240, 255, 0.15)';
    ctx.fillStyle = 'rgba(0, 240, 255, 0.055)';
    if ('features' in landGeo) {
      landGeo.features.forEach((feat: any) => {
        forEachPolygon(feat.geometry, (coords) => {
          ctx.beginPath();
          coords.forEach(ring => traceRing(ring));
          ctx.fill('evenodd');
        });
      });
    } else {
      forEachPolygon((landGeo as any).geometry, (coords: number[][][]) => {
        ctx.beginPath();
        coords.forEach(ring => traceRing(ring));
        ctx.fill('evenodd');
      });
    }
    ctx.restore();

    // ── 6. LAYER 2 — COUNTRY BORDERS (neon outlines with glow) ──────────
    ctx.save();
    ctx.shadowBlur = 10 * S;
    ctx.shadowColor = 'rgba(0, 240, 255, 0.3)';
    ctx.strokeStyle = 'rgba(0, 240, 255, 0.35)';
    ctx.lineWidth = 1.0 * S;
    if ('features' in countriesGeo) {
      countriesGeo.features.forEach((feat: any) => {
        forEachPolygon(feat.geometry, (coords) => {
          ctx.beginPath();
          coords.forEach(ring => traceRing(ring));
          ctx.stroke();
        });
      });
    }
    ctx.restore();

    // ── 7. LAYER 3 — SHARP COASTLINE PASS (no shadow, crisp edges) ──────
    ctx.save();
    ctx.strokeStyle = 'rgba(0, 240, 255, 0.22)';
    ctx.lineWidth = 0.5 * S;
    if ('features' in countriesGeo) {
      countriesGeo.features.forEach((feat: any) => {
        forEachPolygon(feat.geometry, (coords) => {
          ctx.beginPath();
          coords.forEach(ring => traceRing(ring));
          ctx.stroke();
        });
      });
    }
    ctx.restore();

    // ── 8. BRO NORTH AMERICA CORRIDOR HIGHLIGHT ─────────────────────────
    ctx.save();
    ctx.shadowBlur = 30 * S;
    ctx.shadowColor = 'rgba(255, 170, 0, 0.12)';
    ctx.fillStyle = 'rgba(255, 170, 0, 0.025)';
    ctx.beginPath();
    const corridor: [number, number][] = [
      [-140, 55], [-50, 55], [-50, 10], [-140, 10]
    ];
    corridor.forEach(([lon, lat], i) => {
      const [x, y] = project(lon, lat);
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    });
    ctx.closePath();
    ctx.fill();
    ctx.restore();


    return new THREE.CanvasTexture(canvas);
  }

  function initGlobe() {
    const container = document.getElementById('globe-canvas-container');
    const loader = document.getElementById('globe-loader');
    if (!container) return;

    if (loader) loader.style.display = 'none';

    const width = container.clientWidth;
    const height = container.clientHeight;

    // 0. Clean Up Previous WebGL Instances
    if (animationFrameId !== null) {
      cancelAnimationFrame(animationFrameId);
      animationFrameId = null;
    }
    if (resumeSpinTimeout) {
      clearTimeout(resumeSpinTimeout);
      resumeSpinTimeout = null;
    }
    shouldSpin = true;
    if (controls) {
      controls.dispose();
      controls = null;
    }
    if (renderer) {
      renderer.dispose();
      renderer = null;
    }
    if (scene) {
      scene.traverse((object: any) => {
        if (object.geometry) object.geometry.dispose();
        if (object.material) {
          if (Array.isArray(object.material)) {
            object.material.forEach((mat: any) => {
              if (mat.map) mat.map.dispose();
              mat.dispose();
            });
          } else {
            if (object.material.map) object.material.map.dispose();
            object.material.dispose();
          }
        }
      });
      scene = null;
    }
    fleetUnits.length = 0;
    terminals.length = 0;
    glowRings.length = 0;

    // 1. Scene Setup
    scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x030307, 0.0025);

    // 2. Camera Setup
    camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
    camera.position.set(0, 40, 150);

    // 3. Renderer Setup
    renderer = new THREE.WebGLRenderer({ 
      antialias: true, 
      alpha: true,
      powerPreference: "high-performance" 
    });
    renderer.setSize(width, height);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    
    container.innerHTML = '';
    container.appendChild(renderer.domElement);

    // 4. Controls Setup
    controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.minDistance = 55;
    controls.maxDistance = 250;
    controls.enablePan = false;

    // Spin control: stop on hover/touch, resume 5s after cursor leaves
    const stopSpin = () => {
      shouldSpin = false;
      if (resumeSpinTimeout) { clearTimeout(resumeSpinTimeout); resumeSpinTimeout = null; }
    };
    const scheduleResume = () => {
      if (resumeSpinTimeout) clearTimeout(resumeSpinTimeout);
      resumeSpinTimeout = setTimeout(() => { shouldSpin = true; }, 5000);
    };
    container.addEventListener('mouseenter', stopSpin);
    container.addEventListener('mouseleave', scheduleResume);
    container.addEventListener('touchstart', stopSpin, { passive: true });
    container.addEventListener('touchend', scheduleResume);

    // 5. Globe Layers (Obsidian Core + Holographic Wireframe)
    const globeGeometry = new THREE.SphereGeometry(50, 64, 64);
    const globeMaterial = new THREE.MeshStandardMaterial({
      color: 0x0e111f,
      wireframe: true,
      transparent: true,
      opacity: 0.12,
      roughness: 0.9,
      metalness: 0.1
    });
    globeMesh = new THREE.Mesh(globeGeometry, globeMaterial);
    scene.add(globeMesh);

    // Generate World Map Texture from Natural Earth 110m data
    const mapTexture = createWorldMapTexture();
    if (mapTexture && renderer) {
      mapTexture.anisotropy = renderer.capabilities.getMaxAnisotropy();
      mapTexture.minFilter = THREE.LinearMipmapLinearFilter;
      mapTexture.magFilter = THREE.LinearFilter;
      mapTexture.generateMipmaps = true;
    }
    const innerGeometry = new THREE.SphereGeometry(49.6, 64, 64);
    const innerMaterial = new THREE.MeshBasicMaterial({
      map: mapTexture || undefined,
      color: mapTexture ? undefined : 0x030307,
      transparent: true,
      opacity: 0.96
    });
    innerGlobe = new THREE.Mesh(innerGeometry, innerMaterial);
    scene.add(innerGlobe);

    // 6. Setup Lighting Environment
    const ambientLight = new THREE.AmbientLight(0x0e111f, 2.0);
    scene.add(ambientLight);

    const directionalLight1 = new THREE.DirectionalLight(0x00f0ff, 2.5);
    directionalLight1.position.set(150, 100, 50);
    scene.add(directionalLight1);

    const directionalLight2 = new THREE.DirectionalLight(0xffaa00, 1.5);
    directionalLight2.position.set(-150, -100, -50);
    scene.add(directionalLight2);

    // Groups for layout curves
    linesGroup = new THREE.Group();
    fleetsGroup = new THREE.Group();
    scene.add(linesGroup);
    scene.add(fleetsGroup);

    // 7. Draw Curves & Initialize Traveling Particles
    setupRoutes();

    // 8. Animation & Render Loop
    function animateLoop() {
      animationFrameId = requestAnimationFrame(animateLoop);

      // Slow elegant satellite drift — paused while user hovers
      if (shouldSpin && globeMesh && innerGlobe && linesGroup && fleetsGroup) {
        globeMesh.rotation.y += 0.0003;
        innerGlobe.rotation.y += 0.0003;
        linesGroup.rotation.y += 0.0003;
        fleetsGroup.rotation.y += 0.0003;
      }

      // Advance pulse progress for active terminals
      terminals.forEach(term => {
        if (term.pulseProgress >= 0.0) {
          term.pulseProgress += 0.025; // Wave pulse speed
          if (term.pulseProgress > 1.0) {
            term.pulseProgress = -1.0; // Reset to dormant
          }
        }
      });

      // Animate cargo particle vectors slowly along Bezier paths
      fleetUnits.forEach(unit => {
        unit.progress += unit.speed;

        // Trigger pulse on the destination terminal when the particle arrives
        if (unit.progress >= 1.0) {
          unit.progress = 0.0;
          const targetName = unit.route.to.name;
          const term = terminals.find(t => t.name === targetName);
          if (term) {
            term.pulseProgress = 0.0;
          }
        }

        const position = unit.curve.getPointAt(unit.progress % 1.0);
        unit.mesh.position.copy(position);
      });

      // Dynamic dot scaling — keep markers/particles a consistent screen size
      // regardless of zoom level by scaling inversely with camera distance.
      if (camera) {
        const camDist = camera.position.length(); // distance from globe center
        const refDist = 150; // default camera distance
        const dotScale = camDist / refDist;

        // Scale terminal markers and pulsing glow rings (Mesh children inside linesGroup)
        linesGroup?.children.forEach(child => {
          if ((child as THREE.Mesh).isMesh) {
            const ringInfo = glowRings.find(r => r.mesh === child);
            if (ringInfo) {
              const term = terminals.find(t => t.name === ringInfo.terminalName);
              if (term && term.pulseProgress >= 0.0) {
                // Pulse is active! Scale and fade ring
                const phase = term.pulseProgress;
                const pulseFactor = 0.5 + (ringInfo.maxScale - 0.5) * phase;
                child.scale.setScalar(dotScale * pulseFactor);
                // @ts-ignore
                child.material.opacity = ringInfo.baseOpacity * (1 - phase);
              } else {
                // Dormant
                // @ts-ignore
                child.material.opacity = 0.0;
                child.scale.setScalar(0.0);
              }
            } else {
              // Regular marker sphere
              child.scale.setScalar(dotScale);
            }
          }
        });

        // Scale cargo particles
        fleetUnits.forEach(unit => {
          unit.mesh.scale.setScalar(dotScale);
        });
      }

      if (controls && renderer && scene && camera) {
        controls.update();
        renderer.render(scene, camera);
      }
    }

    animateLoop();

    // Handle Window Resize
    function handleResize() {
      if (!container || !camera || !renderer) return;
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    }

    window.addEventListener('resize', handleResize);
  }

  function setupRoutes() {
    // Sharp high-tech terminal markers (small base radius, scaled dynamically)
    const markerGeometry = new THREE.SphereGeometry(0.35, 16, 16);

    // Track unique terminals to avoid duplicate meshes & coordinate concentric pulse rings
    const terminalMap = new Map<string, {
      name: string;
      lat: number;
      lon: number;
      color: number;
      isHQ: boolean;
    }>();

    routes.forEach(route => {
      // Collect unique terminal locations
      [route.from, route.to].forEach(loc => {
        const isHQ = loc.name === "PEI HQ";
        const color = isHQ ? 0xffaa00 : route.color;
        if (!terminalMap.has(loc.name)) {
          terminalMap.set(loc.name, { name: loc.name, lat: loc.lat, lon: loc.lon, color, isHQ });
        } else {
          // If already added, gold takes precedence over cyan
          const existing = terminalMap.get(loc.name)!;
          if (color === 0xffaa00) {
            existing.color = 0xffaa00;
          }
        }
      });

      const pStart = latLonToVector3(route.from.lat, route.from.lon, 50);
      const pEnd = latLonToVector3(route.to.lat, route.to.lon, 50);

      // Create arched control point based on distance between terminals
      const midPoint = new THREE.Vector3().addVectors(pStart, pEnd).multiplyScalar(0.5);
      const distance = pStart.distanceTo(pEnd);
      midPoint.normalize().multiplyScalar(50 + distance * 0.22);

      // Construct Quadratic Bezier Curve
      const curve = new THREE.QuadraticBezierCurve3(pStart, midPoint, pEnd);
      
      // Draw static path line
      const pathPoints = curve.getPoints(40);
      const pathGeometry = new THREE.BufferGeometry().setFromPoints(pathPoints);
      const pathMaterial = new THREE.LineBasicMaterial({
        color: route.color,
        transparent: true,
        opacity: 0.35
      });
      const pathLine = new THREE.Line(pathGeometry, pathMaterial);
      linesGroup!.add(pathLine);

      // Sleek cargo vectors (small base radius, scaled dynamically)
      const particleGeo = new THREE.SphereGeometry(0.22, 12, 12);
      const particleMat = new THREE.MeshBasicMaterial({
        color: route.color === 0xffaa00 ? 0xffaa00 : 0x00f0ff,
        transparent: true,
        opacity: 0.95
      });

      // Spawn staggered particles gliding smoothly and slowly (0.001 speed)
      const particleMesh1 = new THREE.Mesh(particleGeo, particleMat);
      fleetsGroup!.add(particleMesh1);
      fleetUnits.push({
        mesh: particleMesh1,
        curve: curve,
        progress: Math.random(),
        speed: 0.0008 + Math.random() * 0.0006,
        route: route
      });

      const particleMesh2 = new THREE.Mesh(particleGeo, particleMat);
      fleetsGroup!.add(particleMesh2);
      fleetUnits.push({
        mesh: particleMesh2,
        curve: curve,
        progress: (Math.random() + 0.5) % 1.0,
        speed: 0.0008 + Math.random() * 0.0006,
        route: route
      });
    });

    // Draw unique terminals and their pulsing telematic glow rings
    terminalMap.forEach((term) => {
      const p = latLonToVector3(term.lat, term.lon, 50);

      // 1. Draw central terminal marker sphere
      const markerMat = new THREE.MeshBasicMaterial({ color: term.color });
      const markerMesh = new THREE.Mesh(markerGeometry, markerMat);
      markerMesh.position.copy(p);
      linesGroup!.add(markerMesh);

      // 2. Create telematic radar glow rings
      // Ring 1: Inner pulsing ring
      const ringGeo1 = new THREE.RingGeometry(0.35, 0.7, 32);
      const ringMat1 = new THREE.MeshBasicMaterial({
        color: term.color,
        transparent: true,
        opacity: 0.0, // starts completely invisible (dormant)
        side: THREE.DoubleSide,
        depthWrite: false
      });
      const ringMesh1 = new THREE.Mesh(ringGeo1, ringMat1);
      const pRing1 = latLonToVector3(term.lat, term.lon, 50.15);
      ringMesh1.position.copy(pRing1);
      ringMesh1.lookAt(0, 0, 0); // Orient flat on sphere surface
      linesGroup!.add(ringMesh1);

      glowRings.push({
        mesh: ringMesh1,
        baseScale: 1.0,
        speed: 0.035, // fast, reactive trigger pulse
        phase: 0.0,
        maxScale: 2.2,
        baseOpacity: 0.8,
        terminalName: term.name
      });

      // Ring 2: Outer pulsing ring (larger and slower)
      const ringGeo2 = new THREE.RingGeometry(0.4, 0.9, 32);
      const ringMat2 = new THREE.MeshBasicMaterial({
        color: term.color,
        transparent: true,
        opacity: 0.0, // starts completely invisible (dormant)
        side: THREE.DoubleSide,
        depthWrite: false
      });
      const ringMesh2 = new THREE.Mesh(ringGeo2, ringMat2);
      const pRing2 = latLonToVector3(term.lat, term.lon, 50.2);
      ringMesh2.position.copy(pRing2);
      ringMesh2.lookAt(0, 0, 0);
      linesGroup!.add(ringMesh2);

      glowRings.push({
        mesh: ringMesh2,
        baseScale: 1.0,
        speed: 0.02, // slightly slower outer pulse
        phase: 0.0,
        maxScale: 4.0,
        baseOpacity: 0.5,
        terminalName: term.name
      });

      // Track Terminal in global array
      terminals.push({
        name: term.name,
        lat: term.lat,
        lon: term.lon,
        color: term.color,
        isHQ: term.isHQ,
        pulseProgress: -1.0, // inactive (dormant)
        ringMesh1: ringMesh1,
        ringMesh2: ringMesh2
      });
    });
  }

  // Load globe on hydration
  document.addEventListener('astro:page-load', initGlobe);
</script>
