---
const base = import.meta.env.BASE_URL;
---
<div class="relative w-full h-[400px] md:h-[500px] rounded border border-slate-900/60 bg-bro-steel/20 overflow-hidden shadow-2xl flex items-center justify-center select-none">
  <!-- Interactive WebGL Canvas Container -->
  <div id="globe-canvas-container" class="absolute inset-0 w-full h-full cursor-grab active:cursor-grabbing"></div>
  
  <!-- Diagnostic Telemetry HUD overlay -->
  <div class="absolute bottom-4 left-4 z-10 font-mono text-[9px] text-slate-500 uppercase tracking-widest bg-bro-obsidian/70 backdrop-blur-md px-3 py-2 border border-slate-900/50 rounded flex flex-col gap-1 pointer-events-none select-none">
    <div class="flex items-center gap-1.5 text-bro-cyan font-bold">
      <span class="h-1.5 w-1.5 rounded-full bg-bro-cyan animate-ping"></span>
      LIVE GLOBAL TRANSIT FEED
    </div>
    <div>ACTIVE_LANES: <span class="text-slate-350">100 // INS_GPU</span></div>
    <div>SATELLITE_LINK: <span class="text-bro-gold font-bold">ESTABLISHED</span></div>
  </div>

  <div id="globe-loader" class="absolute z-10 font-mono text-[9px] text-slate-500 uppercase tracking-widest pointer-events-none select-none">
    [ INITIALIZING WebGL 3D COMMAND GLOBE... ]
  </div>
</div>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  let scene: THREE.Scene, 
      camera: THREE.PerspectiveCamera, 
      renderer: THREE.WebGLRenderer, 
      controls: OrbitControls;
  let globeMesh: THREE.Mesh, 
      innerGlobe: THREE.Mesh,
      routeInstancedMesh: THREE.InstancedMesh;
  
  const MAX_ROUTES = 100;
  let isDragging = false;

  function initGlobe() {
    const container = document.getElementById('globe-canvas-container');
    const loader = document.getElementById('globe-loader');
    if (!container) return;

    if (loader) loader.style.display = 'none';

    const width = container.clientWidth;
    const height = container.clientHeight;

    // 1. Scene Setup
    scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x030307, 0.002);

    // 2. Camera Setup
    camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
    camera.position.set(0, 0, 160);

    // 3. Renderer Setup
    renderer = new THREE.WebGLRenderer({ 
      antialias: true, 
      alpha: true,
      powerPreference: "high-performance" 
    });
    renderer.setSize(width, height);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    
    // Clear old canvases
    container.innerHTML = '';
    container.appendChild(renderer.domElement);

    // 4. Controls Setup
    controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.minDistance = 90;
    controls.maxDistance = 250;
    controls.enablePan = false;

    // Track user drag interactions to pause auto-rotation
    controls.addEventListener('start', () => { isDragging = true; });
    controls.addEventListener('end', () => { isDragging = false; });

    // 5. Build Globe Mesh Layers (Holographic Wireframe Grid)
    const globeGeometry = new THREE.SphereGeometry(50, 48, 48);
    const globeMaterial = new THREE.MeshStandardMaterial({
      color: 0x00f0ff,
      wireframe: true,
      transparent: true,
      opacity: 0.12,
      roughness: 0.9,
      metalness: 0.1
    });
    globeMesh = new THREE.Mesh(globeGeometry, globeMaterial);
    scene.add(globeMesh);

    // Deep solid inner core to hide backside routes
    const innerGeometry = new THREE.SphereGeometry(49.5, 48, 48);
    const innerMaterial = new THREE.MeshBasicMaterial({
      color: 0x05070d,
      transparent: true,
      opacity: 0.85
    });
    innerGlobe = new THREE.Mesh(innerGeometry, innerMaterial);
    scene.add(innerGlobe);

    // 6. Setup Lighting Environment
    const ambientLight = new THREE.AmbientLight(0x0e111f, 1.8);
    scene.add(ambientLight);

    const directionalLight1 = new THREE.DirectionalLight(0x00f0ff, 2.5);
    directionalLight1.position.set(120, 80, 50);
    scene.add(directionalLight1);

    const directionalLight2 = new THREE.DirectionalLight(0xffaa00, 1.2);
    directionalLight2.position.set(-120, -80, -50);
    scene.add(directionalLight2);

    // 7. Setup Instanced Shipping Routes (GPU batched)
    setupInstancedLanes();

    // 8. Animation & Render Loop
    function animateLoop() {
      requestAnimationFrame(animateLoop);

      // Auto-rotation sequence that pauses during user drag interaction
      if (!isDragging) {
        globeMesh.rotation.y += 0.0006;
        innerGlobe.rotation.y += 0.0006;
        routeInstancedMesh.rotation.y += 0.0006;
      }

      // Animate points slightly for organic signal effect
      const time = Date.now() * 0.001;
      const count = routeInstancedMesh.count;
      const dummyMatrix = new THREE.Object3D();
      
      for (let i = 0; i < count; i++) {
        const matrix = new THREE.Matrix4();
        routeInstancedMesh.getMatrixAt(i, matrix);
        
        const position = new THREE.Vector3();
        position.setFromMatrixPosition(matrix);
        
        // Add a subtle wave scale factor based on time and index
        const scaleVal = 1.0 + Math.sin(time + i) * 0.15;
        
        dummyMatrix.position.copy(position);
        dummyMatrix.scale.set(scaleVal, scaleVal, scaleVal);
        dummyMatrix.updateMatrix();
        routeInstancedMesh.setMatrixAt(i, dummyMatrix.matrix);
      }
      routeInstancedMesh.instanceMatrix.needsUpdate = true;

      controls.update();
      renderer.render(scene, camera);
    }

    animateLoop();

    // Handle Window Resize events
    function handleResize() {
      if (!container || !camera || !renderer) return;
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    }

    window.addEventListener('resize', handleResize);
  }

  function setupInstancedLanes() {
    // Generate route geometries on the GPU
    const curvePoints = new THREE.BoxGeometry(0.6, 0.6, 0.6);
    const instancedMaterial = new THREE.MeshBasicMaterial({ 
      color: 0x00f0ff, 
      transparent: true, 
      opacity: 0.85 
    });
    
    routeInstancedMesh = new THREE.InstancedMesh(curvePoints, instancedMaterial, MAX_ROUTES);
    const dummyMatrix = new THREE.Object3D();

    for (let i = 0; i < MAX_ROUTES; i++) {
      // Map coordinate vectors: cluster routes primarily in North America sector (lat 30-55, lon -125 to -60)
      const theta = (Math.random() * 65 - 125) * (Math.PI / 180); // Longitude range
      const phi = (90 - (Math.random() * 25 + 30)) * (Math.PI / 180); // Latitude range
      
      const radius = 50.2;
      const x = radius * Math.sin(phi) * Math.sin(theta);
      const y = radius * Math.cos(phi);
      const z = radius * Math.sin(phi) * Math.cos(theta);

      dummyMatrix.position.set(x, y, z);
      dummyMatrix.scale.set(1, 1, 1);
      dummyMatrix.updateMatrix();
      routeInstancedMesh.setMatrixAt(i, dummyMatrix.matrix);
    }
    
    routeInstancedMesh.instanceMatrix.needsUpdate = true;
    scene.add(routeInstancedMesh);
  }

  // Load globe on hydration
  document.addEventListener('astro:page-load', initGlobe);
</script>
