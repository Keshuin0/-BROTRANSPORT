---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import AllySupportTrigger from '../components/AllySupportTrigger';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "#BRO Transport Corp. | Elite Commercial Freight Logistics & Dispatch", 
  description = "High-performance Dry Van, Reefer, and Flatbed commercial freight dispatching. Managed cross-border logistics, cold-chain temperature control, and industrial open-deck operations."
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    
    <!-- Load Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Roboto+Flex:opsz,wdth,wght@8..144,25..151,100..1000&display=swap" rel="stylesheet" />
    
    <!-- Preload Local WOFF2 Fonts -->
    <link rel="preload" href={`${base}fonts/inter-latin.woff2`} as="font" type="font/woff2" crossorigin />
    
    <ClientRouter />

    <!-- Cloudflare Turnstile API -->
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
  </head>
  <body class="bg-bro-obsidian bg-cyber-grid text-bro-ice min-h-screen selection:bg-bro-cyan/30 selection:text-bro-cyan relative flex flex-col justify-between">
    <div>
      <!-- Top glowing status accent line -->
      <div class="h-[2px] w-full bg-gradient-to-r from-bro-gold via-bro-cyan to-bro-gold sticky top-0 z-50"></div>
      
      <!-- Unified Header -->
      <header class="sticky top-0 z-40 backdrop-blur-md bg-bro-obsidian/85 border-b border-slate-900/80">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
          <a href={base} class="flex items-center gap-2 group">
            <div class="h-2.5 w-2.5 bg-bro-cyan rounded-full animate-pulse shadow-[0_0_8px_rgba(0,240,255,0.4)] group-hover:bg-bro-cyan transition-colors shrink-0"></div>
            <img src={`${base}images/logo.jpg?v=3`} alt="#BRO TRANSPORT" class="h-10 sm:h-12 w-auto object-contain transition-opacity group-hover:opacity-90" />
          </a>
          
          <nav class="hidden md:flex items-center gap-8 text-xs font-mono uppercase tracking-wider text-slate-350">
            <a href={base} class="hover:text-bro-cyan transition-colors">Home</a>
            <a href={`${base}quote`} data-astro-prefetch class="hover:text-bro-cyan transition-colors">Quote Engine</a>
            <a href={`${base}drivers`} data-astro-prefetch class="hover:text-bro-cyan transition-colors">Driver Gateway</a>
            <a href={`${base}customs`} data-astro-prefetch class="hover:text-bro-cyan transition-colors">Customs Docs</a>
          </nav>

          <div class="flex items-center gap-4">
            <!-- Ally Support Trigger Button -->
            <AllySupportTrigger client:load />
          </div>
        </div>
      </header>

      <main class="w-full">
        <slot />
      </main>
    </div>

    <!-- Unified Footer -->
    <footer class="w-full border-t border-slate-900 bg-bro-obsidian/95 py-8 mt-16">
      <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4 text-slate-500 font-mono text-[10px]">
        <div>
          <span class="text-white font-bold tracking-wider">#BRO TRANSPORT CORP.</span>
          <span class="ml-2 font-light">| NORTH AMERICAN FREIGHT NETWORK</span>
        </div>
        <div>
          <span>© 2026 #BRO Transport Corp. All rights reserved.</span>
        </div>
      </div>
    </footer>

  </body>
</html>
