---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "#BRO Transport Corp. | Elite Heavy-Haul Logistics & Dispatch", 
  description = "High-performance specialized heavy-haul dispatching and logistics coordinator. Managed cross-border operations, oversized permit loads, and safety compliance."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    
    <!-- Preload Local WOFF2 Fonts -->
    <link rel="preload" href={`${import.meta.env.BASE_URL}fonts/outfit-latin.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${import.meta.env.BASE_URL}fonts/inter-latin.woff2`} as="font" type="font/woff2" crossorigin />
    
    <!-- Client Router for seamless Transitions -->
    <ClientRouter />

    <!-- Cloudflare Turnstile API (Explicit render mode) -->
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
  </head>
  <body class="bg-[#05070D] futuristic-grid text-slate-100 min-h-screen selection:bg-blue-500/30 selection:text-blue-200 relative">
    <!-- Top cyber status accent line -->
    <div class="h-[2px] w-full bg-gradient-to-r from-blue-500 via-cyan-500 to-amber-500 sticky top-0 z-50"></div>
    <slot />
  </body>
</html>
