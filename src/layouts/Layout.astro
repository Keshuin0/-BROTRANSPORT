---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "#BRO Transport Corp. | Elite Commercial Freight Logistics & Dispatch", 
  description = "High-performance Dry Van, Reefer, and Flatbed commercial freight dispatching. Managed cross-border logistics, cold-chain temperature control, and industrial open-deck operations."
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    
    <!-- Preconnect and Load Google Fonts (Roboto Flex & JetBrains Mono) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Roboto+Flex:opsz,wdth,wght@8..144,25..151,100..1000&display=swap" rel="stylesheet" />
    
    <!-- Preload Local WOFF2 Fonts -->
    <link rel="preload" href={`${base}fonts/inter-latin.woff2`} as="font" type="font/woff2" crossorigin />
    
    <!-- Client Router for seamless Transitions -->
    <ClientRouter />

    <!-- Cloudflare Turnstile API (Explicit render mode) -->
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
  </head>
  <body class="bg-bro-obsidian bg-cyber-grid text-bro-ice min-h-screen selection:bg-bro-cyan/30 selection:text-bro-cyan relative pb-16 md:pb-0">
    <!-- Top cyber status accent line -->
    <div class="h-[2px] w-full bg-gradient-to-r from-bro-gold via-bro-cyan to-bro-gold sticky top-0 z-50"></div>
    
    <slot />

    <!-- Floating Audio HUD Control -->
    <div class="fixed bottom-6 right-6 z-[99] flex items-center gap-2">
      <button id="bro-audio-toggle" class="bg-[#020408]/90 border border-slate-900 hover:border-cyan-500/50 backdrop-blur-md px-3.5 py-2.5 rounded text-[10px] font-mono font-bold tracking-widest text-slate-400 hover:text-white transition-all flex items-center gap-2 shadow-2xl hover:shadow-[0_0_15px_rgba(0,240,255,0.15)] cursor-pointer animate-[pulse_3s_infinite]" style="content-visibility: auto;">
        <span id="bro-audio-dot" class="h-2 w-2 rounded-full bg-slate-650 transition-all duration-300"></span>
        <span id="bro-audio-label">AUDIO: OFF</span>
      </button>
    </div>

    <script>
      import { broAudio } from '../lib/audio';

      // Setup UI handlers and interaction listeners
      function initAudioLayout() {
        const toggleBtn = document.getElementById('bro-audio-toggle');
        const dot = document.getElementById('bro-audio-dot');
        const label = document.getElementById('bro-audio-label');

        function updateUI() {
          if (!dot || !label) return;
          if (broAudio.isEnabled()) {
            dot.className = 'h-2 w-2 rounded-full bg-cyan-400 shadow-[0_0_8px_#00f0ff] animate-pulse';
            label.className = 'text-cyan-400';
            label.innerText = 'AUDIO: ON';
          } else {
            dot.className = 'h-2 w-2 rounded-full bg-slate-650';
            label.className = 'text-slate-400';
            label.innerText = 'AUDIO: OFF';
          }
        }

        // Initialize state on load
        updateUI();

        // Safe initialize on first user gesture
        const safeInit = () => {
          broAudio.init();
          window.removeEventListener('click', safeInit);
          window.removeEventListener('keydown', safeInit);
          window.removeEventListener('mouseenter', safeInit);
        };
        window.addEventListener('click', safeInit);
        window.addEventListener('keydown', safeInit);
        window.addEventListener('mouseenter', safeInit);

        if (toggleBtn) {
          toggleBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (broAudio.isEnabled()) {
              broAudio.disable();
            } else {
              broAudio.enable();
            }
            updateUI();
            broAudio.playTabClick();
          });
        }

        // Apply interactive micro hover sounds to clickable console elements
        document.querySelectorAll('a, button, select, input[type="checkbox"], input[type="radio"], input[type="range"], input[type="text"], input[type="tel"]').forEach(element => {
          element.addEventListener('mouseenter', () => {
            broAudio.playTabClick();
          });
        });
      }

      // Safe page swaps glitch sound
      document.addEventListener('astro:after-swap', () => {
        broAudio.playScanlineGlitch();
      });

      document.addEventListener('astro:page-load', initAudioLayout);
    </script>
  </body>
</html>
