---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const manifestJson = `{
  "manifestType": "ACE_EManifest",
  "scac": "BROP",
  "tripNumber": "BROP20261024A",
  "portOfEntry": "0115",
  "estimatedArrival": "2026-10-24T14:30:00Z",
  "conveyance": {
    "vin": "1FVACWDB2GHXXXXXX",
    "plate": "PE9948",
    "state": "PE"
  },
  "crew": [
    {
      "fastCardNumber": "980012345",
      "firstName": "Robert",
      "lastName": "MacDonald",
      "dateOfBirth": "1982-04-12"
    }
  ],
  "shipments": [
    {
      "papsNumber": "BROP8843921",
      "shipper": {
        "name": "PEI Potato Co-Op",
        "address": "100 Spud Road, Summerside, PE"
      },
      "consignee": {
        "name": "Boston Distribution Hub",
        "address": "45 Market Blvd, Boston, MA"
      },
      "commodity": "Potatoes",
      "weight": 22679.6,
      "weightUnit": "KG",
      "quantity": 24,
      "packageType": "Pallet"
    }
  ]
}`;
---

<Layout title="Cross-Border Customs Compliance | #BRO Transport Corp." description="Frictionless transborder transit. Automated customs manifest processing for CBSA and CBP including PAPS, PARS, ACE, and ACI schemas.">
  <!-- Customs Portal Hero -->
  <section class="py-20 px-6 bg-[radial-gradient(ellipse_60%_60%_at_50%_-20%,rgba(0,240,255,0.06),rgba(255,255,255,0))] border-b border-slate-900/60 relative z-10">
    <div class="max-w-4xl mx-auto text-center space-y-4">
      <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-bro-cyan font-bold px-3 py-1 bg-bro-steel/30 rounded-full border border-bro-cyan/20">
        // PORT_CLEARANCE_INTELLIGENCE
      </span>
      <h1 class="text-3xl sm:text-5xl font-black tracking-tight leading-none text-white font-display uppercase">
        Customs Compliance
      </h1>
      <p class="text-bro-ice/70 text-sm sm:text-base max-w-xl mx-auto leading-relaxed font-sans">
        Frictionless transborder transit. Automated manifest pre-processing and data transmission pipelines for CBSA and CBP gateways.
      </p>
    </div>
  </section>

  <!-- Customs Documentation Grid -->
  <section class="py-16 px-6 relative z-10 max-w-6xl mx-auto space-y-12">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
      
      <!-- CBP PAPS Pipeline Info -->
      <div class="bg-bro-steel/20 border border-slate-900 p-6 rounded-lg space-y-6 hover:border-bro-cyan/30 transition-all duration-300">
        <div class="flex items-center gap-2 font-mono text-[10px] text-slate-500">
          <span class="h-2 w-2 rounded-full bg-bro-cyan animate-pulse"></span>
          <span>COMPLIANCE_PIPELINE // U.S. IMPORTATION</span>
        </div>
        
        <h3 class="text-xl font-bold font-display uppercase text-white tracking-wide">PAPS / ACE eManifest</h3>
        <p class="text-slate-400 text-xs leading-relaxed font-sans">
          For shipments moving from Canada into the United States, the system coordinates the **Pre-Arrival Processing System (PAPS)**. Each trailer load is assigned a unique PAPS number using our Standard Carrier Alpha Code (**SCAC: `BROP`**).
        </p>

        <div class="bg-[#030307]/50 border border-slate-900 rounded p-4 font-mono text-[9.5px] text-slate-450 space-y-3">
          <div class="flex justify-between">
            <span class="text-white font-bold">Regulatory Agency:</span>
            <span>U.S. Customs & Border Protection (CBP)</span>
          </div>
          <div class="flex justify-between">
            <span class="text-white font-bold">Identifier Scheme:</span>
            <span>SCAC + SCN (Shipment Control Number)</span>
          </div>
          <div class="flex justify-between">
            <span class="text-white font-bold">Submission Threshold:</span>
            <span class="text-bro-cyan">Minimum 1 hour prior to port arrival</span>
          </div>
          <div class="flex justify-between">
            <span class="text-white font-bold">Electronic Interface:</span>
            <span>Automated Broker Interface (ABI) to ACE</span>
          </div>
        </div>
      </div>

      <!-- CBSA PARS Pipeline Info -->
      <div class="bg-bro-steel/20 border border-slate-900 p-6 rounded-lg space-y-6 hover:border-bro-cyan/30 transition-all duration-300">
        <div class="flex items-center gap-2 font-mono text-[10px] text-slate-500">
          <span class="h-2 w-2 rounded-full bg-bro-cyan animate-pulse"></span>
          <span>COMPLIANCE_PIPELINE // CANADIAN IMPORTATION</span>
        </div>
        
        <h3 class="text-xl font-bold font-display uppercase text-white tracking-wide">PARS / ACI eManifest</h3>
        <p class="text-slate-400 text-xs leading-relaxed font-sans">
          For northbound transits entering Canada, our operations coordinate the **Pre-Arrival Review System (PARS)** and Advance Commercial Information (**ACI**) eManifest. Manifests are transmitted at least 1 hour before arrival.
        </p>

        <div class="bg-[#030307]/50 border border-slate-900 rounded p-4 font-mono text-[9.5px] text-slate-450 space-y-3">
          <div class="flex justify-between">
            <span class="text-white font-bold">Regulatory Agency:</span>
            <span>Canada Border Services Agency (CBSA)</span>
          </div>
          <div class="flex justify-between">
            <span class="text-white font-bold">Identifier Scheme:</span>
            <span>Carrier Code + Cargo Control Number (CCN)</span>
          </div>
          <div class="flex justify-between">
            <span class="text-white font-bold">Submission Threshold:</span>
            <span class="text-bro-cyan">Minimum 1 hour prior to port arrival</span>
          </div>
          <div class="flex justify-between">
            <span class="text-white font-bold">Release Verification:</span>
            <span>Release Notification System (RNS) sync</span>
          </div>
        </div>
      </div>

    </div>

    <!-- JSON eManifest Schema Block -->
    <div class="bg-bro-steel/20 border border-slate-900 p-6 rounded-lg space-y-6">
      <div class="flex justify-between items-center border-b border-slate-900/60 pb-3">
        <div class="flex items-center gap-2 font-mono text-[10px] text-slate-500">
          <span class="h-1.5 w-1.5 rounded-full bg-bro-cyan"></span>
          <span>ACE_eMANIFEST_JSON_SCHEMA</span>
        </div>
        <span class="text-[9px] font-mono text-slate-650">BROP_STANDARDS_V2</span>
      </div>

      <p class="text-slate-400 text-xs leading-relaxed font-sans">
        API validation schema for cargo declarations. This JSON payload is transmitted electronically to CBP/CBSA border check-points before the transport unit reaches the port of entry:
      </p>

      <div class="bg-[#030307]/70 border border-slate-950 rounded p-4 relative">
        <pre class="text-[10px] font-mono text-cyan-400 overflow-x-auto leading-relaxed select-text p-2" style="white-space: pre-wrap; word-wrap: break-word;">{manifestJson}</pre>
      </div>
    </div>

  </section>
</Layout>
