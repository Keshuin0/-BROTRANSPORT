---
import Layout from '../layouts/Layout.astro';
import QuoteEngine from '../components/QuoteEngine.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Procurement & Quote Engine | #BRO Transport Corp." description="Request an operations quote. Evaluate load weights and trailer configurations. Real-time Dry Van, Reefer, and Flatbed rate calculations.">
  <!-- Quote Portal Hero -->
  <section class="py-20 px-6 bg-[radial-gradient(ellipse_60%_60%_at_50%_-20%,rgba(0,240,255,0.06),rgba(255,255,255,0))] border-b border-slate-900/60 relative z-10">
    <div class="max-w-4xl mx-auto text-center space-y-4">
      <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-bro-cyan font-bold px-3 py-1 bg-bro-steel/30 rounded-full border border-bro-cyan/20">
        // PROCUREMENT_DIVISION
      </span>
      <h1 class="text-3xl sm:text-5xl font-black tracking-tight leading-none text-white font-display uppercase">
        Operational Rate Calculator
      </h1>
      <p class="text-bro-ice/70 text-sm sm:text-base max-w-xl mx-auto leading-relaxed font-sans">
        Specify your cargo parameters to calculate instant estimated B2B shipping rates for commercial Dry Van, Refrigerated Reefer, or open Flatbed freight networks.
      </p>
    </div>
  </section>

  <!-- Quote Engine Container -->
  <section class="py-16 px-6 relative z-10">
    <div class="max-w-5xl mx-auto">
      <QuoteEngine />
    </div>
  </section>
</Layout>
