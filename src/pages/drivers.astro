---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Driver Intake Portal | #BRO Transport Corp." description="Progressive recruitment portal for commercial dry van, reefer, and flatbed transport operations. Driver qualifications, safety certifications, and intake.">
  <!-- Driver Portal Hero -->
  <section class="py-20 px-6 bg-[radial-gradient(ellipse_60%_60%_at_50%_-20%,rgba(0,240,255,0.06),rgba(255,255,255,0))] border-b border-slate-900/60 relative z-10">
    <div class="max-w-4xl mx-auto text-center space-y-4">
      <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-bro-cyan font-bold px-3 py-1 bg-bro-steel/30 rounded-full border border-bro-cyan/20">
        // CAPACITY_DESK
      </span>
      <h1 class="text-3xl sm:text-5xl font-black tracking-tight leading-none text-white font-display uppercase">
        Driver Gateway
      </h1>
      <p class="text-bro-ice/70 text-sm sm:text-base max-w-xl mx-auto leading-relaxed font-sans">
        Join our freight fleet. Access premium cross-border loads, clean routing pipelines, and secure payment terms. Submit your driver credentials below.
      </p>
    </div>
  </section>

  <!-- Driver Registration Form Section -->
  <section class="py-16 px-6 relative z-10">
    <div class="max-w-xl mx-auto bg-bro-steel/20 border border-slate-900 rounded-lg p-6 md:p-8 shadow-2xl backdrop-blur-md">
      
      <form id="driver-intake-form" class="space-y-6">
        <div class="flex items-center gap-2 border-b border-slate-900/60 pb-3 mb-6">
          <span class="h-2 w-2 rounded-full bg-bro-cyan animate-pulse"></span>
          <h2 class="text-xs font-mono uppercase tracking-widest text-slate-450">CAPACITY_PARTNER_REGISTRATION</h2>
        </div>

        <div class="space-y-4">
          <!-- Driver Name -->
          <div class="space-y-1.5 font-mono text-[9px] text-slate-550">
            <label class="block text-slate-500 uppercase tracking-wider">Driver Full Name:</label>
            <input type="text" name="driverName" id="input-driverName" placeholder="e.g. Robert MacDonald" class="w-full bg-[#030307]/50 border border-slate-900 rounded p-3 text-white text-xs outline-none focus:border-bro-cyan transition-colors" />
          </div>

          <!-- Contact Number -->
          <div class="space-y-1.5 font-mono text-[9px] text-slate-550">
            <label class="block text-slate-500 uppercase tracking-wider">Contact Phone (10-Digit):</label>
            <input type="tel" name="driverPhone" id="input-driverPhone" placeholder="e.g. 9029166936" class="w-full bg-[#030307]/50 border border-slate-900 rounded p-3 text-white text-xs outline-none focus:border-bro-cyan transition-colors" />
          </div>

          <!-- Equipment Type -->
          <div class="space-y-1.5 font-mono text-[9px] text-slate-550">
            <label class="block text-slate-500 uppercase tracking-wider">Equipment division class:</label>
            <select name="equipType" id="select-equipType" class="w-full bg-[#030307]/50 border border-slate-900 rounded p-3 text-white text-xs outline-none focus:border-bro-cyan transition-colors">
              <option value="dry-van">53FT DRY VAN</option>
              <option value="reefer">53FT REEFER / COLD CHAIN</option>
              <option value="flatbed">OPEN DECK / FLATBED / HEAVY-HAUL</option>
            </select>
          </div>

          <!-- Preferred Lanes -->
          <div class="space-y-1.5 font-mono text-[9px] text-slate-550">
            <label class="block text-slate-500 uppercase tracking-wider">Primary lanes & transit routes:</label>
            <input type="text" name="preferredLanes" id="input-preferredLanes" placeholder="e.g. PEI -> Boston, PEI -> Montreal" class="w-full bg-[#030307]/50 border border-slate-900 rounded p-3 text-white text-xs outline-none focus:border-bro-cyan transition-colors" />
          </div>

          <!-- Mandatory Declarations -->
          <div class="space-y-3 pt-3 border-t border-slate-900/60 font-mono text-[9px] text-slate-450">
            <label class="block text-slate-500 uppercase tracking-wider">Compliance Declarations:</label>
            
            <label class="flex items-center gap-2.5 p-3 bg-[#030307]/30 border border-slate-900 rounded cursor-pointer select-none">
              <input type="checkbox" name="class1OrAz" id="chk-class1OrAz" class="accent-bro-cyan" />
              <span>Valid Class 1 or AZ Commercial Driver License</span>
            </label>

            <label class="flex items-center gap-2.5 p-3 bg-[#030307]/30 border border-slate-900 rounded cursor-pointer select-none">
              <input type="checkbox" name="hasCleanAbstract" id="chk-hasCleanAbstract" class="accent-bro-cyan" />
              <span>Clean 3-Year Commercial Driver Abstract</span>
            </label>

            <label class="flex items-center gap-2.5 p-3 bg-[#030307]/30 border border-slate-900 rounded cursor-pointer select-none">
              <input type="checkbox" name="safetyCertified" id="chk-safetyCertified" class="accent-bro-cyan" checked />
              <span>Registered safety certified & DOT compliant</span>
            </label>
          </div>
        </div>

        <!-- Cloudflare Challenge -->
        <div class="flex justify-center py-2.5">
          <div id="turnstile-driver-container" class="min-h-[65px]"></div>
        </div>

        <!-- Notice Box -->
        <div id="driver-error-box" class="hidden text-xs text-rose-450 bg-rose-950/20 border border-rose-900/40 p-4 rounded"></div>

        <button type="submit" class="w-full py-3 bg-bro-cyan text-black hover:bg-bro-cyan/90 font-bold rounded font-mono text-xs uppercase tracking-wider transition-colors duration-300 cursor-pointer">
          Submit registration profile
        </button>
      </form>

    </div>
  </section>
</Layout>

<script>
  import { DriverApplicationSchema } from '../lib/schemas';

  const STORAGE_KEY = 'bro_driver_intake_v1';
  let turnstileToken = '';
  let turnstileWidgetId: string | null = null;

  const form = document.getElementById('driver-intake-form') as HTMLFormElement;
  const errorBox = document.getElementById('driver-error-box');

  // Load state on start
  function loadFormState() {
    try {
      const data = sessionStorage.getItem(STORAGE_KEY);
      if (!data) return;
      const parsed = JSON.parse(data);
      if (parsed.driverName) (document.getElementById('input-driverName') as HTMLInputElement).value = parsed.driverName;
      if (parsed.driverPhone) (document.getElementById('input-driverPhone') as HTMLInputElement).value = parsed.driverPhone;
      if (parsed.equipType) (document.getElementById('select-equipType') as HTMLSelectElement).value = parsed.equipType;
      if (parsed.preferredLanes) (document.getElementById('input-preferredLanes') as HTMLInputElement).value = parsed.preferredLanes;
      if (parsed.class1OrAz) (document.getElementById('chk-class1OrAz') as HTMLInputElement).checked = parsed.class1OrAz;
      if (parsed.hasCleanAbstract) (document.getElementById('chk-hasCleanAbstract') as HTMLInputElement).checked = parsed.hasCleanAbstract;
      if (parsed.safetyCertified) (document.getElementById('chk-safetyCertified') as HTMLInputElement).checked = parsed.safetyCertified;
    } catch(e) {}
  }

  // Save state on change
  function saveFormState() {
    const payload = {
      driverName: (document.getElementById('input-driverName') as HTMLInputElement).value,
      driverPhone: (document.getElementById('input-driverPhone') as HTMLInputElement).value,
      equipType: (document.getElementById('select-equipType') as HTMLSelectElement).value,
      preferredLanes: (document.getElementById('input-preferredLanes') as HTMLInputElement).value,
      class1OrAz: (document.getElementById('chk-class1OrAz') as HTMLInputElement).checked,
      hasCleanAbstract: (document.getElementById('chk-hasCleanAbstract') as HTMLInputElement).checked,
      safetyCertified: (document.getElementById('chk-safetyCertified') as HTMLInputElement).checked,
    };
    sessionStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
  }

  if (form) {
    form.addEventListener('input', saveFormState);
    form.addEventListener('submit', handleFormSubmit);
  }

  // Hydrate Turnstile
  function initTurnstile() {
    const container = document.getElementById('turnstile-driver-container');
    if (!container || !(window as any).turnstile || turnstileWidgetId !== null) return;

    turnstileWidgetId = (window as any).turnstile.render(container, {
      sitekey: '0x4AAAAAAA2I6F9JkSivv8tZ',
      callback: function(token: string) {
        turnstileToken = token;
        if (errorBox) errorBox.classList.add('hidden');
      }
    });
  }

  function handleFormSubmit(e: Event) {
    e.preventDefault();
    if (!errorBox) return;

    errorBox.classList.add('hidden');

    const payload = {
      driverName: (document.getElementById('input-driverName') as HTMLInputElement).value,
      driverPhone: (document.getElementById('input-driverPhone') as HTMLInputElement).value,
      equipType: (document.getElementById('select-equipType') as HTMLSelectElement).value,
      preferredLanes: (document.getElementById('input-preferredLanes') as HTMLInputElement).value,
      class1OrAz: (document.getElementById('chk-class1OrAz') as HTMLInputElement).checked,
      hasCleanAbstract: (document.getElementById('chk-hasCleanAbstract') as HTMLInputElement).checked,
      safetyCertified: (document.getElementById('chk-safetyCertified') as HTMLInputElement).checked,
      turnstileToken: turnstileToken
    };

    const validation = DriverApplicationSchema.safeParse(payload);
    if (!validation.success) {
      errorBox.innerHTML = validation.error.errors.map(e => `• ${e.message}`).join('<br/>');
      errorBox.className = 'text-xs text-rose-450 bg-rose-950/20 border border-rose-900/40 p-4 rounded';
      errorBox.classList.remove('hidden');
      return;
    }

    // Submission states
    errorBox.className = 'text-xs text-bro-cyan bg-bro-cyan/10 border border-bro-cyan/30 p-4 rounded animate-pulse';
    errorBox.innerText = "TRANSMITTING ENCRYPTED APPLICATION PROFILE...";
    errorBox.classList.remove('hidden');

    const apiUrl = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? 'http://127.0.0.1:8787/api/drivers'
      : 'https://brotransport-edge-api.keshuin0.workers.dev/api/drivers';

    fetch(apiUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(async (res) => {
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Server rejected application.');
      return data;
    })
    .then((data) => {
      alert(`Application submitted successfully! Intake ID: ${data.intakeId || 'BROP-DRV'}`);
      sessionStorage.removeItem(STORAGE_KEY);
      form.reset();
      errorBox.classList.add('hidden');
      if (turnstileWidgetId !== null && (window as any).turnstile) {
        (window as any).turnstile.reset(turnstileWidgetId);
        turnstileToken = '';
      }
    })
    .catch((err) => {
      errorBox.innerText = `Uplink failed: ${err.message}`;
      errorBox.className = 'text-xs text-rose-450 bg-rose-950/20 border border-rose-900/40 p-4 rounded';
      errorBox.classList.remove('hidden');
    });
  }

  document.addEventListener('astro:page-load', () => {
    loadFormState();
    initTurnstile();
  });
</script>
