<!-- Client Side Interactive Mechanics Script -->
<script>
  import { broAudio } from '../lib/audio';

  // --- TAB HANDLER ---
  function setupTabs() {
    const btns = document.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.tab-panel');
    const loader = document.getElementById('tab-terminal-loader');
    const loaderCmd = document.getElementById('terminal-loader-cmd');
    const loaderBar = document.getElementById('terminal-loader-bar');
    const loaderPct = document.getElementById('terminal-loader-pct');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        const targetBtnName = btn.textContent?.trim() || '';

        // Play navigation sound
        broAudio.playScanlineGlitch();

        // Stop Reefer hum if we leave reefer tab
        if (targetId !== 'tab-reefer') {
          broAudio.stopReeferHum();
        }

        // Hide all panels
        panels.forEach(p => p.classList.add('hidden'));

        // Reset and show loader
        if (loader && loaderCmd && loaderBar && loaderPct) {
          loader.classList.remove('hidden');
          loaderCmd.innerText = `> UPLINKING ${targetBtnName.split(' // ')[1]} DATA...`;
          
          let progress = 0;
          loaderBar.style.width = '0%';
          loaderPct.innerText = '0%';

          const interval = setInterval(() => {
            progress += Math.floor(Math.random() * 25) + 15;
            if (progress >= 100) {
              progress = 100;
              clearInterval(interval);
            }
            loaderBar.style.width = `${progress}%`;
            loaderPct.innerText = `${progress}%`;
          }, 60);

          setTimeout(() => {
            clearInterval(interval);
            loader.classList.add('hidden');
            
            // Show target panel
            const targetPanel = document.getElementById(targetId);
            if (targetPanel) {
              targetPanel.classList.remove('hidden');
              // Start hum if we enter Reefer tab
              if (targetId === 'tab-reefer') {
                broAudio.startReeferHum();
                const reeferSlider = document.getElementById('reefer-slider') as HTMLInputElement | null;
                if (reeferSlider) {
                  broAudio.updateReeferHum(parseFloat(reeferSlider.value));
                }
              }
            }
          }, 450);
        } else {
          // Fallback
          const targetPanel = document.getElementById(targetId);
          if (targetPanel) {
            targetPanel.classList.remove('hidden');
            if (targetId === 'tab-reefer') {
              broAudio.startReeferHum();
            }
          }
        }

        // Toggle active classes
        btns.forEach(b => {
          b.classList.remove('active', 'border-cyan-500/40', 'bg-cyan-950/20', 'text-white');
          b.classList.add('border-slate-900', 'text-slate-500');
        });
        btn.classList.add('active', 'border-cyan-500/40', 'bg-cyan-950/20', 'text-white');
        btn.classList.remove('border-slate-900', 'text-slate-500');
      });
    });
  }

  // --- VOLUMETRIC DRY VAN CARGO SIMULATOR ---
  function setupDryVanSimulator() {
    const slider = document.getElementById('dry-van-slider') as HTMLInputElement | null;
    const countLabel = document.getElementById('dry-van-count-label');
    const fillVal = document.getElementById('dry-van-fill-val');
    const axleVal = document.getElementById('dry-van-axle-val');
    const weightVal = document.getElementById('dry-van-weight-val');
    const gridContainer = document.getElementById('pallet-grid-container');

    if (!slider || !gridContainer) return;

    // Generate 26 Pallet Slot Elements in the DOM
    gridContainer.innerHTML = '';
    const slots: HTMLDivElement[] = [];
    for (let i = 0; i < 26; i++) {
      const cell = document.createElement('div');
      cell.className = 'aspect-square bg-slate-950 border border-slate-900 rounded-sm flex items-center justify-center text-[7px] font-mono text-slate-800 transition-all select-none duration-250';
      cell.innerText = `${i+1}`;
      gridContainer.appendChild(cell);
      slots.push(cell);
    }

    const updateGrid = () => {
      const val = parseInt(slider.value) || 0;

      // Update values
      if (countLabel) countLabel.innerText = `${val} Pallet${val !== 1 ? 's' : ''}`;
      
      const fillPercent = ((val / 26) * 100).toFixed(1);
      if (fillVal) fillVal.innerText = `${fillPercent}%`;

      const estWeight = val * 1750; // average weight of commercial pallets
      if (weightVal) weightVal.innerText = `${estWeight.toLocaleString()} LBS`;

      // Axle compliance rules
      if (axleVal) {
        if (val > 24) {
          axleVal.innerText = 'OVERLOAD WARN';
          axleVal.className = 'block text-[#ff6000] font-bold animate-pulse';
        } else if (val > 18) {
          axleVal.innerText = 'HEAVY';
          axleVal.className = 'block text-yellow-500 font-bold';
        } else {
          axleVal.innerText = 'OPTIMAL';
          axleVal.className = 'block text-cyan-400 font-bold';
        }
      }

      // Highlight active pallets
      slots.forEach((slot, index) => {
        if (index < val) {
          slot.className = 'aspect-square bg-cyan-950/80 border border-cyan-400/80 rounded-sm flex items-center justify-center text-[7px] font-mono text-cyan-300 shadow-[0_0_4px_rgba(0,240,255,0.2)]';
        } else {
          slot.className = 'aspect-square bg-slate-950 border border-slate-900 rounded-sm flex items-center justify-center text-[7px] font-mono text-slate-800';
        }
      });
    };

    slider.addEventListener('input', () => {
      updateGrid();
      broAudio.playTabClick();
    });

    updateGrid();
  }

  // --- REEFER TEMPERATURE & LIVE WAVE GRAPH ---
  function setupReeferSimulator() {
    const slider = document.getElementById('reefer-slider') as HTMLInputElement | null;
    const tempLabel = document.getElementById('reefer-temp-label');
    const powerVal = document.getElementById('reefer-power-val');
    const codeVal = document.getElementById('reefer-code-val');
    const currentVal = document.getElementById('reefer-current-val');
    const warningLabel = document.getElementById('reefer-warning');
    const wavePath = document.getElementById('thermograph-wave');
    const targetLine = document.getElementById('thermograph-target');

    if (!slider || !wavePath) return;

    let animFrameId: number;
    let time = 0;

    const animateWave = () => {
      time += 0.05;
      const targetTemp = parseFloat(slider.value) || -18;
      
      // Determine wave frequency and height based on thermostat load
      // Colder temperature means compressor is running faster -> higher frequency wave
      const tempRatio = (targetTemp + 20) / 35; // 0 (coldest) to 1 (warmest)
      const freqMultiplier = 3.5 - tempRatio * 2.5; // faster waves at cold
      const waveAmp = 15 + tempRatio * 15; // larger amplitude at warm/unstable

      let pathStr = 'M 0 60';
      for (let x = 0; x <= 400; x += 10) {
        const y = 60 + Math.sin(x * 0.05 * freqMultiplier + time) * waveAmp;
        pathStr += ` L ${x} ${y}`;
      }
      wavePath.setAttribute('d', pathStr);

      // Slide target dotted line up and down (Y: 20 to 100)
      // -20C maps to Y=30, +15C maps to Y=105
      const targetY = 30 + ((targetTemp + 20) / 35) * 75;
      if (targetLine) {
        targetLine.setAttribute('d', `M 0 ${targetY} L 400 ${targetY}`);
      }

      // Check for heat breach warning (above +4°C)
      if (warningLabel) {
        if (targetTemp > 4) {
          warningLabel.innerText = 'WARNING // TEMP BREACH';
          warningLabel.className = 'text-[#ff6000] font-bold animate-[pulse_1s_infinite]';
          wavePath.setAttribute('stroke', '#ff6000');
          // Occasionally play warning chime
          if (Math.random() > 0.98) {
            broAudio.playWarningChime();
          }
        } else {
          warningLabel.innerText = '// SYSTEM STABLE';
          warningLabel.className = 'text-emerald-500 font-bold';
          wavePath.setAttribute('stroke', '#00f0ff');
        }
      }

      animFrameId = requestAnimationFrame(animateWave);
    };

    const updateControls = () => {
      const val = parseFloat(slider.value) || -18;
      if (tempLabel) tempLabel.innerText = `${val.toFixed(1)}°C`;
      
      // Update simulated live readout
      if (currentVal) {
        const jitter = (Math.sin(Date.now() / 1000) * 0.2);
        currentVal.innerText = `${(val + jitter).toFixed(1)}°C`;
      }

      // Update power draw descriptions
      if (powerVal && codeVal) {
        if (val < -15) {
          powerVal.innerText = 'MAX COOLING';
          codeVal.innerText = 'FREEZER_ZONE_ACTV';
        } else if (val < 0) {
          powerVal.innerText = 'STANDARD CYCLE';
          codeVal.innerText = 'COLD_CHAIN_OK';
        } else {
          powerVal.innerText = 'MINIMUM DRAW';
          codeVal.innerText = 'AMBIENT_AIR_MODE';
        }
      }

      broAudio.updateReeferHum(val);
    };

    slider.addEventListener('input', () => {
      updateControls();
      broAudio.playTabClick();
    });

    // Start wave animation loop
    animateWave();
    updateControls();
  }

  // --- FLATBED BENDING BLUEPRINT SIMULATOR ---
  function setupFlatbedSimulator() {
    const slider = document.getElementById('flatbed-slider') as HTMLInputElement | null;
    const cogLabel = document.getElementById('flatbed-cog-label');
    const flexVal = document.getElementById('flatbed-flex-val');
    const ratioVal = document.getElementById('flatbed-ratio-val');
    const warningLabel = document.getElementById('flatbed-warning');
    const framePath = document.getElementById('flatbed-frame-path');
    const cargoBlock = document.getElementById('flatbed-cargo-block');
    const arrow = document.getElementById('vector-arrow');

    if (!slider || !framePath || !cargoBlock || !arrow) return;

    const updateFlatbed = () => {
      const val = parseInt(slider.value) || 50;

      // Update labels
      if (cogLabel) cogLabel.innerText = `${val}% (${val < 45 ? 'Front Loaded' : val > 55 ? 'Rear Loaded' : 'Centered'})`;

      // Flex amount is greatest at center (50%), minimal at axle bounds
      const distFromCenter = Math.abs(50 - val); // 0 to 40
      const flexAmount = Math.max(0.2, (4.5 - (distFromCenter * 0.1))).toFixed(1);
      if (flexVal) flexVal.innerText = `${flexAmount} MM`;

      // Axle weight ratio
      const frontWeight = (100 - val);
      const rearWeight = val;
      if (ratioVal) ratioVal.innerText = `${frontWeight} / ${rearWeight}`;

      // Bending frame path: Q point sits at (210, 80 + dynamic bend)
      // Frame ends at x=70 (tractor cabin link) and x=350 (rear axles)
      const bendFactor = (5 - (distFromCenter * 0.12)) * 2;
      framePath.setAttribute('d', `M 70 80 Q 210 ${80 + bendFactor} 350 80`);

      // Slide cargo box along flatbed frame (x: 100 to 300)
      // maps to slider input (10 to 90)
      const cargoX = 80 + (val / 100) * 230;
      // Adjust cargo Y position to match the frame bend curve
      const ratio = (val - 10) / 80; // 0 to 1
      const curveY = 80 + (bendFactor * 4 * ratio * (1 - ratio)) - 35;
      
      cargoBlock.setAttribute('x', cargoX.toString());
      cargoBlock.setAttribute('y', curveY.toString());

      // Move vector arrow to sit above the cargo box
      arrow.setAttribute('d', `M ${cargoX + 20} ${curveY - 25} L ${cargoX + 20} ${curveY - 5} M ${cargoX + 15} ${curveY - 10} L ${cargoX + 20} ${curveY - 5} L ${cargoX + 25} ${curveY - 10}`);

      // Stress compliance warnings
      if (warningLabel) {
        if (val < 25 || val > 75) {
          warningLabel.innerText = 'WARNING // IMBALANCED LOAD';
          warningLabel.className = 'text-[#ff6000] font-bold animate-pulse';
          framePath.setAttribute('stroke', '#ff6000');
        } else {
          warningLabel.innerText = '// STRESS NORMAL';
          warningLabel.className = 'text-emerald-500 font-bold';
          framePath.setAttribute('stroke', '#00f0ff');
        }
      }
    };

    slider.addEventListener('input', () => {
      updateFlatbed();
      broAudio.playTabClick();
    });

    updateFlatbed();
  }

  // --- INTERACTIVE COMMAND DISPATCH CONSOLE ---
  function setupCommandLineConsole() {
    const inputEl = document.getElementById('telemetry-input') as HTMLInputElement | null;
    const panel = document.getElementById('telemetry-output-panel');

    if (!inputEl || !panel) return;

    let isTyping = false;

    const executeCommand = () => {
      if (isTyping) return;
      const rawCmd = inputEl.value.trim().toLowerCase();
      if (!rawCmd) return;

      inputEl.value = '';
      broAudio.playTabClick();

      // Print prompt line
      const promptDiv = document.createElement('div');
      promptDiv.className = 'text-white font-bold mt-2';
      promptDiv.innerText = `> ${rawCmd.toUpperCase()}`;
      panel.appendChild(promptDiv);

      let lines: string[] = [];

      switch (rawCmd) {
        case 'help':
          lines = [
            'AVAILABLE UPLINK DIRECTIVES:',
            '------------------------------------------',
            'status      - Get active manifest load telemetry',
            'route       - Get current transit corridor coordinates',
            'compressor  - Get temperature cooling cycles log',
            'systems     - Check chassis structural compliance',
            'clear       - Clear active console logs'
          ];
          break;
        case 'status':
          lines = [
            'UPLINK: CONNECTED [SECURE]',
            'ACTIVE LOAD: GENERAL INDUSTRIAL FREIGHT (DRY VAN)',
            'TRAILER ID: BRO-1044 // TANDEM SLIDE CONF',
            'TOTAL WEIGHT: 42,500 LBS [LEGAL LIMIT COMPLIANT]',
            'VELOCITY: 85 KM/H | FUEL STATUS: 92%',
            'MANIFEST STATUS: ACE APPROVED // CLEAR FOR CROSSING'
          ];
          break;
        case 'route':
          lines = [
            'ACTIVE LINK: SATELLITE ROAD MAPPING [KA BAND]',
            'PEI HQ DEPARTURE CLEARANCE: OK',
            'CURRENT TELEMETRY COORDS: 44.2706° N, 79.9048° W',
            'REGION: ONTARIO COMMERCIAL CORRIDOR',
            'APPROACHING HUB: TRANS-SHIPMENT GATEWAY 02',
            'WEATHER STATE: OPTIMAL LANE CONTROLS'
          ];
          break;
        case 'compressor':
          lines = [
            'TELEMETRY SOURCE: REEFER TRAILER BRO-2088',
            'COMPRESSOR MOTOR Hum: ACTIVE [Thermo King S-600]',
            'TARGET SETPOINT: -18.0°C | CURRENT SENSED: -17.8°C',
            'COOLING STATE: STEADY-STATE RECIRCULATION',
            'CHAMBER SENSORS: 4/4 CALIBRATED AND VERIFIED',
            'COLD-CHAIN INTEGRITY: 100% SECURE'
          ];
          break;
        case 'systems':
          lines = [
            'DIAGNOSTIC SCAN: CHASSIS STRESS SCANNER',
            'FLATBED DECK DEFL: 1.2 MM [STRUCTURAL FLEX NORMAL]',
            'LASER SECUREMENT RATIO: 8,500 LBS FORCE [SECURED]',
            'CHASSIS STRESS COEFFICIENT: 0.12 [SAFE OPERATION]',
            'ABS BRAKE PRESSURE: 110 PSI // COMPLIANT',
            'SYSTEM DIAGNOSTIC CODE: 0x00 // SUCCESS'
          ];
          break;
        case 'clear':
          panel.innerHTML = '<div>&gt; TERMINAL READY. TYPE \'help\' FOR LIST OF SYSTEM DIRECTIVES.</div>';
          return;
        default:
          lines = [
            `ERROR: DIRECTIVE '${rawCmd.toUpperCase()}' NOT RECOGNIZED.`,
            'TYPE \'help\' TO SEE THE SYSTEM COMMAND MANIFEST.'
          ];
          break;
      }

      isTyping = true;
      let lineIndex = 0;
      const printLine = () => {
        if (lineIndex < lines.length) {
          const p = document.createElement('div');
          p.innerText = lines[lineIndex];

          if (lines[lineIndex].startsWith('ERROR') || lines[lineIndex].startsWith('SYS_WARNING')) {
            p.className = 'text-rose-400 font-bold';
            broAudio.playWarningChime();
          } else if (lines[lineIndex].startsWith('AVAILABLE') || lines[lineIndex].startsWith('ACTIVE') || lines[lineIndex].startsWith('TARGET')) {
            p.className = 'text-[#00f0ff]';
          } else if (lines[lineIndex].startsWith('---') || lines[lineIndex].startsWith('UPLINK') || lines[lineIndex].startsWith('TELEMETRY')) {
            p.className = 'text-slate-500';
          } else {
            p.className = 'text-slate-350';
          }

          panel.appendChild(p);
          panel.scrollTop = panel.scrollHeight;

          broAudio.playTerminalType();
          lineIndex++;
          setTimeout(printLine, 80);
        } else {
          isTyping = false;
        }
      };

      printLine();
    };

    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        executeCommand();
      }
    });
  }

  // Compatible with ClientRouter transitions
  document.addEventListener('astro:page-load', () => {
    setupTabs();
    setupDryVanSimulator();
    setupReeferSimulator();
    setupFlatbedSimulator();
    setupCommandLineConsole();
  });
</script>
