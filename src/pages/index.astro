---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CorridorMap from '../components/CorridorMap.astro';
import LidarTracker from '../components/LidarTracker.astro';

const fleetItems = await getCollection('fleet');
const base = import.meta.env.BASE_URL;

// Helper to resolve high-fidelity asset images dynamically by ID
const getFleetImage = (id: string) => {
  if (id === '13-axle-combo') return `${base}images/13-axle-combo.png?v=4`;
  if (id === 'extendable-rgn') return `${base}images/rgn-lowboy.png?v=4`;
  if (id === 'mack-titan') return `${base}images/mack-titan.png?v=4`;
  return `${base}images/hero-truck.png?v=4`;
};
---

<Layout>
  <!-- Navigation -->
  <header class="sticky top-0 z-50 backdrop-blur-md bg-[#05070D]/85 border-b border-slate-900" style="view-transition-name: main-header;">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href={base} class="flex items-center gap-2 group">
        <div class="h-3 w-3 bg-blue-500 rounded-full animate-pulse shadow-[0_0_8px_#3b82f6] group-hover:bg-blue-400 transition-colors shrink-0"></div>
        <img src={`${base}images/logo.jpg?v=3`} alt="#BRO TRANSPORT" class="h-12 sm:h-14 w-auto object-contain transition-opacity group-hover:opacity-90" />
      </a>
      
      <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold text-slate-300">
        <a href="#divisions" class="hover:text-blue-400 transition-colors">Operations</a>
        <a href="#fleet" class="hover:text-blue-400 transition-colors">Fleet Specs</a>
        <a href="#corridors" class="hover:text-blue-400 transition-colors">Transit Corridors</a>
        <a href="#radar" class="hover:text-blue-400 transition-colors">LiDAR Tech Hub</a>
        <a href={`${base}quote`} data-astro-prefetch class="hover:text-blue-400 transition-colors">Quote Engine</a>
        <a href={`${base}drivers`} data-astro-prefetch class="hover:text-blue-400 transition-colors">Driver Portal</a>
      </nav>

      <div class="flex items-center gap-4">
        <a href="tel:902-916-6936" class="hidden sm:inline-flex bg-blue-500/10 border border-blue-500/30 hover:border-blue-500 hover:bg-blue-500 hover:text-white transition-all duration-300 text-blue-400 text-xs font-semibold px-4 py-2 rounded-md items-center gap-2">
          <span>Call Desk: 902-916-6936</span>
        </a>
      </div>
    </div>
  </header>

  <Hero />

  <!-- Live Operational Metrics Dashboard Banner -->
  <section class="border-y border-slate-900 bg-[#080B13] relative z-20">
    <div class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="text-center md:text-left space-y-1">
        <div class="text-3xl font-black font-outfit text-white tracking-tight glow-text-blue">35+ YEARS</div>
        <div class="text-[10px] font-mono uppercase tracking-widest text-slate-500">Specialized Logistics Trust</div>
      </div>
      <div class="text-center md:text-left space-y-1 border-l border-slate-900 pl-0 md:pl-8">
        <div class="text-3xl font-black font-outfit text-white tracking-tight glow-text-blue">99.8%</div>
        <div class="text-[10px] font-mono uppercase tracking-widest text-slate-500">On-Time Transit Rating</div>
      </div>
      <div class="text-center md:text-left space-y-1 border-l border-slate-900 pl-0 md:pl-8">
        <div class="text-3xl font-black font-outfit text-amber-500 tracking-tight glow-text-amber">100% COR</div>
        <div class="text-[10px] font-mono uppercase tracking-widest text-slate-500">Safety Certified / DOT Compliant</div>
      </div>
      <div class="text-center md:text-left space-y-1 border-l border-slate-900 pl-0 md:pl-8">
        <div class="text-3xl font-black font-outfit text-emerald-500 tracking-tight glow-text-emerald">24/7 CMD</div>
        <div class="text-[10px] font-mono uppercase tracking-widest text-slate-500">Live Dispatch Desk</div>
      </div>
    </div>
  </section>

  <!-- Interactive Operations Divisions Section -->
  <section id="divisions" class="py-24 px-6 max-w-7xl mx-auto space-y-16">
    <div class="text-center space-y-4">
      <span class="text-xs font-mono uppercase tracking-widest text-blue-500 font-bold">[SYS_DIVISIONS_MANAGEMENT]</span>
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-white font-outfit uppercase">Our Core Operations Suite</h2>
      <p class="text-slate-400 max-w-xl mx-auto text-sm">Industrial-grade dispatch structures separating commercial, specialized, and customs clearances.</p>
    </div>

    <!-- Interactive Tabs Component -->
    <div class="max-w-4xl mx-auto space-y-8" id="operations-tabs-container">
      <!-- Tabs Navigation -->
      <div class="flex flex-col sm:flex-row gap-2 border-b border-slate-900 pb-2">
        <button class="flex-1 text-center py-4 px-3 rounded font-mono text-xs uppercase tracking-wider font-bold border border-blue-500/40 bg-blue-950/20 text-white transition-all duration-300 tab-btn active" data-target="tab-heavy">
          DIV_01 // SPECIALIZED HEAVY-HAUL
        </button>
        <button class="flex-1 text-center py-4 px-3 rounded font-mono text-xs uppercase tracking-wider font-bold border border-slate-900 text-slate-500 hover:text-slate-300 transition-all duration-300 tab-btn" data-target="tab-permits">
          DIV_02 // PERMITS & ESCORTS
        </button>
        <button class="flex-1 text-center py-4 px-3 rounded font-mono text-xs uppercase tracking-wider font-bold border border-slate-900 text-slate-500 hover:text-slate-300 transition-all duration-300 tab-btn" data-target="tab-customs">
          DIV_03 // CUSTOMS eMANIFEST
        </button>
      </div>

      <!-- Tabs Contents -->
      <div class="space-y-6">
        <!-- Tab 1: Heavy Haul -->
        <div class="tab-panel space-y-6" id="tab-heavy">
          <div class="bg-[#0B0F19]/50 border border-slate-900 p-8 rounded-lg grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-4">
              <h3 class="text-2xl font-bold text-white font-outfit uppercase tracking-wide">Division 01 // Specialized Heavy-Haul</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Coordinating high-capacity overweight and oversized superloads across regional corridors. We manage structural clearance evaluations, highway height limitations, and bridge weight tolerances beforehand.
              </p>
              <ul class="space-y-2 text-xs font-mono text-slate-400 pt-2">
                <li class="flex items-center gap-2 text-blue-400"><span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span> 13-axle combi & RGN float allocation</li>
                <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span> Provincial and State oversize permits</li>
                <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span> Escort pilot car coordination</li>
              </ul>
            </div>
            <div class="rounded-lg overflow-hidden border border-slate-900/60 relative h-60 md:h-auto">
              <img src={`${base}images/hero-truck.png`} alt="Heavy Haul trailer" class="w-full h-full object-cover" />
            </div>
          </div>
        </div>

        <!-- Tab 2: Permits & Escorts -->
        <div class="tab-panel space-y-6 hidden" id="tab-permits">
          <div class="bg-[#0B0F19]/50 border border-slate-900 p-8 rounded-lg grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-4">
              <h3 class="text-2xl font-bold text-white font-outfit uppercase tracking-wide">Division 02 // Oversized Permits & Escorts</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Permitted and synchronized route dispatch. We manage multi-jurisdictional oversized load permits, organize police escorts, and verify bridge clearances for heavy machinery across municipal and provincial corridors.
              </p>
              <ul class="space-y-2 text-xs font-mono text-slate-400 pt-2">
                <li class="flex items-center gap-2 text-amber-500"><span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span> Multi-province oversized permit coordination</li>
                <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span> Route clearance and utility company escorts</li>
                <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span> Safety-certified (COR / OSHA) commercial drivers</li>
              </ul>
            </div>
            <div class="rounded-lg overflow-hidden border border-slate-900/60 relative h-60 md:h-auto">
              <img src={`${base}images/mack-titan.png`} alt="Mack Titan heavy haul" class="w-full h-full object-cover" />
            </div>
          </div>
        </div>

        <!-- Tab 3: Customs -->
        <div class="tab-panel space-y-6 hidden" id="tab-customs">
          <div class="bg-[#0B0F19]/50 border border-slate-900 p-8 rounded-lg grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-4">
              <h3 class="text-2xl font-bold text-white font-outfit uppercase tracking-wide">Division 03 // Cross-Border Customs</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Streamlined border crossings between Canada and the United States. We handle the digital transmission of ACE eManifests (US Customs) and ACI eManifests (Canada Customs) to prevent corridor delays.
              </p>
              <ul class="space-y-2 text-xs font-mono text-slate-400 pt-2">
                <li class="flex items-center gap-2 text-purple-400"><span class="h-1.5 w-1.5 rounded-full bg-purple-500"></span> ACE & ACI eManifest electronic filing</li>
                <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-purple-500"></span> PARS & PAPS digital tracking</li>
                <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-purple-500"></span> Fast-lane customs priority integration</li>
              </ul>
            </div>
            <div class="rounded-lg overflow-hidden border border-slate-900/60 relative h-60 md:h-auto">
              <img src={`${base}images/hero-truck.png`} alt="Cross-border cargo" class="w-full h-full object-cover" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive LiDAR Tech Hub Section -->
  <section id="radar" class="py-24 bg-[#080B13] border-y border-slate-950 px-6">
    <div class="max-w-7xl mx-auto space-y-12">
      <div class="text-center space-y-4">
        <span class="text-xs font-mono uppercase tracking-widest text-blue-500 font-bold">[RADAR_LINK_ESTABLISHED]</span>
        <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-white font-outfit uppercase">LiDAR Dispatch Tech Hub</h2>
        <p class="text-slate-400 max-w-xl mx-auto text-sm">Review real-time off-thread WebGL simulation showing active convoy LiDAR coordinate sweeps.</p>
      </div>

      <div class="max-w-5xl mx-auto">
        <LidarTracker />
      </div>
    </div>
  </section>

  <!-- Fleet Showcase Section (With High-Fidelity Imagery) -->
  <section id="fleet" class="py-24 px-6 max-w-7xl mx-auto space-y-16">
    <div class="text-center space-y-4">
      <span class="text-xs font-mono uppercase tracking-widest text-blue-500 font-bold">[SYS_ASSETS_SPECIFICATION]</span>
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-white font-outfit uppercase">Engineered Fleet Capabilities</h2>
      <p class="text-slate-400 max-w-xl mx-auto text-sm">Oversized and specialized industrial transport equipment specifications with active load capacities.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {fleetItems.map((item) => (
        <div class="bg-[#0B0F19]/60 rounded-lg border border-slate-900 overflow-hidden flex flex-col group hover:border-blue-500/35 hover:-translate-y-1 transition-all duration-300 shadow-xl">
          <!-- High-Fidelity Render Image -->
          <div class="h-48 overflow-hidden relative border-b border-slate-900">
            <img 
              src={getFleetImage(item.id)} 
              alt={item.data.title} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
            />
            <div class="absolute top-4 right-4 bg-slate-950/80 px-2 py-1 border border-slate-800 rounded text-[9px] font-mono text-blue-400 font-bold uppercase tracking-widest">
              {item.data.superloadSpec ? "Superload Spec" : "Heavy Spec"}
            </div>
          </div>
          
          <div class="p-6 flex-1 flex flex-col justify-between space-y-6">
            <div class="space-y-3">
              <h3 class="text-xl font-bold text-white font-outfit tracking-wide uppercase">{item.data.title}</h3>
              <p class="text-slate-400 text-xs leading-relaxed">
                {item.body}
              </p>
            </div>
            
            <div class="space-y-4 pt-4 border-t border-slate-900/60">
              <div class="grid grid-cols-2 gap-2 text-[10px] font-mono">
                <div>
                  <span class="text-slate-500 block">MAX CAPACITY:</span>
                  <span class="text-slate-300 font-bold">{item.data.capacityTonnage} Tons</span>
                </div>
                <div>
                  <span class="text-slate-500 block">AXLE LAYOUT:</span>
                  <span class="text-slate-300 font-bold">{item.data.axleConfiguration}</span>
                </div>
              </div>
              
              {item.data.equipmentSpecs && (
                <div class="space-y-1.5">
                  <span class="text-[10px] font-mono text-slate-500 block uppercase">Operational Features:</span>
                  <ul class="list-disc pl-4 text-[10px] text-slate-400 space-y-1 font-mono">
                    {item.data.equipmentSpecs.map((spec) => (
                      <li>{spec}</li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Live Transit Corridors Map Section -->
  <section id="corridors" class="py-24 bg-[#080B13] border-y border-slate-950 px-6">
    <div class="max-w-7xl mx-auto space-y-12">
      <div class="text-center space-y-4">
        <span class="text-xs font-mono uppercase tracking-widest text-blue-500 font-bold">[LIVE_RADAR_TRANSIT]</span>
        <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-white font-outfit uppercase">Live Transit Corridors</h2>
        <p class="text-slate-400 max-w-xl mx-auto text-sm">Oversized corridor overview showing major hubs in Prince Edward Island, Ontario, and Alberta.</p>
      </div>
      
      <div class="max-w-5xl mx-auto">
        <CorridorMap />
      </div>
    </div>
  </section>

  <!-- Client Trust & Endorsements Section -->
  <section class="py-24 px-6 max-w-7xl mx-auto space-y-16">
    <div class="text-center space-y-4">
      <span class="text-xs font-mono uppercase tracking-widest text-blue-500 font-bold">[SECURE_TESTIMONIALS]</span>
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-white font-outfit uppercase">Endorsed Operations</h2>
      <p class="text-slate-400 max-w-xl mx-auto text-sm">Verified testimonials from industrial coordinators and regional transit supervisors.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <div class="bg-[#0B0F19]/50 border border-slate-900 p-8 rounded-lg relative overflow-hidden font-mono text-xs text-slate-400 space-y-4">
        <div class="absolute top-0 right-0 w-20 h-20 bg-blue-500/5 rounded-full blur-2xl"></div>
        <p class="italic leading-relaxed text-slate-300">
          "#BRO Transport coordinated the relocation of our heavy power generator equipment to the Alberta hub. Outstanding permit management and zero corridor delay clearance. They are our go-to superload carrier."
        </p>
        <div class="pt-4 border-t border-slate-900/60 flex items-center justify-between">
          <div>
            <span class="text-white font-bold block">Logistics Manager</span>
            <span class="text-slate-500 text-[10px]">Industrial Power Equipment OEM</span>
          </div>
          <span class="text-blue-500 font-bold">// VERIFIED</span>
        </div>
      </div>

      <div class="bg-[#0B0F19]/50 border border-slate-900 p-8 rounded-lg relative overflow-hidden font-mono text-xs text-slate-400 space-y-4">
        <div class="absolute top-0 right-0 w-20 h-20 bg-amber-500/5 rounded-full blur-2xl"></div>
        <p class="italic leading-relaxed text-slate-300">
          "Oversized permit compliance is non-negotiable for our operations. #BRO's drivers arrived fully certified, route logs synced, and executed complex industrial site transits with absolute precision."
        </p>
        <div class="pt-4 border-t border-slate-900/60 flex items-center justify-between">
          <div>
            <span class="text-white font-bold block">Senior Project Manager</span>
            <span class="text-slate-500 text-[10px]">Global Infrastructure Partners</span>
          </div>
          <span class="text-amber-500 font-bold">// SECURE</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Freight Quote Engine Promotion Section -->
  <section id="quote" class="py-24 px-6 bg-[#080B13] border-t border-slate-950">
    <div class="max-w-4xl mx-auto space-y-8 text-center">
      <div class="space-y-4">
        <span class="inline-flex items-center gap-2 text-xs uppercase tracking-widest text-blue-400 font-bold px-3 py-1 bg-blue-500/10 rounded-full border border-blue-500/20">
          Integrated Dispatch Systems
        </span>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white font-outfit uppercase">Launch Procurement Engine</h2>
        <p class="text-slate-400 text-sm sm:text-base max-w-xl mx-auto leading-relaxed">
          Need a heavy-haul quote? Evaluate corridor constraints, height limits, and weight tolerances to allocate standard, RGN, or 13-axle combinations dynamically.
        </p>
      </div>

      <div class="pt-4">
        <a href={`${base}quote`} data-astro-prefetch class="inline-flex bg-blue-600 hover:bg-blue-500 border border-blue-500/30 text-white px-8 py-4 rounded-md font-semibold text-sm transition-all duration-300 shadow-lg shadow-blue-600/20 transform hover:-translate-y-0.5">
          Open Procurement Console
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-16 border-t border-slate-900 bg-[#05070D] text-center space-y-6">
    <div class="flex flex-col items-center justify-center space-y-2">
      <span class="text-sm font-bold text-white font-outfit tracking-wider">#BRO TRANSPORT CORP.</span>
      <p class="text-xs text-slate-500 max-w-md mx-auto leading-relaxed">Prince Edward Island, Canada. Operating high-stakes industrial relocation and cross-border commercial heavy-haul networks.</p>
    </div>
    
    <div class="flex flex-wrap items-center justify-center gap-6 text-[10px] font-mono text-slate-600">
      <span>COR SAFETY ID: 025684</span>
      <span>DOT REGISTRATION ID: A401-PEI</span>
      <span>PWA ONLINE MODE: CACHED</span>
    </div>
    
    <p class="text-[10px] text-slate-700 pt-4">© 2026 #BRO Transport Corp. All rights reserved. Built with zero-bloat static architecture.</p>
  </footer>
</Layout>

<!-- Client Side Tabs Handler -->
<script>
  function setupTabs() {
    const btns = document.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.tab-panel');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Remove active state
        btns.forEach(b => {
          b.classList.remove('active', 'border-blue-500/40', 'bg-blue-950/20', 'text-white');
          b.classList.add('border-slate-900', 'text-slate-500');
        });
        panels.forEach(p => p.classList.add('hidden'));

        // Add active state to clicked
        btn.classList.add('active', 'border-blue-500/40', 'bg-blue-950/20', 'text-white');
        btn.classList.remove('border-slate-900', 'text-slate-500');
        
        const targetId = btn.getAttribute('data-target');
        const targetPanel = document.getElementById(targetId);
        if (targetPanel) {
          targetPanel.classList.remove('hidden');
        }
      });
    });
  }

  // Compatible with ClientRouter transitions
  document.addEventListener('astro:page-load', setupTabs);
</script>
