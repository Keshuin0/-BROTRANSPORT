---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CorridorMap from '../components/CorridorMap.astro';

const fleetItems = await getCollection('fleet');
const base = import.meta.env.BASE_URL;

// Helper to resolve images dynamically
const getFleetImage = (id: string) => {
  if (id === 'dry-van') return `${base}images/hero-truck.png?v=4`;
  if (id === 'reefer') return `${base}images/rgn-lowboy.png?v=4`;
  if (id === 'flatbed') return `${base}images/mack-titan.png?v=4`;
  return `${base}images/hero-truck.png?v=4`;
};
---

<Layout>
  <!-- Navigation -->
  <header class="sticky top-0 z-50 backdrop-blur-md bg-[#020408]/85 border-b border-slate-900" style="view-transition-name: main-header;">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href={base} class="flex items-center gap-2 group">
        <div class="h-3 w-3 bg-[#00f0ff] rounded-full animate-pulse shadow-[0_0_8px_#00f0ff] group-hover:bg-cyan-400 transition-colors shrink-0"></div>
        <img src={`${base}images/logo.jpg?v=3`} alt="#BRO TRANSPORT" class="h-12 sm:h-14 w-auto object-contain transition-opacity group-hover:opacity-90" />
      </a>
      
      <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold text-slate-350">
        <a href="#divisions" class="hover:text-[#00f0ff] transition-colors">Operations</a>
        <a href="#fleet" class="hover:text-[#00f0ff] transition-colors">Fleet Specs</a>
        <a href="#corridors" class="hover:text-[#00f0ff] transition-colors">Transit Routes</a>
        <a href={`${base}quote`} data-astro-prefetch class="hover:text-[#00f0ff] transition-colors">Quote Engine</a>
        <a href={`${base}drivers`} data-astro-prefetch class="hover:text-[#00f0ff] transition-colors">Driver Portal</a>
        <a href={`${base}Disruptive-Trucking-Website-Master-Roadmap.pdf`} target="_blank" class="hover:text-[#ff6000] transition-colors font-bold text-[#ff6000] font-mono">[RESEARCH_PDF]</a>
      </nav>

      <div class="flex items-center gap-4">
        <a href="tel:902-916-6936" class="hidden sm:inline-flex bg-cyan-500/10 border border-cyan-500/30 hover:border-[#00f0ff] hover:bg-[#00f0ff] hover:text-black transition-all duration-300 text-[#00f0ff] text-xs font-semibold px-4 py-2 rounded-md items-center gap-2">
          <span>Call Desk: 902-916-6936</span>
        </a>
      </div>
    </div>
  </header>

  <Hero />

  <!-- Live Operational Metrics Dashboard Banner -->
  <section class="border-y border-slate-900 bg-[#05070d] relative z-20">
    <div class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="text-center md:text-left space-y-1">
        <div class="text-3xl font-black font-outfit text-white tracking-tight glow-text-cyan">35+ YEARS</div>
        <div class="text-[10px] font-mono uppercase tracking-widest text-slate-500">Commercial Shipping Trust</div>
      </div>
      <div class="text-center md:text-left space-y-1 border-l border-slate-900 pl-0 md:pl-8">
        <div class="text-3xl font-black font-outfit text-white tracking-tight glow-text-cyan">99.8%</div>
        <div class="text-[10px] font-mono uppercase tracking-widest text-slate-500">On-Time Delivery Rating</div>
      </div>
      <div class="text-center md:text-left space-y-1 border-l border-slate-900 pl-0 md:pl-8">
        <div class="text-3xl font-black font-outfit text-[#ff6000] tracking-tight glow-text-blaze">100% COR</div>
        <div class="text-[10px] font-mono uppercase tracking-widest text-slate-500">Safety Certified / DOT Compliant</div>
      </div>
      <div class="text-center md:text-left space-y-1 border-l border-slate-900 pl-0 md:pl-8">
        <div class="text-3xl font-black font-outfit text-[#00f0ff] tracking-tight glow-text-cyan">24/7 CMD</div>
        <div class="text-[10px] font-mono uppercase tracking-widest text-slate-500">Active Fleet Dispatch</div>
      </div>
    </div>
  </section>

  <!-- Interactive Operations Divisions Section -->
  <section id="divisions" class="py-24 px-6 max-w-7xl mx-auto space-y-16">
    <div class="text-center space-y-4">
      <span class="text-xs font-mono uppercase tracking-widest text-[#ff6000] font-bold">[SYS_DIVISIONS_MANAGEMENT]</span>
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-white font-outfit uppercase">Our Core Operations Suite</h2>
      <p class="text-slate-400 max-w-xl mx-auto text-sm">Interactive control terminals for Dry Van packing, Reefer cold chain telemetry, and Flatbed stress diagnostics.</p>
    </div>

    <!-- Interactive Tabs Component -->
    <div class="max-w-5xl mx-auto space-y-8" id="operations-tabs-container">
      <!-- Tabs Navigation -->
      <div class="flex flex-col sm:flex-row gap-2 border-b border-slate-900 pb-2">
        <button class="flex-1 text-center py-4 px-3 rounded font-mono text-[10px] uppercase tracking-wider font-bold border border-cyan-500/40 bg-cyan-950/20 text-white transition-all duration-300 tab-btn active" data-target="tab-dry-van">
          DIV_01 // DRY VAN FREIGHT
        </button>
        <button class="flex-1 text-center py-4 px-3 rounded font-mono text-[10px] uppercase tracking-wider font-bold border border-slate-900 text-slate-500 hover:text-slate-350 transition-all duration-300 tab-btn" data-target="tab-reefer">
          DIV_02 // REFRIGERATED CARGO
        </button>
        <button class="flex-1 text-center py-4 px-3 rounded font-mono text-[10px] uppercase tracking-wider font-bold border border-slate-900 text-slate-500 hover:text-slate-350 transition-all duration-300 tab-btn" data-target="tab-flatbed">
          DIV_03 // FLATBED DIVISION
        </button>
        <button class="flex-1 text-center py-4 px-3 rounded font-mono text-[10px] uppercase tracking-wider font-bold border border-slate-900 text-slate-500 hover:text-slate-350 transition-all duration-300 tab-btn" data-target="tab-tracker">
          DIV_04 // ACTIVE MANIFEST TRACKER
        </button>
      </div>

      <!-- Terminal Loader HUD (Animated Console Screen) -->
      <div id="tab-terminal-loader" class="hidden h-[340px] bg-[#020408] border border-cyan-500/20 rounded-lg p-8 flex flex-col justify-center space-y-4 font-mono text-xs text-cyan-400 relative scanlines cyber-corners shadow-2xl">
        <div class="space-y-1.5">
          <div class="text-cyan-500/70 text-[10px]">SYS_CONSOLE // CONNECTING LINK...</div>
          <div id="terminal-loader-cmd" class="text-slate-200 font-bold">&gt; UPLINKING DRY VAN DIRECTIVES...</div>
        </div>
        
        <div class="flex items-center gap-4">
          <div class="w-full h-3 bg-black border border-slate-900 rounded overflow-hidden relative">
            <div id="terminal-loader-bar" class="h-full w-0 bg-gradient-to-r from-[#ff6000] via-[#00f0ff] to-[#ff6000] transition-all duration-300"></div>
          </div>
          <span id="terminal-loader-pct" class="font-bold shrink-0 text-slate-300">0%</span>
        </div>

        <div class="text-[10px] text-slate-500 space-y-1">
          <div>&gt; CACHING LOGISTICS MANIFESTS... OK</div>
          <div class="flex items-center gap-1">
            <span>&gt; INITIATING PANEL SIMULATOR...</span>
            <span class="h-3 w-1.5 bg-[#00f0ff] animate-ping"></span>
          </div>
        </div>
      </div>

      <!-- Tabs Contents -->
      <div class="space-y-6">
        <!-- Tab 1: Dry Van Freight -->
        <div class="tab-panel space-y-6" id="tab-dry-van">
          <div class="bg-[#05070d]/50 border border-slate-900 p-6 sm:p-8 rounded-lg grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="space-y-4">
              <h3 class="text-2xl font-bold text-white font-outfit uppercase tracking-wide">Division 01 // Dry Van Cargo</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Coordinating high-volume commercial dry van transport across North America. Perfect for general merchandise, electronics, consumer goods, and palletized commodities requiring clean, enclosed security.
              </p>
              
              <div class="space-y-2 pt-2">
                <div class="text-[10px] font-mono text-slate-500 uppercase">// Volumetric Packing Simulator</div>
                <div class="bg-black/40 border border-slate-900 p-4 rounded-md space-y-4">
                  <div class="flex justify-between text-[10px] font-mono text-slate-400">
                    <span>Pallets Loaded (0-26):</span>
                    <span id="dry-van-count-label" class="text-cyan-400 font-bold">14 Pallets</span>
                  </div>
                  <input type="range" id="dry-van-slider" min="0" max="26" value="14" class="w-full h-1 bg-slate-900 rounded-lg appearance-none cursor-pointer accent-[#00f0ff]" />
                  
                  <div class="grid grid-cols-3 gap-2 text-[9px] font-mono text-slate-500 pt-1">
                    <div>
                      <span>VOLUMETRIC FILL:</span>
                      <span id="dry-van-fill-val" class="block text-white font-bold">53.8%</span>
                    </div>
                    <div>
                      <span>AXLE LOADING:</span>
                      <span id="dry-van-axle-val" class="block text-cyan-400 font-bold">OPTIMAL</span>
                    </div>
                    <div>
                      <span>EST. WEIGHT:</span>
                      <span id="dry-van-weight-val" class="block text-white font-bold">24,200 LBS</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="bg-black/50 border border-slate-900 rounded-lg p-6 flex flex-col justify-center items-center space-y-4 relative overflow-hidden min-h-[220px]">
              <div class="absolute top-3 left-3 text-[9px] font-mono text-slate-500 tracking-wider">CARGO_HOLD_GRID // 2D SCHEMATIC</div>
              <!-- Dynamic Pallet Grid -->
              <div id="pallet-grid-container" class="grid grid-cols-13 gap-1.5 w-full max-w-md p-3 bg-black/80 border border-slate-900 rounded relative">
                <!-- 26 pallet slots (2 rows of 13) -->
              </div>
              <div class="text-[9px] font-mono text-slate-500 text-center w-full border-t border-slate-900/60 pt-2">
                REAR DOORS ◄───────────────────► TRACTOR CABIN
              </div>
            </div>
          </div>
        </div>

        <!-- Tab 2: Reefer Climate Control -->
        <div class="tab-panel space-y-6 hidden" id="tab-reefer">
          <div class="bg-[#05070d]/50 border border-slate-900 p-6 sm:p-8 rounded-lg grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="space-y-4">
              <h3 class="text-2xl font-bold text-white font-outfit uppercase tracking-wide">Division 02 // Refrigerated (Reefer)</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Precision temperature-controlled transport for frozen foods, pharmaceuticals, and chilled agricultural products. Equipped with real-time temperature telemetry reporting.
              </p>

              <!-- Thermostat Dial HUD -->
              <div class="space-y-2 pt-2">
                <div class="text-[10px] font-mono text-slate-500 uppercase flex items-center justify-between">
                  <span>// Thermostat Controller</span>
                  <span id="reefer-warning" class="text-emerald-500 font-bold animate-pulse">// SYSTEM STABLE</span>
                </div>
                <div class="bg-black/40 border border-slate-900 p-4 rounded-md space-y-4">
                  <div class="flex justify-between text-[10px] font-mono text-slate-400">
                    <span>Target Temperature:</span>
                    <span id="reefer-temp-label" class="text-cyan-400 font-bold">-18.0°C</span>
                  </div>
                  <input type="range" id="reefer-slider" min="-20" max="15" value="-18" class="w-full h-1 bg-slate-900 rounded-lg appearance-none cursor-pointer accent-[#00f0ff]" />
                  
                  <div class="grid grid-cols-3 gap-2 text-[9px] font-mono text-slate-500 pt-1">
                    <div>
                      <span>COMPRESSOR POWER:</span>
                      <span id="reefer-power-val" class="block text-white font-bold">HIGH LOAD</span>
                    </div>
                    <div>
                      <span>STATUS CODE:</span>
                      <span id="reefer-code-val" class="block text-cyan-400 font-bold">COOL_CYCLE_ACTV</span>
                    </div>
                    <div>
                      <span>TEMP READOUT:</span>
                      <span id="reefer-current-val" class="block text-white font-bold">-17.8°C</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="bg-black/50 border border-slate-900 rounded-lg p-6 flex flex-col justify-between items-center relative overflow-hidden min-h-[220px]">
              <div class="absolute top-3 left-3 text-[9px] font-mono text-slate-500 tracking-wider">THERMOGRAPH_TELEMETRY // LIVE FEED</div>
              
              <!-- Live SVG Temperature Wave Graph -->
              <div class="w-full flex-1 flex items-center justify-center pt-6">
                <svg id="thermograph-svg" viewBox="0 0 400 120" class="w-full h-28 bg-black/85 border border-slate-900 rounded">
                  <!-- Dotted threshold line at +4C -->
                  <line x1="0" y1="90" x2="400" y2="90" stroke="#ff6000" stroke-width="1" stroke-dasharray="3, 3" />
                  <text x="310" y="84" fill="#ff6000" font-family="monospace" font-size="8">BREACH LIMIT (+4°C)</text>
                  
                  <!-- Dynamic Wave Path -->
                  <path id="thermograph-wave" d="M 0 60 Q 50 30 100 60 T 200 60 T 300 60 T 400 60" fill="none" stroke="#00f0ff" stroke-width="1.5" />
                  <path id="thermograph-target" d="M 0 60 L 400 60" fill="none" stroke="#00f0ff" stroke-width="1" stroke-dasharray="4, 4" opacity="0.4" />
                </svg>
              </div>
              <div class="text-[9px] font-mono text-slate-500 text-center w-full pt-2 flex justify-between">
                <span>TIME_DELTA: REAL-TIME SEC</span>
                <span>COMPRESSOR CYCLES: OPTIMAL</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Tab 3: Flatbed Open Deck -->
        <div class="tab-panel space-y-6 hidden" id="tab-flatbed">
          <div class="bg-[#05070d]/50 border border-slate-900 p-6 sm:p-8 rounded-lg grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="space-y-4">
              <h3 class="text-2xl font-bold text-white font-outfit uppercase tracking-wide">Division 03 // Open Deck Flatbed</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Industrial transport for machinery, steel coils, and piping. We manage strapping, chain tension securement, and weather tarps for heavy open deck loads.
              </p>

              <!-- Stress & COG Simulator -->
              <div class="space-y-2 pt-2">
                <div class="text-[10px] font-mono text-slate-500 uppercase flex items-center justify-between">
                  <span>// Cargo Center of Gravity (COg) Slider</span>
                  <span id="flatbed-warning" class="text-emerald-500 font-bold">// STRESS NORMAL</span>
                </div>
                <div class="bg-black/40 border border-slate-900 p-4 rounded-md space-y-4">
                  <div class="flex justify-between text-[10px] font-mono text-slate-400">
                    <span>COg Positioning (Front to Rear):</span>
                    <span id="flatbed-cog-label" class="text-[#ff6000] font-bold">50% (Centered)</span>
                  </div>
                  <input type="range" id="flatbed-slider" min="10" max="90" value="50" class="w-full h-1 bg-slate-900 rounded-lg appearance-none cursor-pointer accent-[#ff6000]" />
                  
                  <div class="grid grid-cols-3 gap-2 text-[9px] font-mono text-slate-500 pt-1">
                    <div>
                      <span>DECK DEFL. FLEX:</span>
                      <span id="flatbed-flex-val" class="block text-white font-bold">1.2 MM</span>
                    </div>
                    <div>
                      <span>SECURE TENSION:</span>
                      <span class="block text-[#ff6000] font-bold">8,500 LBS/SQFT</span>
                    </div>
                    <div>
                      <span>AXLE RATIO F/R:</span>
                      <span id="flatbed-ratio-val" class="block text-white font-bold">50 / 50</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="bg-black/50 border border-slate-900 rounded-lg p-6 flex flex-col justify-between items-center relative overflow-hidden min-h-[220px]">
              <div class="absolute top-3 left-3 text-[9px] font-mono text-slate-500 tracking-wider">STRUCTURAL_DECK_FLEX // BLUEPRINT</div>
              
              <!-- Bending Flatbed SVG Blueprint -->
              <div class="w-full flex-1 flex items-center justify-center pt-6">
                <svg id="flatbed-svg" viewBox="0 0 400 125" class="w-full h-32 bg-black/85 border border-slate-900 rounded">
                  <!-- Ground Line -->
                  <line x1="10" y1="110" x2="390" y2="110" stroke="#1e293b" stroke-width="2" />
                  
                  <!-- Tractor Outline (static representation) -->
                  <rect x="20" y="55" width="50" height="40" fill="none" stroke="#475569" stroke-width="1.5" />
                  <circle cx="35" cy="100" r="8" fill="#1e293b" stroke="#475569" stroke-width="1" />
                  <circle cx="58" cy="100" r="8" fill="#1e293b" stroke="#475569" stroke-width="1" />
                  
                  <!-- Trailer Axles (static wheels) -->
                  <circle cx="330" cy="100" r="8" fill="#1e293b" stroke="#475569" stroke-width="1" />
                  <circle cx="350" cy="100" r="8" fill="#1e293b" stroke="#475569" stroke-width="1" />
                  
                  <!-- Bending Flatbed Frame Path -->
                  <path id="flatbed-frame-path" d="M 70 80 Q 210 80 350 80" fill="none" stroke="#ff6000" stroke-width="3" />
                  
                  <!-- Dynamic Cargo Block -->
                  <rect id="flatbed-cargo-block" x="190" y="45" width="40" height="30" fill="none" stroke="#00f0ff" stroke-width="1.5" />
                  
                  <!-- Force Vector Arrows -->
                  <path id="vector-arrow" d="M 210 20 L 210 40 M 205 35 L 210 40 L 215 35" fill="none" stroke="#00f0ff" stroke-width="1.5" />
                </svg>
              </div>
              <div class="text-[9px] font-mono text-slate-500 text-center w-full pt-2 flex justify-between">
                <span>DECK TOLERANCE: 45,000 LBS MAX</span>
                <span>FLEX RATIO: STATIC LOAD</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Tab 4: Live Telemetry & Command Ticker -->
        <div class="tab-panel space-y-6 hidden" id="tab-tracker">
          <div class="bg-[#05070d]/50 border border-slate-900 p-6 sm:p-8 rounded-lg space-y-6">
            <div class="space-y-2">
              <h3 class="text-2xl font-bold text-white font-outfit uppercase tracking-wide">Division 04 // Interactive Command Dispatch Console</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Connect to active fleet transit beacons. Type commands directly into the terminal below (e.g. <span class="text-cyan-400 font-mono">status</span>, <span class="text-cyan-400 font-mono">route</span>, <span class="text-cyan-400 font-mono">compressor</span>, <span class="text-cyan-400 font-mono">systems</span>, or <span class="text-cyan-400 font-mono">help</span>) to query real-time diagnostics.
              </p>
            </div>

            <!-- Tracker Terminal Console Wrapper -->
            <div class="bg-black/80 border border-slate-800 rounded-lg p-6 font-mono text-xs space-y-4 relative scanlines cyber-corners shadow-xl">
              <div class="flex items-center justify-between border-b border-slate-950 pb-3">
                <span class="text-[#00f0ff] font-bold flex items-center gap-1.5">
                  <span class="h-2 w-2 rounded-full bg-[#00f0ff] animate-pulse shadow-[0_0_6px_#00f0ff]"></span>
                  SYS_TRACKER_DISPATCH // TERMINAL CORE
                </span>
                <span class="text-slate-500 text-[10px]">UPLINK STATUS: ESTABLISHED</span>
              </div>

              <!-- Console output panel -->
              <div id="telemetry-output-panel" class="border border-slate-900 bg-slate-950/70 p-4 rounded text-slate-400 min-h-[180px] max-h-[300px] overflow-y-auto space-y-1.5 select-text leading-relaxed">
                <div>&gt; TERMINAL READY. TYPE 'help' FOR LIST OF SYSTEM DIRECTIVES.</div>
              </div>

              <!-- Console Input Area -->
              <div class="flex items-center bg-[#020408] border border-slate-850 rounded px-3 py-2.5 text-slate-350 focus-within:border-cyan-500 transition-colors">
                <span class="text-[#00f0ff] font-bold mr-2">&gt;</span>
                <input type="text" id="telemetry-input" class="w-full bg-transparent focus:outline-none text-white text-xs placeholder:text-slate-800 uppercase font-mono" placeholder="type status, route, compressor, or systems..." autocomplete="off" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Fleet Showcase Section (With High-Fidelity Imagery) -->
  <section id="fleet" class="py-24 px-6 max-w-7xl mx-auto space-y-16">
    <div class="text-center space-y-4">
      <span class="text-xs font-mono uppercase tracking-widest text-[#ff6000] font-bold">[SYS_ASSETS_SPECIFICATION]</span>
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-white font-outfit uppercase">Engineered Fleet Capabilities</h2>
      <p class="text-slate-400 max-w-xl mx-auto text-sm">Commercial dry, chilled, and open flatbed carriers outfitted with custom securement assets.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {fleetItems.map((item) => (
        <div class="bg-[#05070d]/60 rounded-lg border border-slate-900 overflow-hidden flex flex-col group hover:border-cyan-500/35 hover:-translate-y-1 transition-all duration-300 shadow-xl">
          <!-- Render Image -->
          <div class="h-48 overflow-hidden relative border-b border-slate-900">
            <img 
              src={getFleetImage(item.id)} 
              alt={item.data.title} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
            />
            <div class="absolute top-4 right-4 bg-slate-950/80 px-2 py-1 border border-slate-800 rounded text-[9px] font-mono text-cyan-400 font-bold uppercase tracking-widest">
              Standard Freight
            </div>
          </div>
          
          <div class="p-6 flex-1 flex flex-col justify-between space-y-6">
            <div class="space-y-3">
              <h3 class="text-xl font-bold text-white font-outfit tracking-wide uppercase">{item.data.title}</h3>
              <p class="text-slate-450 text-xs leading-relaxed">
                {item.body}
              </p>
            </div>
            
            <div class="space-y-4 pt-4 border-t border-slate-900/60">
              <div class="grid grid-cols-2 gap-2 text-[10px] font-mono">
                <div>
                  <span class="text-slate-500 block">MAX CARGO LOAD:</span>
                  <span class="text-slate-300 font-bold">{item.data.capacityTonnage * 2000} LBS</span>
                </div>
                <div>
                  <span class="text-slate-500 block">AXLE LAYOUT:</span>
                  <span class="text-slate-350 font-bold">5-Axle Config</span>
                </div>
              </div>
              
              {item.data.equipmentSpecs && (
                <div class="space-y-1.5">
                  <span class="text-[10px] font-mono text-slate-500 block uppercase">Operational Features:</span>
                  <ul class="list-disc pl-4 text-[10px] text-slate-450 space-y-1 font-mono">
                    {item.data.equipmentSpecs.map((spec) => (
                      <li>{spec}</li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Live Transit Corridors Map Section -->
  <section id="corridors" class="py-24 bg-[#05070d] border-y border-slate-950 px-6">
